# Fixed gateway maintenance page for Phase 3 bootstrap / failure retention.
{
  auto_https off
}

:443 {
  tls /srv/certs/cert.pem /srv/certs/key.pem

  @internal_deploy_readiness path /api/system/deploy-readiness/internal
  respond @internal_deploy_readiness 404

  root * /srv/phase2-maintenance
  rewrite * /index.html
  file_server
}

:80 {
  @internal_deploy_readiness path /api/system/deploy-readiness/internal
  respond @internal_deploy_readiness 404

  redir https://{host}{uri} temporary
}
