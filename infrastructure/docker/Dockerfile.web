# syntax=docker/dockerfile:1
FROM node:20-alpine AS build
WORKDIR /app
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json tsconfig.base.json ./
COPY apps/web/package.json apps/web/
COPY packages ./packages
RUN corepack enable && pnpm install --frozen-lockfile
WORKDIR /app/packages/shared-types
RUN pnpm build
WORKDIR /app/packages/part-search-core
RUN pnpm build
WORKDIR /app
COPY apps/web ./apps/web
# NFCエージェントのWebSocket URLをビルド時に設定可能にする
ARG VITE_AGENT_WS_URL=ws://localhost:7071/stream
ENV VITE_AGENT_WS_URL=${VITE_AGENT_WS_URL}
# ラズパイ5のAPIサーバーのURLをビルド時に設定可能にする
ARG VITE_API_BASE_URL=/api
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
ARG VITE_KIOSK_TARGET_LOCATION_SELECTOR_ENABLED=true
ENV VITE_KIOSK_TARGET_LOCATION_SELECTOR_ENABLED=${VITE_KIOSK_TARGET_LOCATION_SELECTOR_ENABLED}
ARG VITE_KIOSK_DUE_MGMT_LAYOUT_V2_ENABLED=false
ENV VITE_KIOSK_DUE_MGMT_LAYOUT_V2_ENABLED=${VITE_KIOSK_DUE_MGMT_LAYOUT_V2_ENABLED}
RUN cd apps/web && pnpm run build

FROM golang:1.26.2-alpine AS caddy-build
WORKDIR /src
ARG TARGETOS=linux
ARG TARGETARCH
RUN apk add --no-cache git build-base
RUN cat <<'EOF' > go.mod
module caddybuilder

go 1.26

require github.com/caddyserver/caddy/v2 v2.11.2

replace google.golang.org/grpc => google.golang.org/grpc v1.79.3

replace github.com/go-jose/go-jose/v3 => github.com/go-jose/go-jose/v3 v3.0.5
replace github.com/go-jose/go-jose/v4 => github.com/go-jose/go-jose/v4 v4.1.4
EOF
RUN cat <<'EOF' > main.go
package main

import (
	_ "github.com/caddyserver/caddy/v2/modules/standard"
	caddycmd "github.com/caddyserver/caddy/v2/cmd"
)

func main() {
	caddycmd.Main()
}
EOF
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -mod=mod -trimpath -ldflags="-s -w" -o /usr/bin/caddy main.go

FROM alpine:3.23
WORKDIR /srv
# envsubstをインストールし、Trivy指摘のzlibを修正版へ更新する
RUN apk add --no-cache ca-certificates gettext libcap \
  && apk upgrade --no-cache zlib
COPY --from=caddy-build /usr/bin/caddy /usr/bin/caddy
RUN setcap cap_net_bind_service=+ep /usr/bin/caddy
COPY --from=build /app/apps/web/dist ./site
COPY infrastructure/docker/Caddyfile ./Caddyfile
COPY infrastructure/docker/Caddyfile.production ./Caddyfile.production
COPY infrastructure/docker/Caddyfile.local.template ./Caddyfile.local.template
# Caddyfileの選択ロジック:
# 1. USE_LOCAL_CERTS環境変数が設定されている場合 → Caddyfile.local（自己署名証明書）
# 2. DOMAIN環境変数が設定されている場合 → Caddyfile.production（Let's Encrypt）
# 3. それ以外 → Caddyfile（HTTPのみ、開発用）
CMD ["sh", "-c", "if [ -n \"$USE_LOCAL_CERTS\" ]; then export NFC_AGENT_HOST=${NFC_AGENT_HOST:-192.168.10.223} && envsubst < /srv/Caddyfile.local.template > /srv/Caddyfile.local && caddy run --config /srv/Caddyfile.local; elif [ -n \"$DOMAIN\" ]; then caddy run --config /srv/Caddyfile.production; else caddy run --config /srv/Caddyfile; fi"]
