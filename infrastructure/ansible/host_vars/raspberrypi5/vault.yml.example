# このファイルは `ansible-vault encrypt` で暗号化した `vault.yml` のサンプルです。
# 以下の値を実環境のシークレットで上書きし、`mv vault.yml.example vault.yml`
# したあとに ansible-vault で暗号化してください。

vault_api_jwt_access_secret: "change-me-access"
vault_api_jwt_refresh_secret: "change-me-refresh"
vault_status_agent_client_key: "client-key-raspberrypi5-server"
vault_api_local_llm_shared_token: ""
# オンデマンド起停（DGX system-prod）。空なら API は shared トークンを制御ヘッダにも流用
vault_api_local_llm_runtime_control_token: ""

# Tailscale preauth key (reusable, tagged推奨)
vault_tailscale_auth_key: ""

# キオスクお問い合わせ（Slack通知）
# 形式: https://hooks.slack.com/services/...
vault_slack_kiosk_support_webhook_url: ""

# Dropbox OAuth 2.0設定
# NOTE: Dropbox App Console (https://www.dropbox.com/developers/apps) で取得
# App Key: Dropbox App ConsoleのSettingsタブから取得
# App Secret: Dropbox App ConsoleのSettingsタブから取得（Showボタンで表示）
# Refresh Token: OAuth認証フローで取得（/api/backup/oauth/authorize → /callback）
# Access Token: Refresh Tokenから自動更新されるため、通常は空でOK（必要に応じて設定）
vault_dropbox_app_key: ""
vault_dropbox_app_secret: ""
vault_dropbox_refresh_token: ""
vault_dropbox_access_token: ""

# 写真持出: GOOD 類似ギャラリー + VLM 補助（Pi5 API のみ参照。未使用なら false/空でよい）
# vault_photo_tool_embedding_enabled: "false"
# vault_photo_tool_embedding_url: ""
# vault_photo_tool_embedding_api_key: ""
# vault_photo_tool_embedding_model_id: ""
# vault_photo_tool_embedding_dimension: "512"
# シャドー: 2回目VLMはログのみ（本番列は1回目のまま）
# vault_photo_tool_label_assist_shadow_enabled: "false"
# アクティブ: 埋め込みONかつゲート通過時のみ2回目を photoToolDisplayName に採用しうる（docs/decisions/ADR-20260404）
# vault_photo_tool_label_assist_active_enabled: "false"
# vault_photo_tool_label_assist_active_min_gallery_rows: "5"

