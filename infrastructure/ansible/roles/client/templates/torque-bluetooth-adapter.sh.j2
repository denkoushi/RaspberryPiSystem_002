#!/usr/bin/env bash
set -euo pipefail

readonly expected_vendor='{{ torque_agent_bluetooth_adapter.usb_vendor_id }}'
readonly expected_product='{{ torque_agent_bluetooth_adapter.usb_product_id }}'
readonly requested_operation="${1:-}"
hci_name="${requested_operation}"
readonly sys_root="$(readlink -f "${TORQUE_BLUETOOTH_SYS_ROOT:-/sys}")"
readonly bluetooth_class_root="${sys_root}/class/bluetooth"
readonly rfkill_class_root="${sys_root}/class/rfkill"
readonly btmgmt_bin="${TORQUE_BLUETOOTH_BTMGMT_BIN:-btmgmt}"
readonly timeout_bin="${TORQUE_BLUETOOTH_TIMEOUT_BIN:-timeout}"
readonly command_timeout_seconds="${TORQUE_BLUETOOTH_COMMAND_TIMEOUT_SECONDS:-4}"
readonly retry_sleep_seconds="${TORQUE_BLUETOOTH_RETRY_SLEEP_SECONDS:-1}"

controller_usb_parent() {
  local controller_name="$1"
  local controller_class_path="${bluetooth_class_root}/${controller_name}"
  local candidate
  local vendor
  local product

  [[ -e "${controller_class_path}/device" ]] || return 1
  candidate="$(readlink -f "${controller_class_path}/device")"
  while [[ "${candidate}" == "${sys_root}"/* ]]; do
    if [[ -r "${candidate}/idVendor" && -r "${candidate}/idProduct" ]]; then
      vendor="$(tr '[:upper:]' '[:lower:]' < "${candidate}/idVendor")"
      product="$(tr '[:upper:]' '[:lower:]' < "${candidate}/idProduct")"
      if [[ "${vendor}" == "${expected_vendor}" && "${product}" == "${expected_product}" ]]; then
        printf '%s\n' "${candidate}"
        return 0
      fi
    fi
    candidate="$(dirname "${candidate}")"
  done
  return 1
}

discover_exact_controller() {
  local class_path
  local controller_name
  local matched_controller=''
  local match_count=0

  for class_path in "${bluetooth_class_root}"/hci[0-9]*; do
    [[ -e "${class_path}/device" ]] || continue
    controller_name="${class_path##*/}"
    [[ "${controller_name}" =~ ^hci[0-9]+$ ]] || continue
    if controller_usb_parent "${controller_name}" >/dev/null; then
      matched_controller="${controller_name}"
      match_count=$((match_count + 1))
    fi
  done
  if [[ "${match_count}" -ne 1 ]]; then
    echo "expected exactly one configured external Bluetooth controller; found ${match_count}" >&2
    return 8
  fi
  printf '%s\n' "${matched_controller}"
}

controller_info_is_powered() {
  awk '
    /^[[:space:]]*current settings:/ {
      for (field_number = 1; field_number <= NF; field_number += 1) {
        if ($field_number == "powered") found = 1
      }
    }
    END { exit(found ? 0 : 1) }
  '
}

btmgmt_is_timeout_status() {
  local status="$1"
  [[ "${status}" -eq 124 || "${status}" -eq 137 ]]
}

run_btmgmt() {
  local operation="$1"
  local command_output
  local command_status
  local detail
  local result
  local stdin_dir
  local stdin_fifo
  shift

  # BlueZ btmgmt 5.82 attaches stdin even for non-interactive commands.  A
  # systemd service's closed stdin prevents the command from being dispatched.
  # Keep both ends of a no-data FIFO open only for the bounded invocation.
  stdin_dir="$(mktemp -d "${TMPDIR:-/tmp}/torque-btmgmt-stdin.XXXXXX")"
  stdin_fifo="${stdin_dir}/stdin"
  mkfifo -m 600 "${stdin_fifo}"
  set +e
  command_output="$(
    {
      exec 9<> "${stdin_fifo}"
      "${timeout_bin}" --signal=TERM --kill-after=1 "${command_timeout_seconds}" "${btmgmt_bin}" "$@" <&9 2>&1
      command_status=$?
      exec 9>&-
      exit "${command_status}"
    }
  )"
  command_status=$?
  set -e
  rm -f "${stdin_fifo}"
  rmdir "${stdin_dir}"
  if [[ "${command_status}" -ne 0 ]]; then
    detail="$(printf '%s' "${command_output}" | LC_ALL=C tr '\n\r\t' '   ' | LC_ALL=C tr -c '[:print:]' '?' | tr -s ' ' | cut -c1-240)"
    [[ -n "${detail}" ]] || detail='none'
    result='exit'
    if btmgmt_is_timeout_status "${command_status}"; then
      result='timeout'
    fi
    printf 'torque-bluetooth operation=%s result=%s status=%s detail=%s\n' \
      "${operation}" "${result}" "${command_status}" "${detail}" >&2
    return "${command_status}"
  fi
  printf '%s\n' "${command_output}"
}

self_test_parser() {
  printf '%s\n' 'current settings: powered connectable bondable' \
    | controller_info_is_powered
  if printf '%s\n' 'current settings: connectable bondable' \
    | controller_info_is_powered; then
    echo "Bluetooth controller parser accepted an unpowered fixture" >&2
    return 9
  fi
}

probe_exact_controller() {
  local controller_name
  local controller_index
  local controller_info
  local command_status

  self_test_parser
  controller_name="$(discover_exact_controller)"
  controller_index="${controller_name#hci}"
  for _ in {1..3}; do
    if controller_info="$(run_btmgmt info --index "${controller_index}" info)"; then
      if ! controller_info_is_powered <<< "${controller_info}"; then
        echo "configured external Bluetooth controller is not powered" >&2
        return 7
      fi
    else
      command_status=$?
      if btmgmt_is_timeout_status "${command_status}"; then
        echo "configured external Bluetooth controller management info did not respond" >&2
        return 10
      fi
      echo "configured external Bluetooth controller management info failed" >&2
      return 12
    fi
  done
}

status_exact_controller() {
  local controller_name
  local controller_index
  local controller_info
  local controller_path
  local rfkill_path
  local rfkill_device
  local powered=false

  controller_name="$(discover_exact_controller)"
  controller_path="$(readlink -f "${bluetooth_class_root}/${controller_name}")"
  for rfkill_path in "${rfkill_class_root}"/rfkill*; do
    [[ -r "${rfkill_path}/type" && "$(< "${rfkill_path}/type")" == bluetooth ]] || continue
    rfkill_device="$(readlink -f "${rfkill_path}/device")"
    if [[ "${rfkill_device}" == "${controller_path}" || "${rfkill_device}" == "${controller_path}/"* ]]; then
      if [[ "$(< "${rfkill_path}/hard")" == 1 || "$(< "${rfkill_path}/soft")" == 1 ]]; then
        printf '{"controller":"%s","powered":false}\n' "${controller_name}"
        return 0
      fi
    fi
  done
  controller_index="${controller_name#hci}"
  controller_info="$(run_btmgmt info --index "${controller_index}" info)"
  if controller_info_is_powered <<< "${controller_info}"; then
    powered=true
  fi
  printf '{"controller":"%s","powered":%s}\n' "${controller_name}" "${powered}"
}

power_off_exact_controller() {
  local controller_name
  local controller_path
  local rfkill_path
  local rfkill_device
  local match_count=0

  controller_name="$(discover_exact_controller)"
  controller_path="$(readlink -f "${bluetooth_class_root}/${controller_name}")"
  for rfkill_path in "${rfkill_class_root}"/rfkill*; do
    [[ -r "${rfkill_path}/type" && "$(< "${rfkill_path}/type")" == bluetooth ]] || continue
    rfkill_device="$(readlink -f "${rfkill_path}/device")"
    if [[ "${rfkill_device}" == "${controller_path}" || "${rfkill_device}" == "${controller_path}/"* ]]; then
      match_count=$((match_count + 1))
      # Soft-block first: this is the bounded fail-closed operation. It targets
      # only the rfkill node whose device resolves to the exact VID/PID controller.
      if [[ "$(< "${rfkill_path}/soft")" != 1 ]]; then
        printf '1\n' > "${rfkill_path}/soft"
      fi
    fi
  done
  if [[ "${match_count}" -ne 1 ]]; then
    echo "expected exactly one rfkill entry for configured external Bluetooth controller; found ${match_count}" >&2
    return 5
  fi
}

if [[ "${hci_name}" == '--discover' ]]; then
  discover_exact_controller
  exit 0
fi

if [[ "${hci_name}" == '--self-test' ]]; then
  self_test_parser
  exit 0
fi

if [[ "${hci_name}" == '--probe' ]]; then
  probe_exact_controller
  exit 0
fi

if [[ "${hci_name}" == '--status' ]]; then
  status_exact_controller
  exit 0
fi

if [[ "${hci_name}" == '--power-off' ]]; then
  power_off_exact_controller
  exit 0
fi

if [[ "${hci_name}" == '--power-on' ]]; then
  hci_name="$(discover_exact_controller)"
fi

if [[ ! "${hci_name}" =~ ^hci[0-9]+$ ]]; then
  echo "invalid Bluetooth controller name" >&2
  exit 2
fi

readonly selected_class_path="${bluetooth_class_root}/${hci_name}"
for _ in {1..15}; do
  [[ -e "${selected_class_path}/device" ]] && break
  sleep 1
done
[[ -e "${selected_class_path}/device" ]]

if ! controller_usb_parent "${hci_name}" >/dev/null; then
  echo "Bluetooth controller does not match configured USB identity" >&2
  exit 3
fi

controller_path="$(readlink -f "${selected_class_path}")"
rfkill_matched=false
for rfkill_path in "${rfkill_class_root}"/rfkill*; do
  [[ -r "${rfkill_path}/type" && "$(< "${rfkill_path}/type")" == bluetooth ]] || continue
  rfkill_device="$(readlink -f "${rfkill_path}/device")"
  if [[ "${rfkill_device}" == "${controller_path}" || "${rfkill_device}" == "${controller_path}/"* ]]; then
    rfkill_matched=true
    if [[ "$(< "${rfkill_path}/hard")" == 1 ]]; then
      echo "configured external Bluetooth controller is hard blocked" >&2
      exit 4
    fi
    if [[ "$(< "${rfkill_path}/soft")" == 1 ]]; then
      printf '0\n' > "${rfkill_path}/soft"
    fi
  fi
done

if [[ "${rfkill_matched}" != true ]]; then
  echo "no rfkill entry matched configured external Bluetooth controller" >&2
  exit 5
fi

hci_index="${hci_name#hci}"
info_succeeded=false
power_succeeded=false
info_timed_out=false
power_timed_out=false
info_failed=false
power_failed=false
for _ in {1..6}; do
  if controller_info="$(run_btmgmt info --index "${hci_index}" info)"; then
    info_succeeded=true
    if controller_info_is_powered <<< "${controller_info}"; then
      exit 0
    fi
  else
    command_status=$?
    if btmgmt_is_timeout_status "${command_status}"; then
      info_timed_out=true
    else
      info_failed=true
    fi
  fi
  if run_btmgmt power-on --index "${hci_index}" power on >/dev/null; then
    power_succeeded=true
  else
    command_status=$?
    if btmgmt_is_timeout_status "${command_status}"; then
      power_timed_out=true
    else
      power_failed=true
    fi
  fi
  sleep "${retry_sleep_seconds}"
done

if [[ "${info_succeeded}" != true ]]; then
  if [[ "${info_timed_out}" == true ]]; then
    echo "configured external Bluetooth controller management info did not respond" >&2
    exit 10
  fi
  if [[ "${info_failed}" == true ]]; then
    echo "configured external Bluetooth controller management info failed" >&2
    exit 12
  fi
fi
if [[ "${power_succeeded}" != true ]]; then
  if [[ "${power_timed_out}" == true ]]; then
    echo "configured external Bluetooth controller power request did not respond" >&2
    exit 11
  fi
  if [[ "${power_failed}" == true ]]; then
    echo "configured external Bluetooth controller power request failed" >&2
    exit 13
  fi
fi
echo "configured external Bluetooth controller did not become powered" >&2
exit 7
