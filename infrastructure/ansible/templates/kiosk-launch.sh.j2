{% set kiosk_origin = kiosk_url | regex_replace('(/.*)$', '') %}
#!/usr/bin/env bash
set -euo pipefail

export DISPLAY={{ kiosk_display | default(':0') }}
export XAUTHORITY=/home/{{ ansible_user }}/.Xauthority
export GTK_USE_PORTAL=0
export XDG_CURRENT_DESKTOP={{ kiosk_desktop | default('LXDE') }}
export XDG_SESSION_TYPE=x11
export DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/$(id -u)/bus
# キーリングを無効化（パスワードダイアログを表示しない）
export GNOME_KEYRING_CONTROL=""
export SSH_AUTH_SOCK=""
# NetworkManagerの認証ダイアログを抑制
export NM_CLI_NO_TERSE=1
export NM_CLI_NO_ASK_PASSWORD=1
# 日本語入力環境変数
export GTK_IM_MODULE=ibus
export XMODIFIERS=@im=ibus
export QT_IM_MODULE=ibus

# 画面上部のパネルを非表示にする（labwc + wf-panel-pi）
pkill -f "lwrespawn /usr/bin/wf-panel-pi" || true
pkill -x wf-panel-pi || true

BROWSER_ENGINE="{{ kiosk_browser_engine | default('chromium') | lower }}"
BROWSER_MODE="{{ kiosk_browser_mode | default('app-like') | lower }}"
BROWSER_BIN="{{ kiosk_browser_exec_path | default(kiosk_browser_chromium_binary | default('/usr/bin/chromium-browser')) }}"
KIOSK_FF_MINIMIZE={% if kiosk_firefox_minimize_chrome_enabled | default(true) | bool %}1{% else %}0{% endif %}
FF_PROFILE="/home/{{ ansible_user }}/.mozilla/firefox/{{ kiosk_firefox_profile_dirname | default('kiosk-system') }}"

COMMON_FLAGS=(
{% for flag in kiosk_browser_flags_common | default([]) %}
  {{ flag }}
{% endfor %}
)

if [[ "${BROWSER_ENGINE}" == "chromium" ]]; then
  export CHROME_WRAPPER="${BROWSER_BIN}"
  CHROMIUM_FLAGS=(
{% for flag in kiosk_browser_flags_chromium | default([]) %}
    {{ flag }}
{% endfor %}
    --app="{{ kiosk_url }}"
    --unsafely-treat-insecure-origin-as-secure={{ kiosk_origin }},http://localhost:7071
    "${COMMON_FLAGS[@]}"
  )
  exec "${BROWSER_BIN}" "${CHROMIUM_FLAGS[@]}"
elif [[ "${BROWSER_ENGINE}" == "firefox" ]]; then
  FIREFOX_FLAGS=(
{% if (kiosk_browser_mode | default('app-like') | lower) == 'kiosk' %}
{% for flag in kiosk_browser_flags_firefox_kiosk | default(['--kiosk']) %}
    {{ flag }}
{% endfor %}
{% else %}
{% for flag in kiosk_browser_flags_firefox_app_like | default(['--new-window']) %}
    {{ flag }}
{% endfor %}
{% endif %}
    "${COMMON_FLAGS[@]}"
  )
  PROFILE_ARGS=()
  if [[ "${KIOSK_FF_MINIMIZE}" -eq 1 ]] && [[ -d "${FF_PROFILE}" ]]; then
    PROFILE_ARGS=(--profile "${FF_PROFILE}")
  fi
  exec "${BROWSER_BIN}" "${PROFILE_ARGS[@]}" "${FIREFOX_FLAGS[@]}" "{{ kiosk_url }}"
else
  echo "Unsupported kiosk browser engine: ${BROWSER_ENGINE}" >&2
  exit 1
fi
