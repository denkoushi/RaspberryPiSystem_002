# Generated by Ansible (roles/client). Do not edit on hosts; change inventory and re-apply.
# haizen_agent の API_BASE_URL は **オリジン（例: https://100.x.x.x）** のみ。末尾に /api を付けない。
# 詳細: docs/runbooks/zero2w-tanaban-edge-setup.md

API_BASE_URL="{{ haizen_agent_api_base_url }}"
X_CLIENT_KEY="{{ haizen_agent_client_key | default(status_agent_client_key | default('')) }}"
# insecure: 自己署名 TLS を許容 / system: OS 証明書ストアで検証（Let's Encrypt 等を Pi5 に載せた後に使用）
HAIZEN_TLS_VERIFY_MODE="{{ haizen_agent_tls_verify_mode | default('insecure') }}"
# 分配番号認識: 省略または legacy_short_numeric（既定・短い整数のみ）。誤認を抑える場合は prefixed_dist とし QR は DIST:n 形式を使用。
# HAIZEN_DISTRIBUTION_MODE=prefixed_dist
{% if haizen_agent_hid_device | default('') | length > 0 %}
HAIZEN_HID_DEVICE="{{ haizen_agent_hid_device }}"
{% endif %}
