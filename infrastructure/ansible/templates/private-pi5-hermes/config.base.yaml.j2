# Shared Hermes security baseline (chat + tools profiles)
terminal:
  backend: docker
  container_persistent: false
  docker_forward_env: []
  env_passthrough: []
  container_memory: 2048
  container_cpu: 1
  # Hermes default container_disk (51200) sets Docker --storage-opt, which requires
  # overlay on XFS with pquota. Pi5 ext4 fails container create → file tools timeout.
  container_disk: 0
{% if hermes_terminal_mount_cwd_to_workspace | default(false) | bool %}
  docker_mount_cwd_to_workspace: true
{% endif %}
{% if (hermes_terminal_docker_volumes | default([])) | length > 0 %}
  docker_volumes:
{% for mount in hermes_terminal_docker_volumes | default([]) %}
    - "{{ mount }}"
{% endfor %}
{% endif %}

approvals:
  mode: manual
  timeout: 120

security:
  allow_lazy_installs: false
  allow_private_urls: true
  tirith_enabled: true
  tirith_fail_open: false
{% if (hermes_security_extra_lines | default('') | trim) | length > 0 %}
{{ hermes_security_extra_lines | indent(2, true) }}
{% endif %}

display:
  tool_progress: "off"
  show_reasoning: false
