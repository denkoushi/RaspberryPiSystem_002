{%- set hermes_security_extra_lines -%}
{% if private_pi5_hermes_tools_web_enabled | default(false) | bool %}
website_blocklist:
  enabled: true
  domains:
{% for domain in private_pi5_hermes_website_blocklist_domains | default([]) %}
    - "{{ domain }}"
{% endfor %}
  shared_files: []
{% endif %}
{%- endset -%}
# Hermes Agent — tools profile (Phase D1 / D2 / D3 / D4)
{% include 'config.base.yaml.j2' %}

model:
  default: {{ private_pi5_hermes_dgx_model | default('system-prod-primary') }}
  provider: custom:dgx-system-prod
  base_url: {{ private_pi5_hermes_dgx_base_url | default('http://100.118.82.72:38081') }}/v1
  context_length: {{ private_pi5_hermes_context_length | default(65536) }}
  max_tokens: {{ private_pi5_hermes_tools_max_tokens | default(512) }}
  reasoning_effort: {{ private_pi5_hermes_reasoning_effort | default('none') }}

custom_providers:
  - name: dgx-system-prod
    base_url: {{ private_pi5_hermes_dgx_base_url | default('http://100.118.82.72:38081') }}/v1
    key_env: OPENAI_API_KEY
    default_model: {{ private_pi5_hermes_dgx_model | default('system-prod-primary') }}
    extra_body:
      chat_template_kwargs:
        enable_thinking: false

compression:
  enabled: false

auxiliary:
  title_generation:
    provider: main
    timeout: 20

memory:
  memory_enabled: false
  user_profile_enabled: false

{% if private_pi5_hermes_tools_browser_enabled | default(false) | bool %}
browser:
  auto_local_for_private_urls: true
  inactivity_timeout: 120
  command_timeout: 30
  record_sessions: false
{% endif %}

agent:
  reasoning_effort: {{ private_pi5_hermes_reasoning_effort | default('none') }}
  system_prompt: |
{% if (private_pi5_hermes_tools_system_prompt | default('') | trim) | length > 0 %}
{{ private_pi5_hermes_tools_system_prompt | trim | indent(4, first=True) }}
{% elif private_pi5_hermes_tools_browser_enabled | default(false) | bool %}
    私用 Pi5 の Hermes 作業用プロファイル（Phase D4）です。
    file ツールは {{ private_pi5_hermes_tools_data_dir }}/workspace（コンテナ内 /workspace）のみ操作してください。
    web / browser は {{ private_pi5_hermes_dgx_base_url | default('http://100.118.82.72:38081') }} 配下の HTTP のみ（HTTPS・LAN・localhost は blocklist で拒否）。
    クラウド browser プロバイダは使用しません。危険な操作は手動承認が必要です。
{% elif private_pi5_hermes_tools_web_enabled | default(false) | bool %}
    私用 Pi5 の Hermes 作業用プロファイル（Phase D3）です。
    file ツールは {{ private_pi5_hermes_tools_data_dir }}/workspace（コンテナ内 /workspace）のみ操作してください。
    web ツールは {{ private_pi5_hermes_dgx_base_url | default('http://100.118.82.72:38081') }} 配下の HTTP のみ利用してください（HTTPS・LAN・localhost は不可）。
    workspace 外のパス・削除の連鎖・システム設定変更は行わないでください。危険な操作は手動承認が必要です。
{% elif private_pi5_hermes_tools_file_enabled | default(false) | bool %}
    私用 Pi5 の Hermes 作業用プロファイル（Phase D2）です。
    file ツールは {{ private_pi5_hermes_tools_data_dir }}/workspace（コンテナ内 /workspace）のみ操作してください。
    workspace 外のパス・削除の連鎖・システム設定変更は行わないでください。危険な操作は手動承認が必要です。
{% else %}
    私用 Pi5 の Hermes 作業用プロファイル（Phase D1）です。
    ツールはまだ無効です。将来の file/web/browser 有効化前に境界ポリシーを確認してください。
{% endif %}
  disabled_toolsets:
{% if not (private_pi5_hermes_tools_web_enabled | default(false) | bool) %}
    - web
{% endif %}
{% if not (private_pi5_hermes_tools_browser_enabled | default(false) | bool) %}
    - browser
{% endif %}
    - terminal
{% if not (private_pi5_hermes_tools_file_enabled | default(false) | bool) %}
    - file
{% endif %}
    - code_execution
    - vision
    - image_gen
    - video
    - video_gen
    - x_search
    - moa
    - tts
    - skills
    - todo
    - memory
    - session_search
    - clarify
    - delegation
    - cronjob
    - messaging
    - kanban
    - discord
    - discord_admin
    - homeassistant
    - spotify
    - yuanbao
    - computer_use

platform_toolsets:
  discord: []
