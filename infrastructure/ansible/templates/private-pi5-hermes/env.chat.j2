LIFE_PILOT_INTEREST_WEB_SEARCH_LANG={{ private_pi5_hermes_life_interest_web_search_lang | default('') | trim }}
LIFE_PILOT_INTEREST_WEB_SEARCH_UI_LANG={{ private_pi5_hermes_life_interest_web_search_ui_lang | default('') | trim }}
LIFE_PILOT_INTEREST_WEB_SEARCH_FRESHNESS={{ private_pi5_hermes_life_interest_web_search_freshness | default('') | trim }}
LIFE_PILOT_INTEREST_WEB_SEARCH_SAFESEARCH={{ private_pi5_hermes_life_interest_web_search_safesearch | default('') | trim }}
LIFE_PILOT_INTEREST_WEB_SEARCH_COUNT={{ private_pi5_hermes_life_interest_web_search_count | default('') | trim }}
LIFE_PILOT_INTEREST_BRAVE_SEARCH_API_KEY={{ private_pi5_hermes_life_interest_brave_search_api_key | default('') | trim }}
{% endif %}
{% endif %}
