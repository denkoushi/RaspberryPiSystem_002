# Hermes chat profile — secrets (0600)
OPENAI_API_KEY={{ private_pi5_hermes_chat_dgx_llm_token }}

{% if (private_pi5_hermes_discord_bot_token | default('') | trim) | length > 0 %}
DISCORD_BOT_TOKEN={{ private_pi5_hermes_discord_bot_token }}
DISCORD_ALLOWED_USERS={{ private_pi5_hermes_discord_allowed_users | default('') }}
DISCORD_REQUIRE_MENTION={{ private_pi5_hermes_discord_require_mention | default(false) | bool }}
{% endif %}

{% if private_pi5_hermes_life_pilot_enabled | default(false) | bool %}
HERMES_LIFE_DISCORD_INBOX_ENABLED={{ private_pi5_hermes_life_discord_inbox_enabled | default(true) | bool }}
HERMES_LIFE_DISCORD_INBOX_CHANNEL_IDS={{ private_pi5_hermes_life_discord_inbox_channel_ids | default('') }}
HERMES_LIFE_DISCORD_INBOX_CAPTURE_ALL={{ private_pi5_hermes_life_discord_inbox_capture_all | default(false) | bool }}
HERMES_LIFE_DISCORD_DEBUG_LINES={{ private_pi5_hermes_life_discord_debug_lines_enabled | default(false) | bool }}
{% if private_pi5_hermes_life_interest_weather_enabled | default(false) | bool %}
LIFE_PILOT_INTEREST_WEATHER_ENABLED=true
LIFE_PILOT_INTEREST_WEATHER_LATITUDE={{ private_pi5_hermes_life_interest_weather_latitude | default('') | trim }}
LIFE_PILOT_INTEREST_WEATHER_LONGITUDE={{ private_pi5_hermes_life_interest_weather_longitude | default('') | trim }}
LIFE_PILOT_INTEREST_WEATHER_LABEL={{ private_pi5_hermes_life_interest_weather_label | default('local weather') | trim }}
LIFE_PILOT_INTEREST_WEATHER_TIMEZONE={{ private_pi5_hermes_life_interest_weather_timezone | default('Asia/Tokyo') | trim }}
{% endif %}
{% if private_pi5_hermes_life_interest_web_search_enabled | default(false) | bool %}
LIFE_PILOT_INTEREST_WEB_SEARCH_ENABLED=true
LIFE_PILOT_INTEREST_WEB_SEARCH_QUERIES={{ private_pi5_hermes_life_interest_web_search_queries | default('') | trim }}
