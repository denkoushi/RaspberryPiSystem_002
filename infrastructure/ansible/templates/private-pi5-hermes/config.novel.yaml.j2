# Hermes Agent — novel profile (creative writing via /novel)
# Secrets live in profile .env only.
{% include 'config.base.yaml.j2' %}

model:
  default: {{ private_pi5_hermes_dgx_model | default('system-prod-primary') }}
  provider: custom:dgx-system-prod
  base_url: {{ private_pi5_hermes_dgx_base_url | default('http://100.118.82.72:38081') }}/v1
  context_length: {{ private_pi5_hermes_context_length | default(65536) }}
  max_tokens: {{ private_pi5_hermes_novel_max_tokens | default(2048) }}
  reasoning_effort: {{ private_pi5_hermes_reasoning_effort | default('none') }}

custom_providers:
  - name: dgx-system-prod
    base_url: {{ private_pi5_hermes_dgx_base_url | default('http://100.118.82.72:38081') }}/v1
    key_env: OPENAI_API_KEY
    default_model: {{ private_pi5_hermes_dgx_model | default('system-prod-primary') }}
    extra_body:
      chat_template_kwargs:
        enable_thinking: false

compression:
  enabled: false

auxiliary:
  title_generation:
    provider: main
    timeout: 20

memory:
  memory_enabled: false
  user_profile_enabled: false

agent:
  reasoning_effort: {{ private_pi5_hermes_reasoning_effort | default('none') }}
  system_prompt: |
{% if (private_pi5_hermes_novel_system_prompt | default('') | trim) | length > 0 %}
{{ private_pi5_hermes_novel_system_prompt | trim | indent(4, first=True) }}
{% else %}
    私用 Pi5 の小説創作専用アシスタントです。
    ユーザーは長文の創作（プロット、章立て、シーン描写、会話、推敲）を依頼します。
    雑談や短い一言返答は行わず、創作に必要な長さで応答してください。
    ファイル操作・Web・ブラウザ・外部ツールは使わないでください。
    設定・世界観・登場人物の一貫性を保ち、明示されたトーンと制約を守ってください。
{% endif %}
  disabled_toolsets:
    - web
    - browser
    - terminal
    - file
    - code_execution
    - vision
    - image_gen
    - video
    - video_gen
    - x_search
    - moa
    - tts
    - skills
    - todo
    - memory
    - session_search
    - clarify
    - delegation
    - cronjob
    - messaging
    - kanban
    - discord
    - discord_admin
    - homeassistant
    - spotify
    - yuanbao
    - computer_use

platform_toolsets:
  discord: []
