# Hermes gateway — 秘密情報（0600）
# Discord はアカウント・Bot 作成後に DISCORD_* を追記して gateway を有効化する

# DGX system-prod（OpenAI 互換）
OPENAI_API_KEY={{ private_pi5_hermes_dgx_llm_shared_token }}

# Discord（未設定時は gateway を起動しない運用）
{% if (private_pi5_hermes_discord_bot_token | default('') | trim) | length > 0 %}
DISCORD_BOT_TOKEN={{ private_pi5_hermes_discord_bot_token }}
DISCORD_ALLOWED_USERS={{ private_pi5_hermes_discord_allowed_users | default('') }}
DISCORD_REQUIRE_MENTION=true
{% endif %}

# 明示: 全員許可は使わない
# GATEWAY_ALLOW_ALL_USERS=false
