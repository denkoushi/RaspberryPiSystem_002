# Docker Compose環境変数ファイル
# このファイルはAnsibleで管理されています
# IPアドレス変更時はこのファイルを更新してください

# サーバーIPアドレス（例: 192.168.128.131）
SERVER_IP={{ docker_server_ip | default((server_ip | default('192.168.128.131'))) }}

# その他のDocker Compose環境変数
# 必要に応じて追加してください

# API JWT秘密鍵（本番必須）
# NOTE:
# - docker-compose.server.yml の api は env_file に apps/api/.env.example と .env を読み込む。
# - .env（= infrastructure/docker/.env）にJWTが無いと、.env.exampleの弱い値へフォールバックしてAPIが起動拒否する。
# - api_jwt_*_effective は「inventoryが弱い/未設定でも、既存 apps/api/.env から復元」できるようAnsible側で解決した値。
JWT_ACCESS_SECRET={{ api_jwt_access_secret_effective | default(api_jwt_access_secret | default('')) }}
JWT_REFRESH_SECRET={{ api_jwt_refresh_secret_effective | default(api_jwt_refresh_secret | default('')) }}

# Pi5 API -> Ubuntu LocalLLM proxy settings
# NOTE: docker-compose.server.yml の api は apps/api/.env.example と
# infrastructure/docker/.env を env_file として読むため、本番で有効化する値はここへも出力する。
LOCAL_LLM_BASE_URL={{ api_local_llm_base_url | default('') }}
LOCAL_LLM_SHARED_TOKEN={{ api_local_llm_shared_token | default('') }}
LOCAL_LLM_MODEL={{ api_local_llm_model | default('') }}
LOCAL_LLM_TIMEOUT_MS={{ api_local_llm_timeout_ms | default(60000) }}
# llama-server オンデマンド起動（Ubuntu 側に control-server.mjs + nginx 等が必要。空は常駐運用と同等）
LOCAL_LLM_RUNTIME_MODE={{ api_local_llm_runtime_mode | default('always_on') }}
LOCAL_LLM_RUNTIME_CONTROL_START_URL={{ api_local_llm_runtime_control_start_url | default('') }}
LOCAL_LLM_RUNTIME_CONTROL_STOP_URL={{ api_local_llm_runtime_control_stop_url | default('') }}
LOCAL_LLM_RUNTIME_CONTROL_TOKEN={{ api_local_llm_runtime_control_token | default('') }}
LOCAL_LLM_RUNTIME_HEALTH_BASE_URL={{ api_local_llm_runtime_health_base_url | default(api_local_llm_base_url, true) | default('') }}
LOCAL_LLM_RUNTIME_READY_TIMEOUT_MS={{ api_local_llm_runtime_ready_timeout_ms | default(180000) }}
LOCAL_LLM_RUNTIME_START_REQUEST_TIMEOUT_MS={{ api_local_llm_runtime_start_request_timeout_ms | default(60000) }}
LOCAL_LLM_RUNTIME_STOP_REQUEST_TIMEOUT_MS={{ api_local_llm_runtime_stop_request_timeout_ms | default(60000) }}
LOCAL_LLM_RUNTIME_HEALTH_POLL_INTERVAL_MS={{ api_local_llm_runtime_health_poll_interval_ms | default(2000) }}
# 推論基盤フェーズ1: 複数 provider / 用途別 route
# NOTE:
# - 空の INFERENCE_PROVIDERS_JSON は API 側で LOCAL_LLM_* フォールバックになる
# - provider ごとに runtimeControl を持てる。mode=on_demand のとき start/stop/health をその provider 用に解決する
# - provider id は空文字だと env 検証に失敗するため default を明示する
INFERENCE_PROVIDERS_JSON={{ inference_providers_json | default('') }}
INFERENCE_PHOTO_LABEL_PROVIDER_ID={{ inference_photo_label_provider_id | default('default') }}
INFERENCE_PHOTO_LABEL_MODEL={{ inference_photo_label_model | default('') }}
INFERENCE_PHOTO_LABEL_VISION_MAX_TOKENS={{ inference_photo_label_vision_max_tokens | default(64) }}
INFERENCE_PHOTO_LABEL_VISION_TEMPERATURE={{ inference_photo_label_vision_temperature | default(0.2) }}
INFERENCE_DOCUMENT_SUMMARY_PROVIDER_ID={{ inference_document_summary_provider_id | default('default') }}
INFERENCE_DOCUMENT_SUMMARY_MODEL={{ inference_document_summary_model | default('') }}
INFERENCE_DOCUMENT_SUMMARY_MAX_TOKENS={{ inference_document_summary_max_tokens | default(512) }}
INFERENCE_DOCUMENT_SUMMARY_TEMPERATURE={{ inference_document_summary_temperature | default(0.2) }}

# サイネージ持出カードグリッド描画エンジン
# NOTE: 未設定時は API 側の既定値 svg_legacy が使われる。
SIGNAGE_LOAN_GRID_ENGINE={{ api_signage_loan_grid_engine | default('svg_legacy') }}
SIGNAGE_PLAYWRIGHT_DEVICE_SCALE_FACTOR={{ api_signage_playwright_device_scale_factor | default('1') }}

# 要領書 OCR 後の LLM 要約（LOCAL_LLM_* または INFERENCE_PROVIDERS_JSON が整っていることが前提）
KIOSK_DOCUMENT_SUMMARY_INFERENCE_ENABLED={{ kiosk_document_summary_inference_enabled | default('false') }}

# 写真持出 GOOD 類似ギャラリー（埋め込み HTTP + pgvector）
# NOTE: true のとき PHOTO_TOOL_EMBEDDING_URL / PHOTO_TOOL_EMBEDDING_MODEL_ID が必須（API 起動時の env 検証）
# 永続化は vault（inventory の vault_photo_tool_* / vault_photo_tool_label_assist_*）を推奨
PHOTO_TOOL_EMBEDDING_ENABLED={{ photo_tool_embedding_enabled | default('false') }}
PHOTO_TOOL_EMBEDDING_URL={{ photo_tool_embedding_url | default('') }}
PHOTO_TOOL_EMBEDDING_API_KEY={{ photo_tool_embedding_api_key | default('') }}
PHOTO_TOOL_EMBEDDING_MODEL_ID={{ photo_tool_embedding_model_id | default('') }}
PHOTO_TOOL_EMBEDDING_TIMEOUT_MS={{ photo_tool_embedding_timeout_ms | default('30000') }}
PHOTO_TOOL_EMBEDDING_DIMENSION={{ photo_tool_embedding_dimension | default('512') }}
PHOTO_TOOL_SIMILARITY_MAX_CANDIDATES={{ photo_tool_similarity_max_candidates | default('5') }}
PHOTO_TOOL_SIMILARITY_MAX_COSINE_DISTANCE={{ photo_tool_similarity_max_cosine_distance | default('0.22') }}
PHOTO_TOOL_SIMILARITY_PIPELINE_VERSION={{ photo_tool_similarity_pipeline_version | default('vision_jpeg_v1') }}
# VLM シャドー補助（ログ比較のみ。true には PHOTO_TOOL_EMBEDDING_ENABLED=true も必要）
PHOTO_TOOL_LABEL_ASSIST_SHADOW_ENABLED={{ photo_tool_label_assist_shadow_enabled | default('false') }}
PHOTO_TOOL_LABEL_ASSIST_MAX_COSINE_DISTANCE={{ photo_tool_label_assist_max_cosine_distance | default('0.14') }}
PHOTO_TOOL_LABEL_ASSIST_MIN_NEIGHBORS={{ photo_tool_label_assist_min_neighbors | default('2') }}
PHOTO_TOOL_LABEL_ASSIST_CONVERGENCE_TOP_K={{ photo_tool_label_assist_convergence_top_k | default('2') }}
PHOTO_TOOL_LABEL_ASSIST_QUERY_NEIGHBOR_LIMIT={{ photo_tool_label_assist_query_neighbor_limit | default('40') }}
PHOTO_TOOL_LABEL_ASSIST_PROMPT_MAX_LABELS={{ photo_tool_label_assist_prompt_max_labels | default('3') }}
# VLM アクティブ補助（ギャラリー行数ゲート通過時のみ 2 回目を本番保存に採用しうる。true には PHOTO_TOOL_EMBEDDING_ENABLED=true も必要）
PHOTO_TOOL_LABEL_ASSIST_ACTIVE_ENABLED={{ photo_tool_label_assist_active_enabled | default('false') }}
PHOTO_TOOL_LABEL_ASSIST_ACTIVE_MIN_GALLERY_ROWS={{ photo_tool_label_assist_active_min_gallery_rows | default('5') }}

# キオスクお問い合わせ（Slack通知）
# NOTE: このファイルはAnsibleで再生成されるため、手動で追記してもIP変更対応などで上書きされます。
# 永続化する場合は Ansible 側の変数（vault）で管理してください。
# 推奨: supportチャンネル（#rps-support）のIncoming Webhook URLを設定して、Generalチャンネルから分離してください
SLACK_KIOSK_SUPPORT_WEBHOOK_URL={{
  slack_kiosk_support_webhook_url
  | default(existing_slack_kiosk_support_webhook_url | default(''))
}}

# Dropbox OAuth 2.0設定
# NOTE: このファイルはAnsibleで再生成されるため、手動で追記してもIP変更対応などで上書きされます。
# 永続化する場合は Ansible 側の変数（vault）で管理してください。
DROPBOX_APP_KEY={{
  dropbox_app_key
  | default(existing_dropbox_app_key | default(''))
}}
DROPBOX_APP_SECRET={{
  dropbox_app_secret
  | default(existing_dropbox_app_secret | default(''))
}}
DROPBOX_REFRESH_TOKEN={{
  dropbox_refresh_token
  | default(existing_dropbox_refresh_token | default(''))
}}
DROPBOX_ACCESS_TOKEN={{
  dropbox_access_token
  | default(existing_dropbox_access_token | default(''))
}}

# Dropbox保存先のベースパス（Dropbox側のパス）
# 例: /backups/talkplaza
# NOTE: 未設定（空文字）の場合はAPI側のデフォルト/設定ファイルに従う
DROPBOX_BASE_PATH={{
  dropbox_base_path
  | default(existing_dropbox_base_path | default(''))
}}

# Alerts Platform Phase2設定
# NOTE: このファイルはAnsibleで再生成されるため、手動で追記してもIP変更対応などで上書きされます。
# 永続化する場合は Ansible 側の変数（group_vars/host_vars/vault）で管理してください。
# Phase2完全移行: DB中心運用（mode=db）
ALERTS_DISPATCHER_MODE={{
  alerts_dispatcher_mode
  | default(existing_alerts_dispatcher_mode | default('db'))
}}
ALERTS_DB_DISPATCHER_ENABLED={{
  alerts_db_dispatcher_enabled
  | default(existing_alerts_db_dispatcher_enabled | default('true'))
}}
ALERTS_DB_INGEST_ENABLED={{
  alerts_db_ingest_enabled
  | default(existing_alerts_db_ingest_enabled | default('true'))
}}

# Alerts Dispatcher設定（Slack通知ルーティング）
# NOTE: このファイルはAnsibleで再生成されるため、手動で追記してもIP変更対応などで上書きされます。
# 永続化する場合は Ansible 側の変数（vault）で管理してください。
# Alerts Dispatcherを有効化（trueで有効化、falseで無効化）
ALERTS_DISPATCHER_ENABLED={{
  alerts_dispatcher_enabled
  | default(existing_alerts_dispatcher_enabled | default('true'))
}}
# Slack Webhook URLs (route-based)
# 未設定（空文字）の場合は、そのrouteKeyのアラートはSlackに送信されません（ファイル生成のみ）
ALERTS_SLACK_WEBHOOK_DEPLOY={{
  alerts_slack_webhook_deploy
  | default(existing_alerts_slack_webhook_deploy | default(''))
}}
ALERTS_SLACK_WEBHOOK_OPS={{
  alerts_slack_webhook_ops
  | default(existing_alerts_slack_webhook_ops | default(''))
}}
ALERTS_SLACK_WEBHOOK_SECURITY={{
  alerts_slack_webhook_security
  | default(existing_alerts_slack_webhook_security | default(''))
}}
ALERTS_SLACK_WEBHOOK_SUPPORT={{
  alerts_slack_webhook_support
  | default(existing_alerts_slack_webhook_support | default(''))
}}

# 実績基準時間: actor locationに無い場合 shared-global-rank を参照するか
ACTUAL_HOURS_SHARED_FALLBACK_ENABLED={{
  actual_hours_shared_fallback_enabled
  | default(existing_actual_hours_shared_fallback_enabled | default('false'))
}}

# 手動順番: deviceScopeKey 正 + Mac 代理は targetDeviceScopeKey 必須（false で従来 targetLocation）
KIOSK_MANUAL_ORDER_DEVICE_SCOPE_V2_ENABLED={{
  kiosk_manual_order_device_scope_v2_enabled | default('true')
}}

# 納期管理キオスク新レイアウト（V2）有効化
# NOTE: ビルド時に埋め込まれる。変更時は web コンテナの再ビルドが必要
VITE_KIOSK_DUE_MGMT_LAYOUT_V2_ENABLED={{
  web_kiosk_due_mgmt_layout_v2_enabled
  | default(existing_vite_kiosk_due_mgmt_layout_v2_enabled | default('false'))
}}

# 手動順番 v2 UI/API 整合（ビルド時に埋め込まれる）
VITE_KIOSK_MANUAL_ORDER_DEVICE_SCOPE_V2_ENABLED={{
  web_kiosk_manual_order_device_scope_v2_enabled | default('true')
}}
