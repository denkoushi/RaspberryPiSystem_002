[Unit]
Description=StackChan Private Bridge
After=network-online.target tailscaled.service
Wants=network-online.target

[Service]
Type=simple
User={{ private_pi5_bridge_effective_user }}
WorkingDirectory={{ private_pi5_bridge_effective_dir }}
EnvironmentFile={{ private_pi5_bridge_env_path }}
ExecStart=/usr/bin/python3 {{ private_pi5_bridge_effective_dir }}/bridge_server.py
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
