STACKCHAN_BRIDGE_HOST={{ private_pi5_bridge_host | default('0.0.0.0') }}
STACKCHAN_BRIDGE_PORT={{ private_pi5_bridge_port | default(18080) }}

DGX_BASE_URL={{ private_pi5_dgx_base_url }}
DGX_MODEL={{ private_pi5_dgx_model }}
DGX_LLM_SHARED_TOKEN={{ private_pi5_dgx_llm_shared_token }}
DGX_RUNTIME_AUTO_START={{ 'true' if (private_pi5_dgx_runtime_auto_start | default(false) | bool) else 'false' }}
DGX_RUNTIME_CONTROL_TOKEN={{ private_pi5_dgx_runtime_control_token | default('') }}
DGX_RUNTIME_START_PATH={{ private_pi5_dgx_runtime_start_path | default('/start') }}
DGX_RUNTIME_READY_PATH={{ private_pi5_dgx_runtime_ready_path | default('/v1/models') }}
DGX_RUNTIME_READY_TIMEOUT_SEC={{ private_pi5_dgx_runtime_ready_timeout_sec | default(600) }}
DGX_RUNTIME_READY_POLL_SEC={{ private_pi5_dgx_runtime_ready_poll_sec | default(1) }}

STACKCHAN_TOKEN={{ private_pi5_stackchan_token | default('') }}

UPSTREAM_TIMEOUT_SEC={{ private_pi5_upstream_timeout_sec | default(45) }}

STT_PROVIDER={{ private_pi5_stt_provider | default('upstream-openai') }}
STT_UPSTREAM_BASE_URL={{ private_pi5_stt_upstream_base_url | default(private_pi5_dgx_base_url) }}
STT_UPSTREAM_PATH={{ private_pi5_stt_upstream_path | default('/v1/audio/transcriptions') }}
STT_UPSTREAM_AUTH_MODE={{ private_pi5_stt_upstream_auth_mode | default('x-llm-token') }}
STT_UPSTREAM_TOKEN={{ private_pi5_stt_upstream_token | default(private_pi5_dgx_llm_shared_token) }}
STT_UPSTREAM_MODEL={{ private_pi5_stt_upstream_model | default('whisper-1') }}
STT_UPSTREAM_TIMEOUT_SEC={{ private_pi5_stt_upstream_timeout_sec | default(60) }}
STT_LOCAL_MODEL={{ private_pi5_stt_local_model | default('small') }}
STT_LOCAL_DEVICE={{ private_pi5_stt_local_device | default('cpu') }}
STT_LOCAL_COMPUTE_TYPE={{ private_pi5_stt_local_compute_type | default('int8') }}
