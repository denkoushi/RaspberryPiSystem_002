[Unit]
Description=Hermes Life Pilot Daily Interest Digest dispatcher
After=network-online.target
Wants=network-online.target
ConditionPathExists={{ private_pi5_hermes_data_dir }}/.env
ConditionPathExists={{ private_pi5_hermes_home }}/.local/bin/hermes-life-interest-digest
ConditionPathExists={{ private_pi5_hermes_data_dir }}/plugins/private-pi5-discord-task-bridge/life_interest_digest.py

[Service]
Type=oneshot
User={{ private_pi5_hermes_user }}
Group={{ private_pi5_hermes_group }}
WorkingDirectory={{ private_pi5_hermes_data_dir }}/plugins/private-pi5-discord-task-bridge
Environment=HOME={{ private_pi5_hermes_home }}
Environment=LIFE_PILOT_STORAGE_ROOT={{ private_pi5_hermes_life_data_dir }}
EnvironmentFile={{ private_pi5_hermes_data_dir }}/.env
ExecStart=/usr/bin/python3 {{ private_pi5_hermes_home }}/.local/bin/hermes-life-interest-digest --dispatch --storage-root {{ private_pi5_hermes_life_data_dir }}{% if (private_pi5_hermes_life_interest_digest_channel_id | default('') | trim) | length > 0 %} --channel-id {{ private_pi5_hermes_life_interest_digest_channel_id | trim }}{% endif %}{% if (private_pi5_hermes_life_interest_digest_user_id | default('') | trim) | length > 0 %} --user-id {{ private_pi5_hermes_life_interest_digest_user_id | trim }}{% endif %}
StandardOutput=journal
StandardError=journal
NoNewPrivileges=true
PrivateTmp=true
