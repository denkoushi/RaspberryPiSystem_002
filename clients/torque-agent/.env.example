TORQUE_API_BASE_URL=http://127.0.0.1:3000
TORQUE_CLIENT_KEY=replace-with-registered-client-key
TORQUE_QUEUE_PATH=/data/torque-events.sqlite3
TORQUE_LOCAL_PORT=7073
TORQUE_HEARTBEAT_TTL_SECONDS=8
TORQUE_CONNECTION_LEASE_ENABLED=true
TORQUE_LEASE_RENEW_INTERVAL_SECONDS=2
# Must exceed renew interval. The host guard turns the external controller off after this local deadline.
TORQUE_GUARD_INTENT_TTL_SECONDS=3
TORQUE_BLUETOOTH_GUARD_DIRECTORY=/run/torque-bluetooth-guard
# APIとWebが別originの場合だけ、許可するキオスクWeb originをJSON配列で追加する。
TORQUE_BROWSER_ORIGINS_JSON=[]
# JSON list. Only /dev/input/by-id paths are accepted.
TORQUE_HID_DEVICES_JSON=[]
# Test fixture only. Do not enable for production CEM3-BTLA devices.
TORQUE_ENABLE_SYNTHETIC_FIXTURE=false
