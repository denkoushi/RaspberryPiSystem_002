# Fastify サーバー設定
PORT=8080
HOST=0.0.0.0

# Prisma / PostgreSQL
# セキュリティ強化: 本番環境では強力なパスワードを設定すること
# デフォルト値（postgres）は開発環境用のみ
POSTGRES_PASSWORD="postgres"
DATABASE_URL="postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/borrow_return"
SHADOW_DATABASE_URL="postgresql://postgres:${POSTGRES_PASSWORD}@db-shadow:5432/borrow_return"

# JWT / 認証
JWT_ACCESS_SECRET="replace-me"
JWT_REFRESH_SECRET="replace-me-refresh"
TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# その他
LOG_LEVEL=info

# 実績基準時間フォールバック
# true: actor locationに特徴量が無い場合 shared-global-rank を参照
# false: actor location のみ参照（既定）
ACTUAL_HOURS_SHARED_FALLBACK_ENABLED=false

# 手動順番: deviceScopeKey 正 + Mac 代理は targetDeviceScopeKey 必須（false で従来の targetLocation 動作）
KIOSK_MANUAL_ORDER_DEVICE_SCOPE_V2_ENABLED=true

# 写真持出 GOOD ギャラリー類似候補（pgvector + 外部埋め込み HTTP）
# false のときはギャラリー更新・候補 API は no-op（既存挙動に近い）
PHOTO_TOOL_EMBEDDING_ENABLED=false
# true のとき必須: 埋め込みサービス URL・モデルID（DB の embeddingModelId と一致させる）
# PHOTO_TOOL_EMBEDDING_URL=http://embedding:8080/embed
# PHOTO_TOOL_EMBEDDING_MODEL_ID=clip-vit-b-512
# PHOTO_TOOL_EMBEDDING_API_KEY=
# PHOTO_TOOL_EMBEDDING_TIMEOUT_MS=30000
# Prisma migration の vector(512) と一致させること
PHOTO_TOOL_EMBEDDING_DIMENSION=512
# 候補件数・cosine 距離しきい値（厳しめ既定; 緩めるときは距離を大きく）
PHOTO_TOOL_SIMILARITY_MAX_CANDIDATES=5
PHOTO_TOOL_SIMILARITY_MAX_COSINE_DISTANCE=0.22
PHOTO_TOOL_SIMILARITY_PIPELINE_VERSION=vision_jpeg_v1

