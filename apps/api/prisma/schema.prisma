model PartMeasurementTemplate {
  id                         String                               @id @default(uuid())
  /// 登録スコープ。既存データは THREE_KEY。
  templateScope              PartMeasurementTemplateScope         @default(THREE_KEY)
  fhincd                     String
  processGroup               PartMeasurementProcessGroup
  /// 資源CD（テンプレート識別キー）。移行前データは __LEGACY__
  resourceCd                 String
  /// FHINMEI_ONLY 候補の照合キー（正規化はAPI側）。THREE_KEY / FHINCD_RESOURCE では null。
  candidateFhinmei           String?
  name                       String
  version                    Int                                  @default(1)
  isActive                   Boolean                              @default(true)
  selfInspectionMode         SelfInspectionMode                   @default(FULL)
  /// 指定数（FIXED_COUNT）。旧 SAMPLE は migration でコピー
  selfInspectionFixedCount   Int?
  /// @deprecated 新規は selfInspectionFixedCount を使用
  selfInspectionSampleSize   Int?
  visualTemplateId           String?
  siblingGroupId             String?
  createdAt                  DateTime                             @default(now())
  updatedAt                  DateTime                             @updatedAt
  items                      PartMeasurementTemplateItem[]
  sheets                     PartMeasurementSheet[]
  selfInspectionSessions     SelfInspectionSession[]
  selfInspectionPaperReports SelfInspectionPaperReport[]
  visualTemplate             PartMeasurementVisualTemplate?       @relation(fields: [visualTemplateId], references: [id], onDelete: SetNull)
  siblingGroup               PartMeasurementTemplateSiblingGroup? @relation(fields: [siblingGroupId], references: [id], onDelete: SetNull)

  @@unique([fhincd, processGroup, resourceCd, version], map: "PartMeasurementTemplate_unique_fhincd_group_resource_version")
  @@index([fhincd, processGroup, resourceCd, isActive], map: "PartMeasurementTemplate_idx_lookup")
  @@index([templateScope, fhincd, resourceCd, isActive])
  @@index([visualTemplateId])
  @@index([siblingGroupId, isActive], map: "PartMeasurementTemplate_idx_sibling_active")
}

model PartMeasurementTemplateItem {
  id                                       String                                    @id @default(uuid())
  templateId                               String
  sortOrder                                Int
  datumSurface                             String
  measurementPoint                         String
  measurementLabel                         String
  /// 図面上の番号など表示用（任意）。測定部位の意味は measurementPoint を使用。
  displayMarker                            String?
  unit                                     String?
  allowNegative                            Boolean                                   @default(true)
  /// 小数桁数（0〜6、DBは Decimal(18,6)）
  decimalPlaces                            Int                                       @default(6)
  /// 図面中心UI: 画像内正規化 X（0–1、左上原点）
  markerXRatio                             Decimal?                                  @db.Decimal(10, 8)
  /// 図面中心UI: 画像内正規化 Y（0–1）
  markerYRatio                             Decimal?                                  @db.Decimal(10, 8)
  /// 指差し先端: 画像内正規化 X（0–1、任意。null=指差しなし）
  calloutTipXRatio                         Decimal?                                  @db.Decimal(10, 8)
  /// 指差し先端: 画像内正規化 Y（0–1、任意）
  calloutTipYRatio                         Decimal?                                  @db.Decimal(10, 8)
  /// 図面中心UI: 基準値（任意）
  nominalValue                             Decimal?                                  @db.Decimal(18, 6)
  /// 図面中心UI: 下限（任意・OK/NG 判定）
  lowerLimit                               Decimal?                                  @db.Decimal(18, 6)
  /// 図面中心UI: 上限（任意）
  upperLimit                               Decimal?                                  @db.Decimal(18, 6)
  /// 深さ系: MEASURED=数値公差 / THROUGH=通し（判定スキップ、limits は 0/0 sentinel）
  depthMode                                PartMeasurementDepthMode                  @default(MEASURED)
  createdAt                                DateTime                                  @default(now())
  updatedAt                                DateTime                                  @updatedAt
  template                                 PartMeasurementTemplate                   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  results                                  PartMeasurementResult[]
