enum KioskDocumentSource {
  MANUAL
  GMAIL
}

enum KioskDocumentOcrStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

/// キオスク「要領書」用PDF（手動アップロード / Gmail取り込み）
model KioskDocument {
  id                   String              @id @default(uuid())
  title                String
  displayTitle         String?
  filename             String
  filePath             String
  fileHash             String?
  sourceType           KioskDocumentSource
  gmailMessageId       String?
  sourceAttachmentName String?
  /// Gmail: 正規化済み添付名。同一キーはより新しいメール（gmailInternalDateMs）で上書き
  gmailLogicalKey      String?             @unique
  /// Gmail API messages.get internalDate（ミリ秒）。上書き判定用
  gmailInternalDateMs  BigInt?
  /// Gmail同一添付の再取り込み防止（例: messageId + 元ファイル名のハッシュ）
  gmailDedupeKey       String?             @unique
  pageCount            Int?
  extractedText        String?
  ocrStatus            KioskDocumentOcrStatus @default(PENDING)
  ocrEngine            String?
  ocrStartedAt         DateTime?
  ocrFinishedAt        DateTime?
  ocrRetryCount        Int                 @default(0)
  ocrFailureReason     String?
  ocrTargetPages       Int?
  candidateFhincd      String?
  candidateDrawingNumber String?
  candidateProcessName String?
  candidateResourceCd  String?
  confidenceFhincd     Float?
  confidenceDrawingNumber Float?
  confidenceProcessName Float?
  confidenceResourceCd Float?
  confirmedFhincd      String?
  confirmedDrawingNumber String?
  confirmedProcessName String?
  confirmedResourceCd  String?
  documentCategory     String?
  /// ISO 等の文書番号（OCR 候補・人手確定）
  candidateDocumentNumber String?
  confidenceDocumentNumber Float?
  confirmedDocumentNumber String?
  /// 本文類推用要約（OCR が最大3候補、人手で確定テキストをスナップショット保存）
  summaryCandidate1    String?
  summaryCandidate2    String?
  summaryCandidate3    String?
  confirmedSummaryText String?
  enabled              Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  metadataHistories    KioskDocumentMetadataHistory[]

  @@index([enabled])
  @@index([title])
  @@index([displayTitle])
  @@index([sourceType])
  @@index([ocrStatus])
  @@index([fileHash])
  @@index([confirmedFhincd])
  @@index([confirmedDrawingNumber])
  @@index([confirmedProcessName])
  @@index([confirmedResourceCd])
  @@index([confirmedDocumentNumber])
}

model KioskDocumentMetadataHistory {
  id                   String   @id @default(uuid())
  kioskDocumentId      String
  actorUserId          String?
  changedFields        String[]
  previousDisplayTitle String?
  nextDisplayTitle     String?
  previousFhincd       String?
  nextFhincd           String?
  previousDrawingNumber String?
  nextDrawingNumber    String?
  previousProcessName  String?
  nextProcessName      String?
  previousResourceCd   String?
  nextResourceCd       String?
  previousCategory     String?
  nextCategory         String?
  createdAt            DateTime @default(now())
  kioskDocument        KioskDocument @relation(fields: [kioskDocumentId], references: [id], onDelete: Cascade)

  @@index([kioskDocumentId, createdAt])
  @@index([actorUserId, createdAt])
}

model AlertDelivery {
  id            String              @id @default(uuid())
  alertId       String // Alert.id（ファイルのid）
  alert         Alert               @relation(fields: [alertId], references: [id], onDelete: Cascade)
  channel       AlertChannel        @default(SLACK) // 配送チャンネル（slack/email/http等）
  routeKey      String // ルートキー（deploy/ops/support/security等）
  status        AlertDeliveryStatus @default(PENDING) // 配送状態
  attemptCount  Int                 @default(0) // 試行回数
  nextAttemptAt DateTime? // 次回試行時刻（バックオフ）
  lastAttemptAt DateTime? // 最終試行時刻
  sentAt        DateTime? // 送信成功時刻
  lastError     String? // 最終エラーメッセージ
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([alertId, channel, routeKey]) // 同一アラート・チャンネル・ルートの重複を防止
  @@index([alertId])
  @@index([status])
  @@index([nextAttemptAt])
  @@index([channel, routeKey, status])
}

enum PartMeasurementProcessGroup {
  CUTTING
  GRINDING
  /// 候補テンプレ（2要素: FIHNCD+資源CD）。正本・シートでは使わない。
  CANDIDATE_FHINCD_RESOURCE
  /// 候補テンプレ（1要素: FHINMEI）。正本・シートでは使わない。
  CANDIDATE_FHINMEI_ONLY
}

/// 部品測定テンプレの登録スコープ（候補抽出・キオスク表示の基準）
enum PartMeasurementTemplateScope {
  THREE_KEY
  FHINCD_RESOURCE
  FHINMEI_ONLY
}

enum PartMeasurementSheetStatus {
  DRAFT
  FINALIZED
  CANCELLED
  INVALIDATED
}

/// 同一測定対象（製造order・工程・資源CD）に複数の記録表をぶら下げる親集約。
model PartMeasurementSession {
  id           String                      @id @default(uuid())
  productNo    String
  processGroup PartMeasurementProcessGroup
  resourceCd   String 
  /// 親としての可算完了（関連記録表が運用ルール上そろった）時刻
  completedAt  DateTime?
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
  sheets       PartMeasurementSheet[]

  @@unique([productNo, processGroup, resourceCd], map: "PartMeasurementSession_unique_business_key")
  @@index([productNo, processGroup])
}

/// 図面など表示用。FIHNCD に紐づけず、業務テンプレから参照して再利用する。
model PartMeasurementVisualTemplate {
  id                       String                    @id @default(uuid())
  name                     String
  /// 例: /api/storage/part-measurement-drawings/{uuid}.png
  drawingImageRelativePath String
  isActive                 Boolean                   @default(true)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  businessTemplates        PartMeasurementTemplate[]

  @@index([isActive, name])
}

model PartMeasurementTemplate {
  id                 String                       @id @default(uuid())
  /// 登録スコープ。既存データは THREE_KEY。
  templateScope      PartMeasurementTemplateScope  @default(THREE_KEY)
  fhincd             String
  processGroup       PartMeasurementProcessGroup
  /// 資源CD（テンプレート識別キー）。移行前データは __LEGACY__
  resourceCd         String
  /// FHINMEI_ONLY 候補の照合キー（正規化はAPI側）。THREE_KEY / FHINCD_RESOURCE では null。
  candidateFhinmei   String?
  name               String
  version            Int                          @default(1)
  isActive           Boolean                      @default(true)
  visualTemplateId   String?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  items              PartMeasurementTemplateItem[]
  sheets             PartMeasurementSheet[]
  visualTemplate     PartMeasurementVisualTemplate? @relation(fields: [visualTemplateId], references: [id], onDelete: SetNull)

  @@unique([fhincd, processGroup, resourceCd, version], map: "PartMeasurementTemplate_unique_fhincd_group_resource_version")
  @@index([fhincd, processGroup, resourceCd, isActive], map: "PartMeasurementTemplate_idx_lookup")
  @@index([templateScope, fhincd, resourceCd, isActive])
  @@index([visualTemplateId])
}

model PartMeasurementTemplateItem {
  id               String                    @id @default(uuid())
  templateId       String
  sortOrder        Int
  datumSurface     String
  measurementPoint String
  measurementLabel String
  /// 図面上の番号など表示用（任意）。測定部位の意味は measurementPoint を使用。
  displayMarker    String?
  unit             String?
  allowNegative    Boolean                   @default(true)
  /// 小数桁数（0〜6、DBは Decimal(18,6)）
  decimalPlaces    Int                       @default(6)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  template         PartMeasurementTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  results          PartMeasurementResult[]

  @@index([templateId, sortOrder])
}

model PartMeasurementSheet {
  id                   String                       @id @default(uuid())
  status               PartMeasurementSheetStatus   @default(DRAFT)
  productNo            String
  fseiban              String
  fhincd               String
  fhinmei              String
  machineName          String?
  resourceCdSnapshot   String?
  processGroupSnapshot PartMeasurementProcessGroup
  sessionId            String
  session              PartMeasurementSession       @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  /// 下書き中・確定前の作業者（NFC）
  employeeId           String?
  employeeNameSnapshot String?
  /// 最初にNFCで紐づけた作業者
  createdByEmployeeId           String?
  createdByEmployeeNameSnapshot String?
  /// 確定時点の作業者
  finalizedByEmployeeId           String?
  finalizedByEmployeeNameSnapshot String?
  quantity             Int?
  scannedBarcodeRaw    String?
  templateId           String?
  clientDeviceId       String?
  /// 編集ロック保持端末
  editLockClientDeviceId String?
  editLockExpiresAt      DateTime?
  cancelledAt          DateTime?
  cancelReason         String?
  invalidatedAt        DateTime?
  invalidatedReason    String?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  finalizedAt          DateTime?
  template             PartMeasurementTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  employee             Employee?                    @relation("PartMeasurementSheetWorker", fields: [employeeId], references: [id], onDelete: SetNull)
  createdByEmployee    Employee?                    @relation("PartMeasurementSheetCreatedBy", fields: [createdByEmployeeId], references: [id], onDelete: SetNull)
  finalizedByEmployee  Employee?                    @relation("PartMeasurementSheetFinalizedBy", fields: [finalizedByEmployeeId], references: [id], onDelete: SetNull)
  clientDevice         ClientDevice?                @relation("PartMeasurementSheetOwningDevice", fields: [clientDeviceId], references: [id], onDelete: SetNull)
  editLockClientDevice ClientDevice?                @relation("PartMeasurementSheetEditLock", fields: [editLockClientDeviceId], references: [id], onDelete: SetNull)
  results              PartMeasurementResult[]

  @@index([status, updatedAt], map: "PartMeasurementSheet_idx_status_updated")
  @@index([fseiban], map: "PartMeasurementSheet_idx_fseiban")
  @@index([productNo, processGroupSnapshot, status], map: "PartMeasurementSheet_idx_product_group_status")
  @@index([finalizedAt], map: "PartMeasurementSheet_idx_finalizedAt")
  @@index([sessionId], map: "PartMeasurementSheet_idx_session")
}

model PartMeasurementResult {
  id             String                      @id @default(uuid())
  sheetId        String
  pieceIndex     Int
  templateItemId String
  value          Decimal?                    @db.Decimal(18, 6)
  createdAt      DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  sheet          PartMeasurementSheet        @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  templateItem   PartMeasurementTemplateItem @relation(fields: [templateItemId], references: [id], onDelete: Restrict)

  @@unique([sheetId, pieceIndex, templateItemId], map: "PartMeasurementResult_unique_cell")
  @@index([sheetId], map: "PartMeasurementResult_idx_sheet")
}
