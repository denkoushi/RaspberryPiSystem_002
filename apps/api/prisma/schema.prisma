  traceabilityMode    String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  procedureDocument   AssemblyProcedureDocument   @relation(fields: [procedureDocumentId], references: [id], onDelete: Restrict)
  areas               AssemblyTemplateArea[]
  checkItems          AssemblyTemplateCheckItem[]
  workSessions        AssemblyWorkSession[]
  lots                AssemblyLot[]

  @@unique([modelCode, procedurePattern, version], map: "AssemblyTemplate_unique_model_pattern_version")
  @@index([modelCode, procedurePattern, isActive], map: "AssemblyTemplate_idx_model_pattern_active")
  @@index([procedureDocumentId], map: "AssemblyTemplate_idx_document")
  @@index([isActive, updatedAt], map: "AssemblyTemplate_idx_active_updated")
  @@index([procedureDocumentId, isActive, updatedAt], map: "AssemblyTemplate_idx_document_active_updated")
}

/// 組立トルク管理: 工程/エリア単位。エリア完了後は作業者が次工程へ進める。
model AssemblyTemplateArea {
  id                   String                 @id @default(uuid())
  templateId           String
  sortOrder            Int
  processNo            String
  areaCode             String
  areaName             String
  unitCode             String
  requireManualAdvance Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  template             AssemblyTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  bolts                AssemblyTemplateBolt[]

  @@unique([templateId, sortOrder], map: "AssemblyTemplateArea_unique_template_sort")
  @@index([templateId], map: "AssemblyTemplateArea_idx_template")
}

/// 組立トルク管理: 手順書上に丸数字で配置する締付箇所。
model AssemblyTemplateBolt {
  id                          String                             @id @default(uuid())
  areaId                      String
  /// NULL only for templates created before traceability rollout.
  templateId                  String?
  sortOrder                   Int
  tighteningId                String
  markerNo                    Int
  xRatio                      Decimal                            @db.Decimal(10, 8)
  yRatio                      Decimal                            @db.Decimal(10, 8)
  calloutTipXRatio            Decimal?                           @db.Decimal(10, 8)
  calloutTipYRatio            Decimal?                           @db.Decimal(10, 8)
  /// 省略/null 時はテンプレート procedureDocument の先頭ページ
  kioskDocumentId             String?
  assemblyProcedureDocumentId String?
  pageIndex                   Int?
  boltSpec                    String
  nominalDiameter             String?
  boltLengthMm                Decimal?                           @db.Decimal(10, 3)
  material                    String?
  strengthClass               String?
  capabilityGroupId           String?
  nominalTorque               Decimal                            @db.Decimal(18, 6)
  lowerLimit                  Decimal                            @db.Decimal(18, 6)
  upperLimit                  Decimal                            @db.Decimal(18, 6)
  unit                        String
  createdAt                   DateTime                           @default(now())
  updatedAt                   DateTime                           @updatedAt
  area                        AssemblyTemplateArea               @relation(fields: [areaId], references: [id], onDelete: Cascade)
  kioskDocument               KioskDocument?                     @relation(fields: [kioskDocumentId], references: [id], onDelete: Restrict)
  assemblyProcedureDocument   AssemblyProcedureDocument?         @relation(fields: [assemblyProcedureDocumentId], references: [id], onDelete: Restrict)
  torqueRecords               AssemblyTorqueRecord[]
  torqueWrenchConfirmations   AssemblyTorqueWrenchConfirmation[]

  @@unique([areaId, sortOrder], map: "AssemblyTemplateBolt_unique_area_sort")
  @@unique([areaId, tighteningId], map: "AssemblyTemplateBolt_unique_area_tightening")
  @@index([templateId, markerNo], map: "AssemblyTemplateBolt_idx_template_marker")
  @@index([areaId, markerNo], map: "AssemblyTemplateBolt_idx_area_marker")
  @@index([capabilityGroupId], map: "AssemblyTemplateBolt_idx_capability_group")
  @@index([kioskDocumentId], map: "AssemblyTemplateBolt_idx_kiosk_document")
  @@index([assemblyProcedureDocumentId], map: "AssemblyTemplateBolt_idx_assembly_document")
}

/// 組立トルク管理: 手順書上に丸数字で配置するチェック項目（OK/確認済みトグル）。
model AssemblyTemplateCheckItem {
  id                          String                     @id @default(uuid())
  templateId                  String
  markerNo                    Int
  label                       String?
  required                    Boolean                    @default(true)
  xRatio                      Float
  yRatio                      Float
  calloutTipXRatio            Float?
  calloutTipYRatio            Float?
  kioskDocumentId             String?
  assemblyProcedureDocumentId String?
  pageIndex                   Int                        @default(0)
  sortOrder                   Int
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt
  template                    AssemblyTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  kioskDocument               KioskDocument?             @relation(fields: [kioskDocumentId], references: [id], onDelete: Restrict)
  assemblyProcedureDocument   AssemblyProcedureDocument? @relation(fields: [assemblyProcedureDocumentId], references: [id], onDelete: Restrict)
  checkRecords                AssemblyCheckRecord[]

  @@unique([templateId, sortOrder], map: "AssemblyTemplateCheckItem_unique_template_sort")
  @@unique([templateId, markerNo], map: "AssemblyTemplateCheckItem_unique_template_marker")
  @@index([templateId], map: "AssemblyTemplateCheckItem_idx_template")
  @@index([kioskDocumentId], map: "AssemblyTemplateCheckItem_idx_kiosk_document")
  @@index([assemblyProcedureDocumentId], map: "AssemblyTemplateCheckItem_idx_assembly_document")
}

/// 組立キオスク: 作業開始時に払い出す全体一意の作業用ID。
/// 物理テーブルと列名は旧シリアルNo.実装と互換に保つ。
model AssemblyWorkUnit {
  id                          String                               @id @default(uuid())
  workId                      String                               @unique @map("serialNo")
  createdAt                   DateTime                             @default(now())
  updatedAt                   DateTime                             @updatedAt
  lotSerial                   AssemblyLotSerial?
  workSession                 AssemblyWorkSession?
  parentCompositionLinks      AssemblyWorkUnitComposition[]        @relation("AssemblyCompositionParent")
  childCompositionLinks       AssemblyWorkUnitComposition[]        @relation("AssemblyCompositionChild")
  formalIdentifierAssignments AssemblyFormalIdentifierAssignment[]

  @@map("AssemblySerialRegistry")
}

/// 組立キオスク: 製番ごとのロット計画。各シリアルの作業セッションは開始時に遅延作成する。
model AssemblyLot {
  id                       String              @id @default(uuid())
  templateId               String
  productNo                String
  expectedQuantity         Int
  operatorEmployeeId       String?
  operatorNameSnapshot     String
  targetUnit               String
  torqueWrenchId           String
  clientDeviceId           String?
  clientDeviceNameSnapshot String?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  template                 AssemblyTemplate    @relation(fields: [templateId], references: [id], onDelete: Restrict)
  serials                  AssemblyLotSerial[]

  @@index([productNo, updatedAt], map: "AssemblyLot_idx_product_updated")
  @@index([templateId, updatedAt], map: "AssemblyLot_idx_template_updated")
}

/// 組立キオスク: ロット内シリアル。シリアルはRegistry経由で全体一意にする。
model AssemblyLotSerial {
  id          String               @id @default(uuid())
  lotId       String
  workUnitId  String               @unique @map("serialRegistryId")
  sortOrder   Int
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  lot         AssemblyLot          @relation(fields: [lotId], references: [id], onDelete: Cascade)
  workUnit    AssemblyWorkUnit     @relation(fields: [workUnitId], references: [id], onDelete: Restrict)
  workSession AssemblyWorkSession?

  @@unique([lotId, sortOrder], map: "AssemblyLotSerial_unique_lot_sort")
  @@index([lotId, sortOrder], map: "AssemblyLotSerial_idx_lot_sort")
}

/// 組立トルク管理: 製番/シリアル単位の作業実績。
model AssemblyWorkSession {
  id                           String                             @id @default(uuid())
  templateId                   String
  workUnitId                   String?                            @unique @map("serialRegistryId")
  lotSerialId                  String?                            @unique
  status                       AssemblyWorkSessionStatus          @default(IN_PROGRESS)
  productNo                    String
  workId                       String                             @map("serialNo")
  nameplateNo                  String
  operatorEmployeeId           String?
  operatorNameSnapshot         String
  targetUnit                   String
  torqueWrenchId               String
  clientDeviceId               String?
  clientDeviceNameSnapshot     String?
  currentAreaId                String?
  currentBoltId                String?
  startedAt                    DateTime                           @default(now())
  completedAt                  DateTime?
  cancelledAt                  DateTime?
  cancelReason                 String?
  createdAt                    DateTime                           @default(now())
  updatedAt                    DateTime                           @updatedAt
  template                     AssemblyTemplate                   @relation(fields: [templateId], references: [id], onDelete: Restrict)
  workUnit                     AssemblyWorkUnit?                  @relation(fields: [workUnitId], references: [id], onDelete: Restrict)
  lotSerial                    AssemblyLotSerial?                 @relation(fields: [lotSerialId], references: [id], onDelete: SetNull)
  torqueRecords                AssemblyTorqueRecord[]
  checkRecords                 AssemblyCheckRecord[]
  restartLogs                  AssemblyAreaRestartLog[]
  approval                     AssemblyWorkSessionApproval?
  torqueWrenchConfirmations    AssemblyTorqueWrenchConfirmation[]
  torqueWrenchConnectionLeases TorqueWrenchConnectionLease[]

  @@index([status, updatedAt], map: "AssemblyWorkSession_idx_status_updated")
  @@index([productNo, status], map: "AssemblyWorkSession_idx_product_status")
  @@index([productNo, workId, status, updatedAt], map: "AssemblyWorkSession_idx_product_serial_status")
  @@index([templateId, status], map: "AssemblyWorkSession_idx_template_status")
}

/// 組立キオスク: 作業用IDの親子構成履歴。unlinkedAt が NULL の行だけが現在有効。
model AssemblyWorkUnitComposition {
  id                                 String           @id @default(uuid())
  parentWorkUnitId                   String
  childWorkUnitId                    String
  linkedAt                           DateTime         @default(now())
  linkedByUsernameSnapshot           String?
  linkedByClientDeviceId             String?
  linkedByClientDeviceNameSnapshot   String?
  unlinkedAt                         DateTime?
  unlinkedByUsernameSnapshot         String?
  unlinkedByClientDeviceId           String?
  unlinkedByClientDeviceNameSnapshot String?
  unlinkReason                       String?
  parentWorkUnit                     AssemblyWorkUnit @relation("AssemblyCompositionParent", fields: [parentWorkUnitId], references: [id], onDelete: Restrict)
  childWorkUnit                      AssemblyWorkUnit @relation("AssemblyCompositionChild", fields: [childWorkUnitId], references: [id], onDelete: Restrict)

  @@index([parentWorkUnitId, unlinkedAt], map: "AssemblyWorkUnitComposition_idx_parent_active")
  @@index([childWorkUnitId, unlinkedAt], map: "AssemblyWorkUnitComposition_idx_child_active")
}

/// 組立キオスク: 最上位完成品へ後付けする正式IDの履歴。supersededAt が NULL の行だけが現在有効。
model AssemblyFormalIdentifierAssignment {
  id                                   String           @id @default(uuid())
  workUnitId                           String
  formalId                             String           @unique
  assignedAt                           DateTime         @default(now())
  assignedByUsernameSnapshot           String?
  assignedByClientDeviceId             String?
  assignedByClientDeviceNameSnapshot   String?
  supersededAt                         DateTime?
  supersededByUsernameSnapshot         String?
  supersededByClientDeviceId           String?
  supersededByClientDeviceNameSnapshot String?
  supersedeReason                      String?
  workUnit                             AssemblyWorkUnit @relation(fields: [workUnitId], references: [id], onDelete: Restrict)

  @@index([workUnitId, supersededAt], map: "AssemblyFormalIdentifierAssignment_idx_work_unit_active")
}

/// 作業者が物理レンチの製造番号と表示設定を確認した履歴。
model AssemblyTorqueWrenchConfirmation {
  id                       String                     @id @default(uuid())
  sessionId                String
  templateBoltId           String
  torqueWrenchProfileId    String
  settingHistoryId         String
  conditionFingerprint     String
  operatorEmployeeId       String?
  operatorNameSnapshot     String
  clientDeviceId           String?
  clientDeviceNameSnapshot String?
  confirmedAt              DateTime                   @default(now())
  session                  AssemblyWorkSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  templateBolt             AssemblyTemplateBolt       @relation(fields: [templateBoltId], references: [id], onDelete: Restrict)
  torqueWrenchProfile      TorqueWrenchProfile        @relation(fields: [torqueWrenchProfileId], references: [id], onDelete: Restrict)
  settingHistory           TorqueWrenchSettingHistory @relation(fields: [settingHistoryId], references: [id], onDelete: Restrict)

  @@index([sessionId, conditionFingerprint, confirmedAt(sort: Desc)], map: "AssemblyTorqueWrenchConfirmation_idx_session_condition")
  @@index([torqueWrenchProfileId, confirmedAt(sort: Desc)], map: "AssemblyTorqueWrenchConfirmation_idx_profile_confirmed")
  @@index([settingHistoryId], map: "AssemblyTorqueWrenchConfirmation_idx_setting")
}

/// 組立トルク管理: トルクレンチ入力の履歴。NGや重複無視も削除せず残す。
model AssemblyTorqueRecord {
  id                           String                        @id @default(uuid())
  sessionId                    String
  templateBoltId               String
  attempt                      Int
  inputSource                  AssemblyTorqueInputSource     @default(MANUAL)
  rawPayload                   Json?
  value                        Decimal?                      @db.Decimal(18, 6)
  inputUnit                    String?
  valueNm                      Decimal?                      @db.Decimal(18, 6)
  judgement                    AssemblyTorqueRecordJudgement
  accepted                     Boolean                       @default(false)
  ignoredReason                String?
  torqueWrenchProfileId        String?
  confirmationId               String?
  settingHistoryId             String?
  serialNumberSnapshot         String?
  manufacturerSnapshot         String?
  modelNumberSnapshot          String?
  settingLowerLimitSnapshot    Decimal?                      @db.Decimal(18, 6)
  settingNominalTorqueSnapshot Decimal?                      @db.Decimal(18, 6)
  settingUpperLimitSnapshot    Decimal?                      @db.Decimal(18, 6)
  settingUnitSnapshot          String?
  sourceClientDeviceId         String?
  sourceEventKey               String?
  expectedTemplateBoltId       String?
  deviceRecordedAt             DateTime?
  deviceMemoryCounter          String?
  deviceJudgement              String?
  overrideActorUserId          String?
  overrideActorUsername        String?
  overrideReason               String?
  connectionLeaseId            String?
  connectionLeaseGeneration    Int?
  recordedAt                   DateTime                      @default(now())
  createdAt                    DateTime                      @default(now())
  session                      AssemblyWorkSession           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  templateBolt                 AssemblyTemplateBolt          @relation(fields: [templateBoltId], references: [id], onDelete: Restrict)
  agentEvent                   AssemblyTorqueAgentEvent?

  @@unique([sessionId, templateBoltId, attempt], map: "AssemblyTorqueRecord_unique_attempt")
  @@index([sourceClientDeviceId, sourceEventKey], map: "AssemblyTorqueRecord_idx_source_event")
  @@index([sessionId, recordedAt], map: "AssemblyTorqueRecord_idx_session_recorded")
  @@index([templateBoltId], map: "AssemblyTorqueRecord_idx_bolt")
  @@index([torqueWrenchProfileId, recordedAt], map: "AssemblyTorqueRecord_idx_profile_recorded")
  @@index([torqueWrenchProfileId, deviceMemoryCounter, recordedAt], map: "AssemblyTorqueRecord_idx_profile_memory_recorded")
  @@index([confirmationId], map: "AssemblyTorqueRecord_idx_confirmation")
  @@index([settingHistoryId], map: "AssemblyTorqueRecord_idx_setting")
}

/// Pi5-authoritative current connection owner for one physical torque wrench.
/// A retained released/expired row preserves the monotonic fencing generation.
model TorqueWrenchConnectionLease {
  torqueWrenchProfileId String              @id
  leaseId               String              @unique
  generation            Int
  requestId             String
  ownerClientDeviceId   String
  ownerSessionId        String
  acquiredAt            DateTime            @default(now())
  renewedAt             DateTime            @default(now())
  expiresAt             DateTime
  connectAfter          DateTime
  releasedAt            DateTime?
  releaseReason         String?
  updatedAt             DateTime            @updatedAt
  torqueWrenchProfile   TorqueWrenchProfile @relation(fields: [torqueWrenchProfileId], references: [id], onDelete: Restrict)
  ownerClientDevice     ClientDevice        @relation(fields: [ownerClientDeviceId], references: [id], onDelete: Cascade)
  ownerSession          AssemblyWorkSession @relation(fields: [ownerSessionId], references: [id], onDelete: Cascade)

  @@index([ownerClientDeviceId, expiresAt], map: "TorqueWrenchConnectionLease_idx_owner_expiry")
  @@index([ownerSessionId], map: "TorqueWrenchConnectionLease_idx_session")
  @@index([expiresAt], map: "TorqueWrenchConnectionLease_idx_expiry")
}

/// Append-only acquisition/release/takeover audit. Renewals update the current row only.
model TorqueWrenchConnectionLeaseHistory {
  id                       String              @id @default(uuid())
  torqueWrenchProfileId    String
  leaseId                  String
  generation               Int
  action                   String
  ownerClientDeviceId      String
  ownerClientDeviceName    String
  ownerSessionId           String
  previousClientDeviceId   String?
  previousClientDeviceName String?
  previousSessionId        String?
  reason                   String?
  actorUserId              String?
  actorUsername            String?
  createdAt                DateTime            @default(now())
  torqueWrenchProfile      TorqueWrenchProfile @relation(fields: [torqueWrenchProfileId], references: [id], onDelete: Restrict)

  @@index([torqueWrenchProfileId, createdAt], map: "TorqueWrenchConnectionLeaseHistory_idx_profile_time")
  @@index([ownerClientDeviceId, createdAt], map: "TorqueWrenchConnectionLeaseHistory_idx_owner_time")
  @@index([leaseId], map: "TorqueWrenchConnectionLeaseHistory_idx_lease")
}

/// Agent event idempotency claim. New-table PK preserves uniqueness without
/// adding a contract constraint to the already-live torque record table.
model AssemblyTorqueAgentEvent {
  sourceClientDeviceId String
  sourceEventKey       String
  torqueRecordId       String               @unique
  createdAt            DateTime             @default(now())
  torqueRecord         AssemblyTorqueRecord @relation(fields: [torqueRecordId], references: [id], onDelete: Cascade)

  @@id([sourceClientDeviceId, sourceEventKey])
}

/// 組立トルク管理: 作業セッションごとのチェック項目トグル状態。
model AssemblyCheckRecord {
  id                    String                    @id @default(uuid())
  sessionId             String
  checkItemId           String
  checked               Boolean
  checkedByOperatorName String?
  checkedAt             DateTime                  @updatedAt
  createdAt             DateTime                  @default(now())
  session               AssemblyWorkSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  checkItem             AssemblyTemplateCheckItem @relation(fields: [checkItemId], references: [id], onDelete: Restrict)

  @@unique([sessionId, checkItemId], map: "AssemblyCheckRecord_unique_session_check_item")
  @@index([sessionId], map: "AssemblyCheckRecord_idx_session")
  @@index([checkItemId], map: "AssemblyCheckRecord_idx_check_item")
}

/// 組立トルク管理: エリアやり直し履歴。
model AssemblyAreaRestartLog {
  id        String              @id @default(uuid())
  sessionId String
  areaId    String
  reason    String
  createdAt DateTime            @default(now())
  session   AssemblyWorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt], map: "AssemblyAreaRestartLog_idx_session_created")
  @@index([areaId], map: "AssemblyAreaRestartLog_idx_area")
}

/// 組立キオスク: 完了した作業セッションの記録承認。
model AssemblyWorkSessionApproval {
  id                           String              @id @default(uuid())
  sessionId                    String              @unique
  approvedAt                   DateTime            @default(now())
  approverEmployeeId           String?
  approverEmployeeCodeSnapshot String
  approverEmployeeNameSnapshot String
  approverNfcTagUidSnapshot    String
  comment                      String?
  clientDeviceId               String?
  clientDeviceNameSnapshot     String?
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  session                      AssemblyWorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  approverEmployee             Employee?           @relation("AssemblyWorkSessionRecordApprover", fields: [approverEmployeeId], references: [id], onDelete: SetNull)
  clientDevice                 ClientDevice?       @relation(fields: [clientDeviceId], references: [id], onDelete: SetNull)

  @@index([approvedAt], map: "AssemblyWorkSessionApproval_idx_approved_at")
  @@index([approverEmployeeId], map: "AssemblyWorkSessionApproval_idx_approver_employee")
  @@index([clientDeviceId], map: "AssemblyWorkSessionApproval_idx_client_device")
}

model SelfInspectionSession {
