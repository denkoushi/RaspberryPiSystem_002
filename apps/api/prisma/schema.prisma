  @@index([completedAt], map: "SelfInspectionSession_idx_completed_at")
  @@index([completedAt, updatedAt], map: "SelfInspectionSession_idx_completed_at_updated_at")
  @@index([recordApprovalRequiredAt], map: "SelfInspectionSession_idx_record_approval_required_at")
  @@index([recordApprovalWorkflowStartedAt], map: "SelfInspectionSession_idx_record_approval_workflow_started_at")
  @@index([inspectorRemeasurementRequiredAt], map: "SelfInspectionSession_idx_inspector_remeasurement_required_at")
