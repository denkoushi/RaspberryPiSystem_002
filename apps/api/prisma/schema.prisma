  sessionId                                   String
  entryIndex                                  Int
  entrySlotKind                               SelfInspectionEntrySlotKind                   @default(FIXED)
  inspectorEmployeeId                         String?
  inspectorEmployeeCodeSnapshot               String?
  inspectorEmployeeNameSnapshot               String?
  inspectorEmployeeNfcTagUidSnapshot          String?
  measuringInstrumentId                       String?
  measuringInstrumentManagementNumberSnapshot String?
  measuringInstrumentNameSnapshot             String?
  measuringInstrumentTagUidSnapshot           String?
  clientDeviceId                              String?
  clientDeviceNameSnapshot                    String?
  createdAt                                   DateTime                                      @default(now())
  updatedAt                                   DateTime                                      @updatedAt
  session                                     SelfInspectionSession                         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  inspectorEmployee                           Employee?                                     @relation("SelfInspectionInspectorEntryEmployee", fields: [inspectorEmployeeId], references: [id], onDelete: SetNull)
  measuringInstrument                         MeasuringInstrument?                          @relation(fields: [measuringInstrumentId], references: [id], onDelete: SetNull)
  clientDevice                                ClientDevice?                                 @relation(fields: [clientDeviceId], references: [id], onDelete: SetNull)
  values                                      SelfInspectionInspectorMeasurementValue[]
  instrumentUsages                            SelfInspectionInspectorEntryInstrumentUsage[]

  @@unique([sessionId, entryIndex], map: "SelfInspectionInspectorEntry_unique_session_entry")
  @@index([sessionId], map: "SelfInspectionInspectorEntry_idx_session")
  @@index([inspectorEmployeeId], map: "SelfInspectionInspectorEntry_idx_inspector_employee")
  @@index([measuringInstrumentId], map: "SelfInspectionInspectorEntry_idx_measuring_instrument")
  @@index([clientDeviceId], map: "SelfInspectionInspectorEntry_idx_client_device")
}

model SelfInspectionInspectorEntryInstrumentUsage {
  id                                          String                       @id @default(uuid())
  entryId                                     String
  measuringInstrumentId                       String?
  loanId                                      String?
  measuringInstrumentManagementNumberSnapshot String
  measuringInstrumentNameSnapshot             String
  measuringInstrumentTagUidSnapshot           String?
  preUseInspectedAt                           DateTime                     @default(now())
  createdAt                                   DateTime                     @default(now())
  updatedAt                                   DateTime                     @updatedAt
  entry                                       SelfInspectionInspectorEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  measuringInstrument                         MeasuringInstrument?         @relation(fields: [measuringInstrumentId], references: [id], onDelete: SetNull)
  loan                                        Loan?                        @relation(fields: [loanId], references: [id], onDelete: SetNull)

  @@unique([entryId, measuringInstrumentId], map: "SelfInspectionInspectorEntryUsage_unique_entry_instrument")
  @@index([entryId], map: "SelfInspectionInspectorEntryUsage_idx_entry")
  @@index([measuringInstrumentId], map: "SelfInspectionInspectorEntryUsage_idx_instrument")
  @@index([loanId], map: "SelfInspectionInspectorEntryUsage_idx_loan")
}

model SelfInspectionInspectorMeasurementValue {
  id                         String                                            @id @default(uuid())
  inspectorEntryId           String
  templateItemId             String
  operatorMeasurementValueId String?
  operatorValueSnapshot      Decimal?                                          @db.Decimal(18, 6)
  inspectorValue             Decimal?                                          @db.Decimal(18, 6)
  differenceValue            Decimal?                                          @db.Decimal(18, 6)
  judgementStatus            SelfInspectionInspectorMeasurementJudgementStatus @default(NOT_EVALUATED)
  finalJudgementStatus       String?
  judgedAt                   DateTime?
  judgementComment           String?
  createdAt                  DateTime                                          @default(now())
  updatedAt                  DateTime                                          @updatedAt
  inspectorEntry             SelfInspectionInspectorEntry                      @relation(fields: [inspectorEntryId], references: [id], onDelete: Cascade)
  templateItem               PartMeasurementTemplateItem                       @relation(fields: [templateItemId], references: [id], onDelete: Restrict)
  operatorMeasurementValue   SelfInspectionMeasurementValue?                   @relation(fields: [operatorMeasurementValueId], references: [id], onDelete: SetNull)

  @@unique([inspectorEntryId, templateItemId], map: "SelfInspectionInspectorValue_unique_entry_item")
  @@index([inspectorEntryId], map: "SelfInspectionInspectorValue_idx_entry")
  @@index([templateItemId], map: "SelfInspectionInspectorValue_idx_template_item")
  @@index([operatorMeasurementValueId], map: "SelfInspectionInspectorValue_idx_operator_value")
  @@index([judgementStatus], map: "SelfInspectionInspectorValue_idx_judgement_status")
}

model SelfInspectionRecordApproval {
  id                                String                @id @default(uuid())
  sessionId                         String                @unique
  approvedAt                        DateTime              @default(now())
  approverEmployeeId                String?
  approverEmployeeCodeSnapshot      String
  approverEmployeeNameSnapshot      String
  approverEmployeeNfcTagUidSnapshot String
  comment                           String?
  clientDeviceId                    String?
  clientDeviceNameSnapshot          String?
  createdAt                         DateTime              @default(now())
  updatedAt                         DateTime              @updatedAt
  session                           SelfInspectionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  approverEmployee                  Employee?             @relation("SelfInspectionRecordApprover", fields: [approverEmployeeId], references: [id], onDelete: SetNull)
  clientDevice                      ClientDevice?         @relation(fields: [clientDeviceId], references: [id], onDelete: SetNull)

  @@index([approvedAt], map: "SelfInspectionRecordApproval_idx_approved_at")
  @@index([approverEmployeeId], map: "SelfInspectionRecordApproval_idx_approver_employee")
  @@index([clientDeviceId], map: "SelfInspectionRecordApproval_idx_client_device")
}

model SelfInspectionPaperReport {
  id              String                          @id @default(uuid())
  sessionId       String
  scheduleRowId   String
  templateId      String
  status          SelfInspectionPaperReportStatus @default(ISSUED)
  issuedAt        DateTime                        @default(now())
  supersededAt    DateTime?
  importedAt      DateTime?
  cancelledAt     DateTime?
  clientDeviceId  String?
  plannedQuantity Int
  templateVersion Int
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt
  session         SelfInspectionSession           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  template        PartMeasurementTemplate         @relation(fields: [templateId], references: [id], onDelete: Restrict)
  clientDevice    ClientDevice?                   @relation(fields: [clientDeviceId], references: [id], onDelete: SetNull)
  pages           SelfInspectionPaperReportPage[]
  ocrReviews      SelfInspectionPaperOcrReview[]

  @@index([sessionId, status], map: "SelfInspectionPaperReport_idx_session_status")
  @@index([scheduleRowId, status], map: "SelfInspectionPaperReport_idx_schedule_status")
  @@index([issuedAt], map: "SelfInspectionPaperReport_idx_issued_at")
  @@index([templateId], map: "SelfInspectionPaperReport_idx_template")
  @@index([clientDeviceId], map: "SelfInspectionPaperReport_idx_client_device")
}

model SelfInspectionPaperReportPage {
  id             String                         @id @default(uuid())
  reportId       String
  pageCode       String                         @unique
  pageNumber     Int
  qrPayload      String
  entryIndexFrom Int?
  entryIndexTo   Int?
  markerNoFrom   Int?
  markerNoTo     Int?
  createdAt      DateTime                       @default(now())
  report         SelfInspectionPaperReport      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  ocrReviews     SelfInspectionPaperOcrReview[]

  @@unique([reportId, pageNumber], map: "SelfInspectionPaperReportPage_unique_report_page")
  @@index([reportId], map: "SelfInspectionPaperReportPage_idx_report")
}

model SelfInspectionPaperOcrReview {
  id                   String                             @id @default(uuid())
  reportId             String
  pageId               String?
  status               SelfInspectionPaperOcrReviewStatus @default(OCR_REVIEW)
  qrPayload            String?
  imageStoragePath     String?
  ocrCandidateValues   Json
  confirmedValues      Json?
  confirmedByActorId   String?
  confirmedByActorName String?
  confirmedAt          DateTime?
  failureReason        String?
  createdAt            DateTime                           @default(now())
  updatedAt            DateTime                           @updatedAt
  report               SelfInspectionPaperReport          @relation(fields: [reportId], references: [id], onDelete: Cascade)
  page                 SelfInspectionPaperReportPage?     @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([reportId, status], map: "SelfInspectionPaperOcrReview_idx_report_status")
  @@index([pageId], map: "SelfInspectionPaperOcrReview_idx_page")
  @@index([confirmedAt], map: "SelfInspectionPaperOcrReview_idx_confirmed_at")
}

