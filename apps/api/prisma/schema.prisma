  expectedEntryCount               Int
  clientDeviceId                   String?
  startedAt                        DateTime?
  completedAt                      DateTime?
  recordApprovalRequiredAt         DateTime?
  recordApprovalWorkflowStartedAt  DateTime?
  inspectorRemeasurementRequiredAt DateTime?
  decisionWorkflow                 String?
