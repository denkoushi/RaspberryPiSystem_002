generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ItemStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  RETIRED
}

enum MeasuringInstrumentStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  RETIRED
}

enum RiggingStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  RETIRED
}

enum TransactionAction {
  BORROW
  RETURN
  ADJUST
  CANCEL
}

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

/// 写真持出 VLM ラベルに対する人レビュー品質（分析・運用向け）
enum PhotoToolHumanLabelQuality {
  GOOD
  MARGINAL
  BAD
}

/// `Loan.photoToolDisplayName` が最後のラベルジョブでどう確定したか（管理UIのみ・既存行は UNKNOWN）
enum PhotoToolVlmLabelProvenance {
  UNKNOWN
  FIRST_PASS_VLM
  ASSIST_ACTIVE_VLM
  ASSIST_ACTIVE_CONVERGED
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SignageContentType {
  TOOLS
  PDF
  SPLIT
}

enum SignageDisplayMode {
  SLIDESHOW
  SINGLE
}

/// 部品配膳イベントの種別（履歴・監査用）
enum OrderPlacementActionType {
  /// 分配枝導入前のデータ（branchNo は 1 として扱う）
  LEGACY
  CREATE_BRANCH
  MOVE_BRANCH
}

/// パレット可視化の監査イベント
enum MachinePalletEventActionType {
  SET_ITEM
  REPLACE_ITEM
  DELETE_ITEM
  CLEAR_PALLET
  UPSERT_ILLUSTRATION
  DELETE_ILLUSTRATION
}

model Employee {
  id                                 String                         @id @default(uuid())
  employeeCode                       String                         @unique
  displayName                        String
  lastName                           String? // 苗字（CSVインポート用）
  firstName                          String? // 名前（CSVインポート用）
  nfcTagUid                          String?                        @unique
  department                         String? // 部署（例: 製造担当部門）
  section                            String? // セクション（例: 加工担当部署）
  contact                            String?
  status                             EmployeeStatus                 @default(ACTIVE)
  createdAt                          DateTime                       @default(now())
  updatedAt                          DateTime                       @updatedAt
  loans                              Loan[]
  inspectionRecords                  InspectionRecord[]
  riggingInspectionRecords           RiggingInspectionRecord[]
  transactions                       Transaction[]                  @relation("EmployeeActor")
  partMeasurementSheetsWorker        PartMeasurementSheet[]         @relation("PartMeasurementSheetWorker")
  partMeasurementSheetsCreated       PartMeasurementSheet[]         @relation("PartMeasurementSheetCreatedBy")
  partMeasurementSheetsFinalized     PartMeasurementSheet[]         @relation("PartMeasurementSheetFinalizedBy")
  selfInspectionLotEntries           SelfInspectionLotEntry[]
  selfInspectionInspectorEntries     SelfInspectionInspectorEntry[] @relation("SelfInspectionInspectorEntryEmployee")
  selfInspectionRecordApprovals      SelfInspectionRecordApproval[] @relation("SelfInspectionRecordApprover")
  assemblyWorkSessionRecordApprovals AssemblyWorkSessionApproval[]  @relation("AssemblyWorkSessionRecordApprover")
}

model Item {
  id                    String                 @id @default(uuid())
  itemCode              String                 @unique
  name                  String
  description           String?
  nfcTagUid             String?                @unique
  category              String?
  storageLocation       String?
  status                ItemStatus             @default(AVAILABLE)
  notes                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  loans                 Loan[]
  mobilePlacementEvents MobilePlacementEvent[]
}

model MeasuringInstrument {
  id                                           String                                        @id @default(uuid())
  name                                         String
  managementNumber                             String                                        @unique
  genreId                                      String?
  storageLocation                              String?
  department                                   String? // 管理部署（CSVインポート用）
  measurementRange                             String?
  calibrationExpiryDate                        DateTime?
  status                                       MeasuringInstrumentStatus                     @default(AVAILABLE)
  createdAt                                    DateTime                                      @default(now())
  updatedAt                                    DateTime                                      @updatedAt
  genre                                        MeasuringInstrumentGenre?                     @relation(fields: [genreId], references: [id], onDelete: SetNull)
  inspectionRecords                            InspectionRecord[]
  tags                                         MeasuringInstrumentTag[]
  loans                                        Loan[]
  selfInspectionLotEntries                     SelfInspectionLotEntry[]
  selfInspectionLotEntryInstrumentUsages       SelfInspectionLotEntryInstrumentUsage[]
  selfInspectionInspectorEntries               SelfInspectionInspectorEntry[]
  selfInspectionInspectorEntryInstrumentUsages SelfInspectionInspectorEntryInstrumentUsage[]
  torqueWrenchProfile                          TorqueWrenchProfile?

  @@index([genreId])
}

model MeasuringInstrumentGenre {
  id                String                @id @default(uuid())
  name              String                @unique
  imageUrlPrimary   String?
  imageUrlSecondary String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  instruments       MeasuringInstrument[]
  inspectionItems   InspectionItem[]
}

model InspectionItem {
  id                String                   @id @default(uuid())
  genreId           String
  name              String
  content           String
  criteria          String
  method            String
  order             Int
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  genre             MeasuringInstrumentGenre @relation(fields: [genreId], references: [id], onDelete: Cascade)
  inspectionRecords InspectionRecord[]

  @@unique([genreId, name])
  @@index([genreId])
  @@index([order])
}

enum InspectionResult {
  PASS
  FAIL
}

model InspectionRecord {
  id                    String              @id @default(uuid())
  measuringInstrumentId String
  loanId                String?
  employeeId            String
  inspectionItemId      String
  result                InspectionResult
  inspectedAt           DateTime
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  measuringInstrument   MeasuringInstrument @relation(fields: [measuringInstrumentId], references: [id], onDelete: Cascade)
  loan                  Loan?               @relation(fields: [loanId], references: [id], onDelete: SetNull)
  employee              Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  inspectionItem        InspectionItem      @relation(fields: [inspectionItemId], references: [id], onDelete: Cascade)

  @@index([measuringInstrumentId])
  @@index([loanId])
  @@index([employeeId])
  @@index([inspectionItemId])
  @@index([inspectedAt])
}

model MeasuringInstrumentTag {
  id                    String              @id @default(uuid())
  measuringInstrumentId String
  rfidTagUid            String              @unique
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  measuringInstrument   MeasuringInstrument @relation(fields: [measuringInstrumentId], references: [id], onDelete: Cascade)

  @@index([measuringInstrumentId])
}

/// トルクレンチの型番と測定能力。物理資産とは分離して複数台で再利用する。
model TorqueWrenchModel {
  id                    String                             @id @default(uuid())
  manufacturer          String
  manufacturerKey       String
  modelNumber           String
  modelNumberKey        String
  torqueMinNm           Decimal                            @db.Decimal(18, 6)
  torqueMaxNm           Decimal                            @db.Decimal(18, 6)
  resolutionNm          Decimal?                           @db.Decimal(18, 6)
  communicationType     String                             @default("BLUETOOTH_HOGP")
  outputProfile         String?
  isActive              Boolean                            @default(true)
  createdAt             DateTime                           @default(now())
  updatedAt             DateTime                           @updatedAt
  profiles              TorqueWrenchProfile[]
  capabilityGroupModels TorqueWrenchCapabilityGroupModel[]

  @@unique([manufacturerKey, modelNumberKey], map: "TorqueWrenchModel_unique_manufacturer_model_key")
  @@index([isActive, manufacturerKey, modelNumberKey], map: "TorqueWrenchModel_idx_active_keys")
}

/// 製造番号で識別する物理トルクレンチ。校正・保管・状態は MeasuringInstrument を正本とする。
model TorqueWrenchProfile {
  id                                String                               @id @default(uuid())
  measuringInstrumentId             String                               @unique
  modelId                           String
  serialNumber                      String
  serialNumberKey                   String                               @unique
  /// NULL keeps the expand-phase compatibility path. Once set, agent events require a valid connection lease.
  connectionLeaseEnforcedAt         DateTime?
  connectionLeaseEnforcementReason  String?
  connectionLeaseEnforcedByUserId   String?
  connectionLeaseEnforcedByUsername String?
  createdAt                         DateTime                             @default(now())
  updatedAt                         DateTime                             @updatedAt
  measuringInstrument               MeasuringInstrument                  @relation(fields: [measuringInstrumentId], references: [id], onDelete: Restrict)
  model                             TorqueWrenchModel                    @relation(fields: [modelId], references: [id], onDelete: Restrict)
  settingHistories                  TorqueWrenchSettingHistory[]
  confirmations                     AssemblyTorqueWrenchConfirmation[]
  connectionLease                   TorqueWrenchConnectionLease?
  connectionLeaseHistory            TorqueWrenchConnectionLeaseHistory[]

  @@index([modelId], map: "TorqueWrenchProfile_idx_model")
}

/// 呼び径・長さ・材質・強度区分に対して使用可能な型番群。
model TorqueWrenchCapabilityGroup {
  id              String                             @id @default(uuid())
  name            String                             @unique
  nominalDiameter String
  boltLengthMm    Decimal                            @db.Decimal(10, 3)
  material        String
  strengthClass   String
  isActive        Boolean                            @default(true)
  createdAt       DateTime                           @default(now())
  updatedAt       DateTime                           @updatedAt
  models          TorqueWrenchCapabilityGroupModel[]

  @@index([nominalDiameter, boltLengthMm, material, strengthClass, isActive], map: "TorqueWrenchCapabilityGroup_idx_fastener_active")
}

model TorqueWrenchCapabilityGroupModel {
  capabilityGroupId String
  modelId           String
  createdAt         DateTime                    @default(now())
  capabilityGroup   TorqueWrenchCapabilityGroup @relation(fields: [capabilityGroupId], references: [id], onDelete: Cascade)
  model             TorqueWrenchModel           @relation(fields: [modelId], references: [id], onDelete: Restrict)

  @@id([capabilityGroupId, modelId])
  @@index([modelId, capabilityGroupId], map: "TorqueWrenchCapabilityGroupModel_idx_model_group")
}

/// 物理トルクレンチの設定値。上書きせず、最新履歴を現在値として扱う。
model TorqueWrenchSettingHistory {
  id                    String                             @id @default(uuid())
  torqueWrenchProfileId String
  lowerLimit            Decimal                            @db.Decimal(18, 6)
  nominalTorque         Decimal                            @db.Decimal(18, 6)
  upperLimit            Decimal                            @db.Decimal(18, 6)
  unit                  String
  lowerLimitNm          Decimal                            @db.Decimal(18, 6)
  nominalTorqueNm       Decimal                            @db.Decimal(18, 6)
  upperLimitNm          Decimal                            @db.Decimal(18, 6)
  effectiveAt           DateTime                           @default(now())
  actorUserId           String?
  actorUsername         String?
  reason                String?
  createdAt             DateTime                           @default(now())
  torqueWrenchProfile   TorqueWrenchProfile                @relation(fields: [torqueWrenchProfileId], references: [id], onDelete: Restrict)
  confirmations         AssemblyTorqueWrenchConfirmation[]

  @@index([torqueWrenchProfileId, effectiveAt(sort: Desc), createdAt(sort: Desc)], map: "TorqueWrenchSettingHistory_idx_profile_effective")
}

model RiggingGear {
  id                String                    @id @default(uuid())
  name              String
  managementNumber  String                    @unique
  idNum             String?                   @unique
  storageLocation   String?
  department        String?
  maxLoadTon        Float?
  lengthMm          Int?
  widthMm           Int?
  thicknessMm       Int?
  startedAt         DateTime?
  usableYears       Int? // 使用可能年数（CSVインポート用）
  status            RiggingStatus             @default(AVAILABLE)
  notes             String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  tags              RiggingGearTag[]
  inspectionRecords RiggingInspectionRecord[]
  loans             Loan[]
}

model RiggingGearTag {
  id            String      @id @default(uuid())
  riggingGearId String
  rfidTagUid    String      @unique
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  riggingGear   RiggingGear @relation(fields: [riggingGearId], references: [id], onDelete: Cascade)

  @@index([riggingGearId])
}

model RiggingInspectionRecord {
  id            String           @id @default(uuid())
  riggingGearId String
  loanId        String?
  employeeId    String
  result        InspectionResult
  inspectedAt   DateTime
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  riggingGear   RiggingGear      @relation(fields: [riggingGearId], references: [id], onDelete: Cascade)
  loan          Loan?            @relation(fields: [loanId], references: [id], onDelete: SetNull)
  employee      Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([riggingGearId])
  @@index([loanId])
  @@index([employeeId])
  @@index([inspectedAt])
}

model Machine {
  id                        String   @id @default(uuid())
  equipmentManagementNumber String   @unique
  name                      String
  shortName                 String?
  classification            String?
  operatingStatus           String?
  ncManual                  String?
  maker                     String?
  processClassification     String?
  coolant                   String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([operatingStatus])
  @@index([classification])
}

model ClientDevice {
  id                                 String                         @id @default(uuid())
  name                               String
  location                           String?
  apiKey                             String                         @unique
  statusClientId                     String? // ClientStatus.clientId への紐づけ（x-client-key → statusClientId）
  defaultMode                        String?                        @default("TAG") // 'PHOTO' | 'TAG'（デフォルト: 'TAG'）
  kioskInitialRoute                  String? // 端末ごとのキオスク起動先（borrow_tag | borrow_photo | leader_order_board | assembly。production_schedule は旧互換）
  /// キオスクのサイネージプレビューで参照する `ClientDevice.apiKey`（サイネージ用途端末のみ許可。未設定時は自端末キーでプレビュー）
  signagePreviewTargetApiKey         String?
  /// Zero2W 棚番エッジ等: 端末に固定する棚番（`西-北-01` 形式・trim 保存）
  haizenPresetShelfCodeRaw           String?
  /// Zero2W / haizen-agent からの配膳スキャン対象端末（キオスク設定・API 抽出の正）
  haizenEdgeEnabled                  Boolean                        @default(false)
  /// キオスク棚レイアウト編集（区画フロアプラン・マス割当）を許可する端末
  shelfLayoutEditEnabled             Boolean                        @default(false)
  lastSeenAt                         DateTime?
  createdAt                          DateTime                       @default(now())
  updatedAt                          DateTime                       @updatedAt
  loans                              Loan[]
  transactions                       Transaction[]
  partMeasurementSheets              PartMeasurementSheet[]         @relation("PartMeasurementSheetOwningDevice")
  partMeasurementEditLocks           PartMeasurementSheet[]         @relation("PartMeasurementSheetEditLock")
  selfInspectionSessions             SelfInspectionSession[]
  selfInspectionPaperReports         SelfInspectionPaperReport[]
  selfInspectionInspectorEntries     SelfInspectionInspectorEntry[]
  selfInspectionRecordApprovals      SelfInspectionRecordApproval[]
  assemblyWorkSessionRecordApprovals AssemblyWorkSessionApproval[]
  mobilePlacementEvents              MobilePlacementEvent[]
  orderPlacementEvents               OrderPlacementEvent[]
  mobilePlacementShelvesCreated      MobilePlacementShelf[]
  machinePalletEvents                MachinePalletEvent[]
  haizenScanEvents                   HaizenScanEvent[]
  haizenCurrentPlacements            HaizenCurrentPlacement[]       @relation("HaizenCurrentLastDevice")
  torqueWrenchConnectionLeases       TorqueWrenchConnectionLease[]

  @@index([statusClientId])
}

/// Zero2W / ヘッドレスエッジ由来の配膳スキャン履歴（1スキャン1行）
model HaizenScanEvent {
  id                           String   @id @default(uuid())
  clientDeviceId               String
  /// スキャン時点の端末プリセット棚番
  presetShelfCodeRaw           String
  manufacturingOrderBarcodeRaw String
  distributionNumber           Int?
  rawBarcode                   String?
  csvDashboardRowId            String?
  scheduleSnapshot             Json?
  /// RESOLVED | UNRESOLVED
  resolutionStatus             String   @db.VarChar(32)
  createdAt                    DateTime @default(now())

  clientDevice ClientDevice @relation(fields: [clientDeviceId], references: [id], onDelete: Restrict)

  @@index([clientDeviceId, createdAt])
  @@index([manufacturingOrderBarcodeRaw])
  @@index([resolutionStatus, createdAt])
}

/// 製造order（ProductNo）ごとの最新配膳位置（常に最新スキャンで上書き）
model HaizenCurrentPlacement {
  id                           String   @id @default(uuid())
  manufacturingOrderBarcodeRaw String   @unique
  shelfCodeRaw                 String
  clientDeviceId               String
  distributionNumber           Int?
  csvDashboardRowId            String?
  scheduleSnapshot             Json?
  updatedAt                    DateTime @updatedAt
  createdAt                    DateTime @default(now())

  lastScanClientDevice ClientDevice @relation("HaizenCurrentLastDevice", fields: [clientDeviceId], references: [id], onDelete: Restrict)

  @@index([shelfCodeRaw])
  @@index([clientDeviceId])
}

/// 資源CD（ProductionScheduleResourceMaster.resourceCd）単位の加工機イラスト
model PalletMachineIllustration {
  resourceCd       String   @id @db.VarChar(20)
  /// 未登録の場合は台数設定のみ先に upsert され null となり得る
  imageRelativeUrl String?  @db.VarChar(512)
  /// 加工機のパレット数（1..）。既存行はマイグレで 10
  palletCount      Int      @default(10)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// パレット上の現在アイテム（投影）
model MachinePalletItem {
  id                String   @id @default(uuid())
  /// 資源CD（API 上は machineCd）
  resourceCd        String   @db.VarChar(20)
  palletNo          Int
  displayOrder      Int
  fhincd            String   @db.VarChar(120)
  fhinmei           String   @db.VarChar(255)
  fseiban           String   @db.VarChar(120)
  machineName       String?  @db.VarChar(255)
  csvDashboardRowId String?
  scheduleSnapshot  Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([resourceCd, palletNo, displayOrder], map: "MachinePalletItem_uidx_machine_pallet_order")
  @@index([resourceCd, palletNo, displayOrder], map: "MachinePalletItem_idx_machine_pallet_order")
  @@index([resourceCd], map: "MachinePalletItem_idx_resource")
}

/// パレット可視化イベントログ
model MachinePalletEvent {
  id                           String                       @id @default(uuid())
  clientDeviceId               String?
  actionType                   MachinePalletEventActionType
  /// 資源CD（API 上は machineCd）
  resourceCd                   String                       @db.VarChar(20)
  palletNo                     Int?
  affectedItemId               String?
  manufacturingOrderBarcodeRaw String?
  illustrationRelativeUrl      String?                      @db.VarChar(512)
  scheduleSnapshot             Json?
  createdAt                    DateTime                     @default(now())

  clientDevice ClientDevice? @relation(fields: [clientDeviceId], references: [id], onDelete: SetNull)

  @@index([clientDeviceId, createdAt], map: "MachinePalletEvent_idx_device_time")
  @@index([resourceCd, createdAt], map: "MachinePalletEvent_idx_resource_time")
}

/// 配膳スマホなどによる棚番・現物バーコード配置の履歴（現在値は Item.storageLocation）
model MobilePlacementEvent {
  id                      String   @id @default(uuid())
  clientDeviceId          String
  shelfCodeRaw            String
  itemBarcodeRaw          String
  itemId                  String?
  csvDashboardRowId       String?
  scheduleSnapshot        Json?
  previousStorageLocation String?
  newStorageLocation      String
  placedAt                DateTime @default(now())
  createdAt               DateTime @default(now())

  clientDevice ClientDevice @relation(fields: [clientDeviceId], references: [id], onDelete: Restrict)
  item         Item?        @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([clientDeviceId, placedAt])
  @@index([itemId])
}

/// 部品配膳（製造order番号起点・Item は更新しない）
model OrderPlacementEvent {
  id                           String                   @id @default(uuid())
  clientDeviceId               String
  shelfCodeRaw                 String
  manufacturingOrderBarcodeRaw String
  csvDashboardRowId            String?
  scheduleSnapshot             Json?
  /// 製造order配下の分配枝番号（1 始まり。履歴上は LEGACY も 1）
  branchNo                     Int                      @default(1)
  actionType                   OrderPlacementActionType @default(LEGACY)
  placedAt                     DateTime                 @default(now())
  createdAt                    DateTime                 @default(now())

  clientDevice ClientDevice @relation(fields: [clientDeviceId], references: [id], onDelete: Restrict)

  @@index([clientDeviceId, placedAt])
  @@index([manufacturingOrderBarcodeRaw, branchNo])
}

/// 製造orderごとの分配枝の現在棚（履歴は OrderPlacementEvent 側）
model OrderPlacementBranchState {
  id                           String   @id @default(uuid())
  manufacturingOrderBarcodeRaw String
  branchNo                     Int
  shelfCodeRaw                 String
  csvDashboardRowId            String?
  scheduleSnapshot             Json?
  lastEventId                  String?  @unique
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@unique([manufacturingOrderBarcodeRaw, branchNo])
  @@index([manufacturingOrderBarcodeRaw])
}

/// 配膳スマホの棚番マスタ（`+` で登録。トップの「登録済み棚番」候補の正本）
model MobilePlacementShelf {
  id                      String                        @id @default(uuid())
  shelfCodeRaw            String                        @unique
  /// オペレータ向け表示名（例: Robodrill01南）
  displayLabel            String?
  /// 段（将来 `-1` 運用。初期 NULL）
  tier                    Int?
  /// マクロ区画 ID（nw..se）
  macroZoneId             String?
  createdAt               DateTime                      @default(now())
  createdByClientDeviceId String?
  createdBy               ClientDevice?                 @relation(fields: [createdByClientDeviceId], references: [id], onDelete: SetNull)
  layoutEntities          MobilePlacementLayoutEntity[]
}

enum MobilePlacementLayoutEntityKind {
  MACHINE
  SHELF
  AISLE
  UNUSED
}

model MobilePlacementZoneLayout {
  id            String                        @id @default(uuid())
  /// マクロ区画 ID（nw | n | ne | w | c | e | sw | s | se）
  macroZoneId   String                        @unique
  /// 区画内グリッド（3 または 4）
  gridSize      Int                           @default(3)
  /// 次に採番する棚スロット（1..99）
  nextShelfSlot Int                           @default(1)
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt
  entities      MobilePlacementLayoutEntity[]
}

model MobilePlacementLayoutEntity {
  id           String                          @id @default(uuid())
  zoneLayoutId String
  zoneLayout   MobilePlacementZoneLayout       @relation(fields: [zoneLayoutId], references: [id], onDelete: Cascade)
  entityKind   MobilePlacementLayoutEntityKind
  /// 0-index セル番号の JSON 配列
  cellIndices  Json
  /// 加工機マスタ resourceCd（MACHINE のみ）
  resourceCd   String?
  /// 加工機表示名スナップショット（MACHINE のみ）
  resourceName String?
  shelfId      String?
  shelf        MobilePlacementShelf?           @relation(fields: [shelfId], references: [id], onDelete: SetNull)
  /// 通路ラベル（AISLE のみ・任意）
  aisleLabel   String?
  createdAt    DateTime                        @default(now())
  updatedAt    DateTime                        @updatedAt

  @@index([zoneLayoutId])
  @@index([shelfId])
}

model ClientStatus {
  id            String    @id @default(uuid())
  clientId      String    @unique
  hostname      String
  ipAddress     String
  cpuUsage      Float
  memoryUsage   Float
  diskUsage     Float
  temperature   Float?
  uptimeSeconds Int?
  lastBoot      DateTime?
  lastSeen      DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([lastSeen])
}

model ClientLog {
  id        String   @id @default(uuid())
  clientId  String
  level     String
  message   String
  context   Json?
  createdAt DateTime @default(now())

  @@index([clientId, createdAt])
  @@index([createdAt])
}

model User {
  id                          String         @id @default(uuid())
  username                    String         @unique
  passwordHash                String
  role                        UserRole       @default(VIEWER)
  status                      UserStatus     @default(ACTIVE)
  mfaEnabled                  Boolean        @default(false)
  totpSecret                  String?
  mfaBackupCodes              String[]       @default([])
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt
  transactions                Transaction[]
