generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ItemStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  RETIRED
}

enum MeasuringInstrumentStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  RETIRED
}

enum RiggingStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  RETIRED
}

enum TransactionAction {
  BORROW
  RETURN
  ADJUST
  CANCEL
}

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

/// 写真持出 VLM ラベルに対する人レビュー品質（分析・運用向け）
enum PhotoToolHumanLabelQuality {
  GOOD
  MARGINAL
  BAD
}

/// `Loan.photoToolDisplayName` が最後のラベルジョブでどう確定したか（管理UIのみ・既存行は UNKNOWN）
enum PhotoToolVlmLabelProvenance {
  UNKNOWN
  FIRST_PASS_VLM
  ASSIST_ACTIVE_VLM
  ASSIST_ACTIVE_CONVERGED
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SignageContentType {
  TOOLS
  PDF
  SPLIT
}

enum SignageDisplayMode {
  SLIDESHOW
  SINGLE
}

/// 部品配膳イベントの種別（履歴・監査用）
enum OrderPlacementActionType {
  /// 分配枝導入前のデータ（branchNo は 1 として扱う）
  LEGACY
  CREATE_BRANCH
  MOVE_BRANCH
}

/// パレット可視化の監査イベント
enum MachinePalletEventActionType {
  SET_ITEM
  REPLACE_ITEM
  DELETE_ITEM
  CLEAR_PALLET
  UPSERT_ILLUSTRATION
  DELETE_ILLUSTRATION
}

model Employee {
  id                       String                    @id @default(uuid())
  employeeCode             String                    @unique
  displayName              String
  lastName                 String? // 苗字（CSVインポート用）
  firstName                String? // 名前（CSVインポート用）
  nfcTagUid                String?                   @unique
  department               String? // 部署（例: 製造担当部門）
  section                  String? // セクション（例: 加工担当部署）
  contact                  String?
  status                   EmployeeStatus            @default(ACTIVE)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  loans                    Loan[]
  inspectionRecords        InspectionRecord[]
  riggingInspectionRecords RiggingInspectionRecord[]
  transactions             Transaction[]             @relation("EmployeeActor")
  partMeasurementSheetsWorker   PartMeasurementSheet[] @relation("PartMeasurementSheetWorker")
  partMeasurementSheetsCreated  PartMeasurementSheet[] @relation("PartMeasurementSheetCreatedBy")
  partMeasurementSheetsFinalized PartMeasurementSheet[] @relation("PartMeasurementSheetFinalizedBy")
  selfInspectionLotEntries SelfInspectionLotEntry[]
}

model Item {
  id              String     @id @default(uuid())
  itemCode        String     @unique
  name            String
  description     String?
  nfcTagUid       String?    @unique
  category        String?
  storageLocation String?
  status          ItemStatus @default(AVAILABLE)
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  loans           Loan[]
  mobilePlacementEvents MobilePlacementEvent[]
}

model MeasuringInstrument {
  id                    String                    @id @default(uuid())
  name                  String
  managementNumber      String                    @unique
  genreId               String?
  storageLocation       String?
  department            String? // 管理部署（CSVインポート用）
  measurementRange      String?
  calibrationExpiryDate DateTime?
  status                MeasuringInstrumentStatus @default(AVAILABLE)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  genre                 MeasuringInstrumentGenre? @relation(fields: [genreId], references: [id], onDelete: SetNull)
  inspectionRecords     InspectionRecord[]
  tags                  MeasuringInstrumentTag[]
  loans                 Loan[]
  selfInspectionLotEntries SelfInspectionLotEntry[]

  @@index([genreId])
}

model MeasuringInstrumentGenre {
  id                 String               @id @default(uuid())
  name               String               @unique
  imageUrlPrimary    String?
  imageUrlSecondary  String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  instruments        MeasuringInstrument[]
  inspectionItems    InspectionItem[]
}

model InspectionItem {
  id                    String                   @id @default(uuid())
  genreId               String
  name                  String
  content               String
  criteria              String
  method                String
  order                 Int
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  genre                 MeasuringInstrumentGenre @relation(fields: [genreId], references: [id], onDelete: Cascade)
  inspectionRecords     InspectionRecord[]

  @@unique([genreId, name])
  @@index([genreId])
  @@index([order])
}

enum InspectionResult {
  PASS
  FAIL
}

model InspectionRecord {
  id                    String              @id @default(uuid())
  measuringInstrumentId String
  loanId                String?
  employeeId            String
  inspectionItemId      String
  result                InspectionResult
  inspectedAt           DateTime
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  measuringInstrument   MeasuringInstrument @relation(fields: [measuringInstrumentId], references: [id], onDelete: Cascade)
  loan                  Loan?               @relation(fields: [loanId], references: [id], onDelete: SetNull)
  employee              Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  inspectionItem        InspectionItem      @relation(fields: [inspectionItemId], references: [id], onDelete: Cascade)

  @@index([measuringInstrumentId])
  @@index([loanId])
  @@index([employeeId])
  @@index([inspectionItemId])
  @@index([inspectedAt])
}

model MeasuringInstrumentTag {
  id                    String              @id @default(uuid())
  measuringInstrumentId String
  rfidTagUid            String              @unique
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  measuringInstrument   MeasuringInstrument @relation(fields: [measuringInstrumentId], references: [id], onDelete: Cascade)

  @@index([measuringInstrumentId])
}

model RiggingGear {
  id                String                    @id @default(uuid())
  name              String
  managementNumber  String                    @unique
  idNum             String?                   @unique
  storageLocation   String?
  department        String?
  maxLoadTon        Float?
  lengthMm          Int?
  widthMm           Int?
  thicknessMm       Int?
  startedAt         DateTime?
  usableYears       Int? // 使用可能年数（CSVインポート用）
  status            RiggingStatus             @default(AVAILABLE)
  notes             String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  tags              RiggingGearTag[]
  inspectionRecords RiggingInspectionRecord[]
  loans             Loan[]
}

model RiggingGearTag {
  id            String      @id @default(uuid())
  riggingGearId String
  rfidTagUid    String      @unique
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  riggingGear   RiggingGear @relation(fields: [riggingGearId], references: [id], onDelete: Cascade)

  @@index([riggingGearId])
}

model RiggingInspectionRecord {
  id            String           @id @default(uuid())
  riggingGearId String
  loanId        String?
  employeeId    String
  result        InspectionResult
  inspectedAt   DateTime
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  riggingGear   RiggingGear      @relation(fields: [riggingGearId], references: [id], onDelete: Cascade)
  loan          Loan?            @relation(fields: [loanId], references: [id], onDelete: SetNull)
  employee      Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([riggingGearId])
  @@index([loanId])
  @@index([employeeId])
  @@index([inspectedAt])
}

model Machine {
  id                        String   @id @default(uuid())
  equipmentManagementNumber String   @unique
  name                      String
  shortName                 String?
  classification            String?
  operatingStatus           String?
  ncManual                  String?
  maker                     String?
  processClassification     String?
  coolant                   String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([operatingStatus])
  @@index([classification])
}

model ClientDevice {
  id             String        @id @default(uuid())
  name           String
  location       String?
  apiKey         String        @unique
  statusClientId String? // ClientStatus.clientId への紐づけ（x-client-key → statusClientId）
  defaultMode    String?       @default("TAG") // 'PHOTO' | 'TAG'（デフォルト: 'TAG'）
  /// キオスクのサイネージプレビューで参照する `ClientDevice.apiKey`（サイネージ用途端末のみ許可。未設定時は自端末キーでプレビュー）
  signagePreviewTargetApiKey String?
  /// Zero2W 棚番エッジ等: 端末に固定する棚番（`西-北-01` 形式・trim 保存）
  haizenPresetShelfCodeRaw String?
  /// Zero2W / haizen-agent からの配膳スキャン対象端末（キオスク設定・API 抽出の正）
  haizenEdgeEnabled        Boolean  @default(false)
  /// キオスク棚レイアウト編集（区画フロアプラン・マス割当）を許可する端末
  shelfLayoutEditEnabled   Boolean  @default(false)
  lastSeenAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  loans                   Loan[]
  transactions            Transaction[]
  partMeasurementSheets   PartMeasurementSheet[] @relation("PartMeasurementSheetOwningDevice")
  partMeasurementEditLocks PartMeasurementSheet[] @relation("PartMeasurementSheetEditLock")
  selfInspectionSessions  SelfInspectionSession[]
  selfInspectionPaperReports SelfInspectionPaperReport[]
  mobilePlacementEvents   MobilePlacementEvent[]
  orderPlacementEvents    OrderPlacementEvent[]
  mobilePlacementShelvesCreated MobilePlacementShelf[]
  machinePalletEvents     MachinePalletEvent[]
  haizenScanEvents        HaizenScanEvent[]
  haizenCurrentPlacements HaizenCurrentPlacement[] @relation("HaizenCurrentLastDevice")

  @@index([statusClientId])
}

/// Zero2W / ヘッドレスエッジ由来の配膳スキャン履歴（1スキャン1行）
model HaizenScanEvent {
  id                           String   @id @default(uuid())
  clientDeviceId               String
  /// スキャン時点の端末プリセット棚番
  presetShelfCodeRaw           String
  manufacturingOrderBarcodeRaw String
  distributionNumber           Int?
  rawBarcode                   String?
  csvDashboardRowId            String?
  scheduleSnapshot             Json?
  /// RESOLVED | UNRESOLVED
  resolutionStatus             String   @db.VarChar(32)
  createdAt                    DateTime @default(now())

  clientDevice ClientDevice @relation(fields: [clientDeviceId], references: [id], onDelete: Restrict)

  @@index([clientDeviceId, createdAt])
  @@index([manufacturingOrderBarcodeRaw])
  @@index([resolutionStatus, createdAt])
}

/// 製造order（ProductNo）ごとの最新配膳位置（常に最新スキャンで上書き）
model HaizenCurrentPlacement {
  id                           String   @id @default(uuid())
  manufacturingOrderBarcodeRaw String   @unique
  shelfCodeRaw                 String
  clientDeviceId               String
  distributionNumber           Int?
  csvDashboardRowId            String?
  scheduleSnapshot             Json?
  updatedAt                    DateTime @updatedAt
  createdAt                    DateTime @default(now())

  lastScanClientDevice ClientDevice @relation("HaizenCurrentLastDevice", fields: [clientDeviceId], references: [id], onDelete: Restrict)

  @@index([shelfCodeRaw])
  @@index([clientDeviceId])
}

/// 資源CD（ProductionScheduleResourceMaster.resourceCd）単位の加工機イラスト
model PalletMachineIllustration {
  resourceCd       String   @id @db.VarChar(20)
  /// 未登録の場合は台数設定のみ先に upsert され null となり得る
  imageRelativeUrl String?  @db.VarChar(512)
  /// 加工機のパレット数（1..）。既存行はマイグレで 10
  palletCount      Int      @default(10)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// パレット上の現在アイテム（投影）
model MachinePalletItem {
  id                 String   @id @default(uuid())
  /// 資源CD（API 上は machineCd）
  resourceCd         String   @db.VarChar(20)
  palletNo           Int
  displayOrder       Int
  fhincd             String   @db.VarChar(120)
  fhinmei            String   @db.VarChar(255)
  fseiban            String   @db.VarChar(120)
  machineName        String?  @db.VarChar(255)
  csvDashboardRowId  String?
  scheduleSnapshot   Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([resourceCd, palletNo, displayOrder], map: "MachinePalletItem_idx_machine_pallet_order")
  @@index([resourceCd], map: "MachinePalletItem_idx_resource")
}

/// パレット可視化イベントログ
model MachinePalletEvent {
  id                             String                     @id @default(uuid())
  clientDeviceId                 String?
  actionType                     MachinePalletEventActionType
  /// 資源CD（API 上は machineCd）
  resourceCd                     String                     @db.VarChar(20)
  palletNo                       Int?
  affectedItemId                 String?
  manufacturingOrderBarcodeRaw   String?
  illustrationRelativeUrl        String?                    @db.VarChar(512)
  scheduleSnapshot               Json?
  createdAt                      DateTime                   @default(now())

  clientDevice ClientDevice? @relation(fields: [clientDeviceId], references: [id], onDelete: SetNull)

  @@index([clientDeviceId, createdAt], map: "MachinePalletEvent_idx_device_time")
  @@index([resourceCd, createdAt], map: "MachinePalletEvent_idx_resource_time")
}

/// 配膳スマホなどによる棚番・現物バーコード配置の履歴（現在値は Item.storageLocation）
model MobilePlacementEvent {
  id                      String   @id @default(uuid())
  clientDeviceId          String
  shelfCodeRaw            String
  itemBarcodeRaw          String
  itemId                  String?
  csvDashboardRowId       String?
  scheduleSnapshot        Json?
  previousStorageLocation String?
  newStorageLocation      String
  placedAt                DateTime @default(now())
  createdAt               DateTime @default(now())

  clientDevice ClientDevice @relation(fields: [clientDeviceId], references: [id], onDelete: Restrict)
  item         Item?        @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([clientDeviceId, placedAt])
  @@index([itemId])
}

/// 部品配膳（製造order番号起点・Item は更新しない）
model OrderPlacementEvent {
  id                             String                   @id @default(uuid())
  clientDeviceId                 String
  shelfCodeRaw                   String
  manufacturingOrderBarcodeRaw   String
  csvDashboardRowId              String?
  scheduleSnapshot               Json?
  /// 製造order配下の分配枝番号（1 始まり。履歴上は LEGACY も 1）
  branchNo                       Int                      @default(1)
  actionType                     OrderPlacementActionType @default(LEGACY)
  placedAt                       DateTime                 @default(now())
  createdAt                      DateTime                 @default(now())

  clientDevice ClientDevice @relation(fields: [clientDeviceId], references: [id], onDelete: Restrict)

  @@index([clientDeviceId, placedAt])
  @@index([manufacturingOrderBarcodeRaw, branchNo])
}

/// 製造orderごとの分配枝の現在棚（履歴は OrderPlacementEvent 側）
model OrderPlacementBranchState {
  id                           String   @id @default(uuid())
  manufacturingOrderBarcodeRaw String
  branchNo                     Int
  shelfCodeRaw                 String
  csvDashboardRowId            String?
  scheduleSnapshot             Json?
  lastEventId                  String?  @unique
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@unique([manufacturingOrderBarcodeRaw, branchNo])
  @@index([manufacturingOrderBarcodeRaw])
}

/// 配膳スマホの棚番マスタ（`+` で登録。トップの「登録済み棚番」候補の正本）
model MobilePlacementShelf {
  id                      String        @id @default(uuid())
  shelfCodeRaw            String        @unique
  /// オペレータ向け表示名（例: Robodrill01南）
  displayLabel            String?
  /// 段（将来 `-1` 運用。初期 NULL）
  tier                    Int?
  /// マクロ区画 ID（nw..se）
  macroZoneId             String?
  createdAt               DateTime      @default(now())
  createdByClientDeviceId String?
  createdBy               ClientDevice? @relation(fields: [createdByClientDeviceId], references: [id], onDelete: SetNull)
  layoutEntities          MobilePlacementLayoutEntity[]
}

enum MobilePlacementLayoutEntityKind {
  MACHINE
  SHELF
  AISLE
  UNUSED
}

model MobilePlacementZoneLayout {
  id            String   @id @default(uuid())
  /// マクロ区画 ID（nw | n | ne | w | c | e | sw | s | se）
  macroZoneId   String   @unique
  /// 区画内グリッド（3 または 4）
  gridSize      Int      @default(3)
  /// 次に採番する棚スロット（1..99）
  nextShelfSlot Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  entities      MobilePlacementLayoutEntity[]
}

model MobilePlacementLayoutEntity {
  id           String                          @id @default(uuid())
  zoneLayoutId String
  zoneLayout   MobilePlacementZoneLayout       @relation(fields: [zoneLayoutId], references: [id], onDelete: Cascade)
  entityKind   MobilePlacementLayoutEntityKind
  /// 0-index セル番号の JSON 配列
  cellIndices  Json
  /// 加工機マスタ resourceCd（MACHINE のみ）
  resourceCd   String?
  /// 加工機表示名スナップショット（MACHINE のみ）
  resourceName String?
  shelfId      String?
  shelf        MobilePlacementShelf?           @relation(fields: [shelfId], references: [id], onDelete: SetNull)
  /// 通路ラベル（AISLE のみ・任意）
  aisleLabel   String?
  createdAt    DateTime                        @default(now())
  updatedAt    DateTime                        @updatedAt

  @@index([zoneLayoutId])
  @@index([shelfId])
}

model ClientStatus {
  id            String    @id @default(uuid())
  clientId      String    @unique
  hostname      String
  ipAddress     String
  cpuUsage      Float
  memoryUsage   Float
  diskUsage     Float
  temperature   Float?
  uptimeSeconds Int?
  lastBoot      DateTime?
  lastSeen      DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([lastSeen])
}

model ClientLog {
  id        String   @id @default(uuid())
  clientId  String
  level     String
  message   String
  context   Json?
  createdAt DateTime @default(now())

  @@index([clientId, createdAt])
  @@index([createdAt])
}

model User {
  id              String         @id @default(uuid())
  username        String         @unique
  passwordHash    String
  role            UserRole       @default(VIEWER)
  status          UserStatus     @default(ACTIVE)
  mfaEnabled      Boolean        @default(false)
  totpSecret      String?
  mfaBackupCodes  String[]       @default([])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  transactions    Transaction[]
  auditLogsActor  RoleAuditLog[] @relation("RoleAuditActor")
  auditLogsTarget RoleAuditLog[] @relation("RoleAuditTarget")
  photoToolHumanReviewedLoans Loan[] @relation("PhotoToolHumanReviewer")
}

model RoleAuditLog {
  id           String   @id @default(uuid())
  actorUserId  String
  targetUserId String
  fromRole     UserRole
  toRole       UserRole
  createdAt    DateTime @default(now())

  actorUser  User @relation("RoleAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  targetUser User @relation("RoleAuditTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@index([targetUserId])
}

model Loan {
  id                      String                    @id @default(uuid())
  itemId                  String?
  measuringInstrumentId   String?
  riggingGearId           String?
  employeeId              String?
  clientId                String?
  borrowedAt              DateTime                  @default(now())
  dueAt                   DateTime?
  returnedAt              DateTime?
  cancelledAt             DateTime? // 取消日時（誤スキャン時の取消に使用、ダッシュボードで除外可能）
  notes                   String?
  photoUrl                String? // 写真のURL（例: /api/storage/photos/2025/11/20251127_123456_employee-uuid.jpg）
  photoTakenAt            DateTime? // 撮影日時
  /// VLM が付与した表示用工具名（写真持出・マスタ Item 非紐づけ）
  photoToolDisplayName    String?
  /// 上記表示名を最後のジョブがどの経路で保存したか（人レビュー列とは独立）
  photoToolVlmLabelProvenance PhotoToolVlmLabelProvenance @default(UNKNOWN)
  /// true の Loan のみバッチがサムネイル推論の対象（リリース後の写真持出で true）
  photoToolLabelRequested Boolean                   @default(false)
  /// 推論ジョブが処理中として掴んだ時刻（二重実行緩和・スタック回収用）
  photoToolLabelClaimedAt DateTime?
  /// 人が確定した表示用工具名（null の場合は VLM 表示を優先）
  photoToolHumanDisplayName     String?
  photoToolHumanQuality         PhotoToolHumanLabelQuality?
  photoToolHumanReviewedAt      DateTime?
  photoToolHumanReviewedByUserId String?
  /// 管理画面から登録した類似ギャラリー教師行（実貸出ではない）
  photoToolGallerySeed    Boolean                   @default(false)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  item                    Item?                     @relation(fields: [itemId], references: [id], onDelete: SetNull)
  measuringInstrument     MeasuringInstrument?      @relation(fields: [measuringInstrumentId], references: [id], onDelete: SetNull)
  riggingGear             RiggingGear?              @relation(fields: [riggingGearId], references: [id], onDelete: SetNull)
  employee                Employee?                 @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  client                  ClientDevice?             @relation(fields: [clientId], references: [id])
  photoToolHumanReviewedBy User?                    @relation("PhotoToolHumanReviewer", fields: [photoToolHumanReviewedByUserId], references: [id], onDelete: SetNull)
  transactions            Transaction[]
  InspectionRecord        InspectionRecord[]
  RiggingInspectionRecord RiggingInspectionRecord[]

  @@index([itemId])
  @@index([measuringInstrumentId])
  @@index([riggingGearId])
  @@index([employeeId])
  @@index([clientId])
  @@index([returnedAt])
  @@index([cancelledAt])
  @@index([photoTakenAt])
  @@index([photoToolLabelRequested, photoToolDisplayName, photoToolLabelClaimedAt], map: "Loan_photoToolLabel_job_idx")
  @@index([photoToolHumanReviewedByUserId])
}

model Transaction {
  id                String            @id @default(uuid())
  loanId            String?
  action            TransactionAction
  actorEmployeeId   String?
  performedByUserId String?
  clientId          String?
  details           Json?
  createdAt         DateTime          @default(now())
  loan              Loan?             @relation(fields: [loanId], references: [id])
  actorEmployee     Employee?         @relation("EmployeeActor", fields: [actorEmployeeId], references: [id])
  performedByUser   User?             @relation(fields: [performedByUserId], references: [id])
  client            ClientDevice?     @relation(fields: [clientId], references: [id])

  @@index([loanId])
  @@index([actorEmployeeId])
  @@index([performedByUserId])
  @@index([clientId])
}

model ImportJob {
  id          String       @id @default(uuid())
  type        String
  status      ImportStatus @default(PENDING)
  summary     Json?
  createdAt   DateTime     @default(now())
  completedAt DateTime?
}

model CsvImportHistory {
  id            String       @id @default(uuid())
  scheduleId    String // スケジュールID（backup.jsonのcsvImports[].id）
  scheduleName  String? // スケジュール名（表示用）
  status        ImportStatus @default(PENDING)
  employeesPath String? // Dropbox上の従業員CSVパス
  itemsPath     String? // Dropbox上のアイテムCSVパス
  summary       Json? // インポート結果サマリー（{ employees: { processed, created, updated }, items: { processed, created, updated } }）
  errorMessage  String? // エラーメッセージ（失敗時）
  startedAt     DateTime     @default(now())
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([scheduleId])
  @@index([status])
  @@index([startedAt])
  @@index([completedAt])
}

// Gmail API 429（rate limit）をスケジュール横断で調停するための状態
model GmailRateLimitState {
  // 現状は userId="me" 前提のため固定キーで運用（例: "gmail:me"）
  id               String    @id
  cooldownUntil    DateTime?
  last429At        DateTime?
  lastRetryAfterMs Int?
  version          Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([cooldownUntil])
}

enum BackupOperationType {
  BACKUP
  RESTORE
}

enum BackupStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum BackupFileStatus {
  EXISTS // ファイルが存在する
  DELETED // ファイルが削除済み（保持期間超過または最大件数超過）
}

model BackupHistory {
  id              String              @id @default(uuid())
  operationType   BackupOperationType // バックアップまたはリストア
  targetKind      String // バックアップ対象の種類（database, csv, file, directory, image）
  targetSource    String // バックアップ対象のソース
  backupPath      String? // バックアップファイルのパス（Dropboxまたはローカル）
  storageProvider String              @default("local") // ストレージプロバイダー（local, dropbox）
  status          BackupStatus        @default(PENDING)
  fileStatus      BackupFileStatus    @default(EXISTS) // バックアップファイルの存在状態
  sizeBytes       Int? // バックアップファイルサイズ（バイト）
  hash            String? // バックアップファイルのハッシュ値（SHA256）
  summary         Json? // バックアップ・リストア結果サマリー
  errorMessage    String? // エラーメッセージ（失敗時）
  startedAt       DateTime            @default(now())
  completedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([operationType])
  @@index([targetKind])
  @@index([status])
  @@index([fileStatus])
  @@index([startedAt])
  @@index([completedAt])
}

model BackupConfigChange {
  id               String   @id @default(uuid())
  actionType       String
  actorUserId      String?
  actorUsername    String?
  summary          String?
  diff             Json?
  snapshotRedacted Json
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([actionType])
}

model SignageSchedule {
  id                 String             @id @default(uuid())
  name               String
  contentType        SignageContentType
  pdfId              String?
  pdf                SignagePdf?        @relation("SchedulePdf", fields: [pdfId], references: [id], onDelete: SetNull)
  layoutConfig       Json? // レイアウト設定（FULL/SPLIT + slots定義）。nullの場合は旧contentType/pdfIdから合成
  targetClientKeys   String[]           @default([]) // 空=全端末向け。値ありのときは列挙された apiKey（x-client-key）のみ
  dayOfWeek          Int[]
  startTime          String
  endTime            String
  priority           Int
  enabled            Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([enabled])
  @@index([priority])
}

model SignagePdf {
  id            String             @id @default(uuid())
  name          String
  filename      String
  filePath      String
  displayMode   SignageDisplayMode
  slideInterval Int?
  enabled       Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  schedules     SignageSchedule[]  @relation("SchedulePdf")
  emergencies   SignageEmergency[] @relation("EmergencyPdf")

  @@index([enabled])
}

model SignageEmergency {
  id           String              @id @default(uuid())
  message      String?
  contentType  SignageContentType?
  pdfId        String?
  pdf          SignagePdf?         @relation("EmergencyPdf", fields: [pdfId], references: [id], onDelete: SetNull)
  layoutConfig Json? // レイアウト設定（FULL/SPLIT + slots定義）。nullの場合は旧contentType/pdfIdから合成
  enabled      Boolean             @default(false)
  expiresAt    DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([enabled])
  @@index([expiresAt])
}

model VisualizationDashboard {
  id               String   @id @default(uuid())
  name             String
  description      String?
  dataSourceType   String
  rendererType     String
  dataSourceConfig Json
  rendererConfig   Json
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([enabled])
  @@index([dataSourceType])
  @@index([rendererType])
}

enum CsvDashboardIngestMode {
  APPEND // 追加（重複無視）
  DEDUP // 重複除去
}

enum CsvDashboardTemplateType {
  TABLE // テーブル形式
  CARD_GRID // カードグリッド形式
}

enum CsvDashboardConfigType {
  DASHBOARD
  MASTER
}

enum CsvImportStrategy {
  UPSERT
  REPLACE
}

enum AlertSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum AlertChannel {
  SLACK
  EMAIL
  HTTP
}

enum AlertDeliveryStatus {
  PENDING
  SENT
  FAILED
  SUPPRESSED
}

model CsvDashboard {
  id                     String                   @id @default(uuid())
  name                   String // ダッシュボード名
  description            String? // 説明
  configType             CsvDashboardConfigType   @default(DASHBOARD) // 設定種別（ダッシュボード/マスター設定）
  importType             String                   @default("csvDashboards") // インポートタイプ（employees/items/.../csvDashboards）
  allowedManualImport    Boolean                  @default(true) // 手動取り込みを許可
  allowedScheduledImport Boolean                  @default(true) // 自動取り込みを許可
  importStrategy         CsvImportStrategy        @default(UPSERT) // 取り込み戦略（主にマスターデータ用）
  columnDefinitions      Json // 列定義（列名マッピング、順序、型、表示名など）
  dateColumnName         String? // 日付列の内部名（表示期間フィルタ用）
  displayPeriodDays      Int                      @default(1) // 表示期間（日数、デフォルトは当日のみ）
  emptyMessage           String? // 0件時のメッセージ
  ingestMode             CsvDashboardIngestMode   @default(APPEND) // 取り込み方式
  dedupKeyColumns        String[]                 @default([]) // 重複除去キー列（内部名の配列、dedup時のみ使用）
  gmailScheduleId        String? // Gmail取得スケジュールID（オプション、将来の拡張用）
  gmailSubjectPattern    String? // Gmail件名パターン（CSV取得用）
  templateType           CsvDashboardTemplateType @default(TABLE) // 可視化テンプレート種別
  templateConfig         Json // テンプレート設定（行数、フォントサイズ、表示列など）
  csvFilePath            String? // 最新のCSVファイルパス（原本保存先）
  enabled                Boolean                  @default(true)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  ingestRuns             CsvDashboardIngestRun[]
  rows                   CsvDashboardRow[]

  @@index([enabled])
  @@index([gmailScheduleId])
  @@index([gmailSubjectPattern])
  @@index([configType, importType])
}

model CsvDashboardIngestRun {
  id             String       @id @default(uuid())
  csvDashboardId String
  csvDashboard   CsvDashboard @relation(fields: [csvDashboardId], references: [id], onDelete: Cascade)
  status         ImportStatus @default(PENDING)
  messageId      String? // GmailメッセージID
  messageSubject String? // Gmail件名
  csvFilePath    String? // 取り込んだCSVファイルパス
  rowsProcessed  Int          @default(0) // 処理行数
  rowsAdded      Int          @default(0) // 追加行数（dedup時は重複除外後の数）
  rowsSkipped    Int          @default(0) // スキップ行数（重複など）
  errorMessage   String? // エラーメッセージ
  startedAt      DateTime     @default(now())
  completedAt    DateTime?
  sourceRows     CsvDashboardRow[] @relation("CsvDashboardRowSourceIngestRun")

  @@index([csvDashboardId])
  @@index([status])
  @@index([startedAt])
  @@index([completedAt])
}

model CsvDashboardRow {
  id                         String                              @id @default(uuid())
  csvDashboardId             String
  csvDashboard               CsvDashboard                        @relation(fields: [csvDashboardId], references: [id], onDelete: Cascade)
  occurredAt                 DateTime // 日付列から抽出した日時（表示期間フィルタ用、Asia/Tokyo）
  dataHash                   String? // データのハッシュ（重複除去用、dedup時のみ使用）
  rowData                    Json // 正規化された行データ（列マッピング適用後）
  sourceIngestRunId          String?
  sourceIngestRun            CsvDashboardIngestRun?              @relation("CsvDashboardRowSourceIngestRun", fields: [sourceIngestRunId], references: [id], onDelete: SetNull)
  sourceRowOrdinal           Int?
  sourceIngestRunStartedAt   DateTime?
  createdAt                  DateTime                            @default(now())
  updatedAt                  DateTime?                           @updatedAt
  orderAssignments           ProductionScheduleOrderAssignment[]
  orderSplits                ProductionScheduleOrderSplit[]
  rowNotes                   ProductionScheduleRowNote[]
  productionScheduleProgress ProductionScheduleProgress?
  productionScheduleExternalCompletion ProductionScheduleExternalCompletion?
  globalRowRanks             ProductionScheduleGlobalRowRank[]
  orderSupplements           ProductionScheduleOrderSupplement[]
  fkojunstStatus             ProductionScheduleFkojunstStatus?
  fkojunstMailStatus         ProductionScheduleFkojunstMailStatus?

  @@index([csvDashboardId])
  @@index([csvDashboardId, occurredAt]) // 表示期間フィルタ用の複合インデックス
  @@index([csvDashboardId, dataHash]) // 重複除去用の複合インデックス（dedup時のみ使用）
  @@index([csvDashboardId, updatedAt]) // 世代トークン用
  @@index([csvDashboardId, sourceIngestRunId, sourceRowOrdinal], map: "CsvDashRow_srcRun_rowOrd_idx") // FKOJUNST_Status DEDUP更新後のCSV run+行順固定用
  @@index([csvDashboardId, sourceIngestRunStartedAt, sourceRowOrdinal], map: "CsvDashRow_srcRunStart_rowOrd_idx") // sourceIngestRunId 欠損旧行の fallback 用
}

model ProductionScheduleOrderSupplement {
  id                 String    @id @default(uuid())
  csvDashboardId     String
  csvDashboardRowId  String
  sourceCsvDashboardId String
  productNo          String    @db.VarChar(20)
  resourceCd         String    @db.VarChar(20)
  processOrder       String    @db.VarChar(20)
  plannedQuantity    Int?
  plannedStartDate   DateTime? @db.Date
  /// 現場の手動補正を保護するフラグ（true のとき取込同期で着手日を上書きしない）。
  plannedStartDateManuallySet Boolean @default(false)
  plannedEndDate     DateTime? @db.Date
  /// 直近で CSV 同期に再出現した時刻（差分同期の鮮度管理）。
  lastSeenAt         DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  csvDashboardRow CsvDashboardRow @relation(fields: [csvDashboardRowId], references: [id], onDelete: Cascade)

  @@unique([csvDashboardRowId], map: "ProductionScheduleOrderSupplement_unique_row")
  @@unique([csvDashboardId, sourceCsvDashboardId, productNo, resourceCd, processOrder], map: "ProductionScheduleOrderSupplement_unique_source_key")
  @@index([csvDashboardId], map: "ProductionScheduleOrderSupplement_idx_dashboard")
  @@index([sourceCsvDashboardId], map: "ProductionScheduleOrderSupplement_idx_source_dashboard")
  @@index([plannedStartDate], map: "ProductionScheduleOrderSupplement_idx_start_date")
  @@index([lastSeenAt], map: "ProductionScheduleOrderSupplement_idx_last_seen")
}

/// Gmail FKOJUNST CSV 由来の工順ステータス（最新CSVが正。source 単位で全置換）
model ProductionScheduleFkojunstStatus {
  id                   String   @id @default(uuid())
  csvDashboardId       String
  csvDashboardRowId    String
  sourceCsvDashboardId String
  productNo            String   @db.VarChar(20)
  resourceCd           String   @db.VarChar(20)
  processOrder         String   @db.VarChar(20)
  /// C=加工完了 P=未確定 S=現場着手 R=移動票発行のみ X=場外
  statusCode           String   @db.VarChar(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  csvDashboardRow CsvDashboardRow @relation(fields: [csvDashboardRowId], references: [id], onDelete: Cascade)

  @@unique([csvDashboardRowId], map: "ProductionScheduleFkojunstStatus_unique_row")
  @@unique([csvDashboardId, sourceCsvDashboardId, productNo, resourceCd, processOrder], map: "ProductionScheduleFkojunstStatus_unique_source_key")
  @@index([csvDashboardId], map: "ProductionScheduleFkojunstStatus_idx_dashboard")
  @@index([sourceCsvDashboardId], map: "ProductionScheduleFkojunstStatus_idx_source_dashboard")
}

/// Gmail 件名 `FKOJUNST_Status` のCSV由来。キーは (FKOJUN, FKOTEICD→本体FSIGENCD, FSEZONO→本体ProductNo)。最新FUPDTEDTを正。
model ProductionScheduleFkojunstMailStatus {
  id                   String   @id @default(uuid())
  csvDashboardId       String
  csvDashboardRowId    String
  sourceCsvDashboardId String
  fkojun               String   @db.VarChar(20)
  fkoteicd             String   @db.VarChar(40)
  fsezono              String   @db.VarChar(32)
  statusCode           String   @db.VarChar(1)
  sourceUpdatedAt      DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  csvDashboardRow CsvDashboardRow @relation(fields: [csvDashboardRowId], references: [id], onDelete: Cascade)

  @@unique([csvDashboardRowId], map: "PSFkojunstMailStatus_unique_row")
  @@unique([csvDashboardId, sourceCsvDashboardId, fkojun, fkoteicd, fsezono], map: "PSFkojunstMailStatus_unique_src_key")
  @@index([csvDashboardId], map: "PSFkojunstMailStatus_idx_dashboard")
  @@index([sourceCsvDashboardId], map: "PSFkojunstMailStatus_idx_source_dashboard")
}

/// 順位ボード用: FKOJUNST_Status raw 全体から抽出した「強い工程変更残骸」疑い snapshot。
model ProductionScheduleProcessChangeResidualSnapshot {
  sourceCsvDashboardId String   @id
  rawMailRowsRevision  String
  algorithmVersion     Int      @default(1)
  evidenceCount        Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  evidenceRows ProductionScheduleProcessChangeResidualEvidence[]

  @@index([rawMailRowsRevision], map: "PSProcChangeResidualSnapshot_idx_revision")
}

/// 順位ボード用: 表示時に raw FKOJUNST_Status 全件を読まないための residual evidence。
model ProductionScheduleProcessChangeResidualEvidence {
  id                            String   @id @default(uuid())
  sourceCsvDashboardId          String
  productNo                     String   @db.VarChar(32)
  fkojun                        String   @db.VarChar(20)
  resourceCd                    String   @db.VarChar(40)
  currentStatusCode             String   @db.VarChar(1)
  currentSourceUpdatedAt        DateTime
  completedOtherResourceCd      String   @db.VarChar(40)
  completedOtherStatusCode      String   @db.VarChar(1)
  completedOtherSourceUpdatedAt DateTime
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  snapshot ProductionScheduleProcessChangeResidualSnapshot @relation(fields: [sourceCsvDashboardId], references: [sourceCsvDashboardId], onDelete: Cascade)

  @@unique([sourceCsvDashboardId, productNo, fkojun, resourceCd], map: "PSProcChangeResidualEvidence_unique_key")
  @@index([sourceCsvDashboardId], map: "PSProcChangeResidualEvidence_idx_source")
}

/// Gmail 件名 `FHINMEI_MH_SH` の補完CSV由来。同一取り込み実行内の重複 FSEIBAN は末尾行が正（同期処理で解決）。
model ProductionScheduleSeibanMachineNameSupplement {
  id                   String   @id @default(uuid())
  sourceCsvDashboardId String
  fseiban              String   @db.VarChar(64)
  machineName          String   @db.VarChar(500)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([sourceCsvDashboardId, fseiban], map: "PSSeibanMachNmSup_unique_src_fsb")
  @@index([fseiban], map: "PSSeibanMachNmSup_idx_fseiban")
}

/// Gmail 件名 `CustomerSCAW` 由来。FANKENMEI と MH/SH 行の FHINMEI を正規化照合し、同一製番は後勝ちで顧客名を紐付け（source 単位で全置換）。
model ProductionScheduleFseibanCustomerScaw {
  id                   String   @id @default(uuid())
  sourceCsvDashboardId String
  fseiban              String   @db.VarChar(64)
  customerName         String   @db.VarChar(500)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([sourceCsvDashboardId, fseiban], map: "PSFseibanCustScaw_unique_src_fsb")
  @@index([fseiban], map: "PSFseibanCustScaw_idx_fseiban")
}

/// Gmail 件名 `FKOBAINO` の購買CSV由来。取り込みごとに upsert し、同一キーは更新・未登録は追加（履歴蓄積）。
model PurchaseOrderLookupRow {
  id                         String   @id @default(uuid())
  sourceCsvDashboardId       String
  purchaseOrderNo            String   @db.VarChar(20)
  purchasePartCodeRaw        String   @db.VarChar(128)
  purchasePartCodeNormalized String   @db.VarChar(128)
  /// 生産日程 `FHINCD` との照合キー（括弧除去 + 末尾数値枝番除去）。upsert 一意制約はこの列。
  purchasePartCodeMatchKey   String   @db.VarChar(128)
  seiban                     String   @db.VarChar(64)
  purchasePartName           String   @db.VarChar(500)
  acceptedQuantity           Int      @default(0)
  lineIndex                  Int      @default(0)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@unique([sourceCsvDashboardId, purchaseOrderNo, seiban, purchasePartCodeMatchKey], map: "POLookup_unique_src_po_seiban_matchkey")
  @@index([purchaseOrderNo], map: "POLookup_idx_purchaseOrderNo")
  @@index([sourceCsvDashboardId], map: "POLookup_idx_sourceDashboard")
}

model ProductionScheduleRowNote {
  id                String    @id @default(uuid())
  csvDashboardId    String
  csvDashboardRowId String
  note              String    @db.VarChar(100) // 現場リーダー備考、100文字以内・改行不可
  processingType    String?   @db.VarChar(20) // 処理種別（未選択可）
  dueDate           DateTime? @db.Date // 納期日（年なし表示、日付のみ）
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  csvDashboardRow CsvDashboardRow @relation(fields: [csvDashboardRowId], references: [id], onDelete: Cascade)

  @@unique([csvDashboardRowId])
  @@index([csvDashboardId])
}

/// 順位ボード向け: 親生産日程行の数量分割片（初回は表示・納期・手動順番のみ）。
model ProductionScheduleOrderSplit {
  id                      String    @id @default(uuid())
  csvDashboardId          String
  parentCsvDashboardRowId String
  splitNo                 Int
  splitQuantity           Int
  dueDate                 DateTime? @db.Date
  plannedStartDate        DateTime? @db.Date
  plannedEndDate          DateTime? @db.Date
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  parentRow   CsvDashboardRow                          @relation(fields: [parentCsvDashboardRowId], references: [id], onDelete: Cascade)
  assignments ProductionScheduleOrderSplitAssignment[]

  @@unique([parentCsvDashboardRowId, splitNo], map: "PSOrderSplit_unique_parent_split_no")
  @@index([csvDashboardId], map: "PSOrderSplit_idx_dashboard")
  @@index([parentCsvDashboardRowId], map: "PSOrderSplit_idx_parent_row")
  @@index([csvDashboardId, parentCsvDashboardRowId, splitNo], map: "PSOrderSplit_idx_dashboard_parent_split_no")
}

/// 分割片の手動順番（親 `ProductionScheduleOrderAssignment` と同一順位空間で衝突チェック）。
model ProductionScheduleOrderSplitAssignment {
  id             String   @id @default(uuid())
  csvDashboardId String
  splitId        String
  location       String
  siteKey        String
  resourceCd     String
  orderNumber    Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  split ProductionScheduleOrderSplit @relation(fields: [splitId], references: [id], onDelete: Cascade)

  @@unique([csvDashboardId, location, resourceCd, orderNumber], map: "PSOrderSplitAssign_unique_order_slot")
  @@unique([splitId, location], map: "PSOrderSplitAssign_unique_split_location")
  @@index([csvDashboardId, location, resourceCd], map: "PSOrderSplitAssign_idx_loc_resource")
  @@index([csvDashboardId, siteKey], map: "PSOrderSplitAssign_idx_site")
  @@index([csvDashboardId, siteKey, resourceCd, orderNumber], map: "PSOrderSplitAssign_idx_site_resource_order")
}

/// 分割片 CRUD の監査ログ（世代トークンには含めない）。
model ProductionScheduleOrderSplitAuditLog {
  id                      String   @id @default(uuid())
  csvDashboardId          String
  actorClientKey          String?
  actorLocation           String?
  targetLocation          String?
  siteKey                 String?
  actionType              String
  requestId               String?
  parentCsvDashboardRowId String
  splitId                 String?
  beforeJson              Json?
  afterJson               Json?
  createdAt               DateTime @default(now())

  @@index([parentCsvDashboardRowId], map: "PSOrderSplitAudit_idx_parent")
  @@index([splitId], map: "PSOrderSplitAudit_idx_split")
  @@index([createdAt], map: "PSOrderSplitAudit_idx_created")
}

model ProductionScheduleOrderAssignment {
  id                String   @id @default(uuid())
  csvDashboardId    String
  csvDashboardRowId String
  /// 手動順番の保存キー（deviceScopeKey）。旧データで工場名のみの行は siteKey と同一になりうる。
  location          String
  /// location（deviceScopeKey）から導出した工場キー。overview 集計に使用。
  siteKey           String
  resourceCd        String
  orderNumber       Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  csvDashboardRow CsvDashboardRow @relation(fields: [csvDashboardRowId], references: [id], onDelete: Cascade)

  @@unique([csvDashboardId, location, resourceCd, orderNumber])
  @@unique([csvDashboardRowId, location])
  @@index([csvDashboardId, location, resourceCd])
  @@index([csvDashboardId, siteKey])
}

/// 手動順番（キオスク）上ペイン: 端末ごとの資源CD割り当て（複数・優先順）。工場単位で資源の重複は禁止。
model ProductionScheduleManualOrderResourceAssignment {
  id               String   @id @default(uuid())
  csvDashboardId   String
  siteKey          String
  deviceScopeKey   String
  resourceCd       String
  priority         Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([csvDashboardId, siteKey, resourceCd], map: "ps_mo_res_assign_site_resource_cd_key")
  @@unique([csvDashboardId, deviceScopeKey, priority], map: "ps_mo_res_assign_device_priority_key")
  @@unique([csvDashboardId, deviceScopeKey, resourceCd], map: "ps_mo_res_assign_device_resource_cd_key")
  @@index([csvDashboardId, siteKey])
}

model ProductionScheduleProgress {
  // 1:1で固定（csvDashboardRowIdを主キーにすることで、DB側で別ID生成が不要）
  csvDashboardRowId String   @id
  csvDashboardId    String
  isCompleted       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  csvDashboardRow CsvDashboardRow @relation(fields: [csvDashboardRowId], references: [id], onDelete: Cascade)

  @@index([csvDashboardId, isCompleted])
}

/// CSV 由来の外部完了（現行正本は FKOJUNST_Status C/X）を winner 単位で保持する。本体 rowData は変更しない。
/// `isExternallyCompleted` は後方互換・検索用に同期する（2026-05-26 以降はメール status 完了のみ）。
model ProductionScheduleExternalCompletion {
  csvDashboardRowId       String   @id
  csvDashboardId          String
  isExternallyCompleted   Boolean  @default(false)
  /// FKOJUNST_Status メール CSV: 直前スナップショットにあって今回 dedupe キー集合から消えた。
