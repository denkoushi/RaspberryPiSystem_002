enum BackupOperationType {
  BACKUP
  RESTORE
}

enum BackupStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum BackupFileStatus {
  EXISTS // ファイルが存在する
  DELETED // ファイルが削除済み（保持期間超過または最大件数超過）
}

model BackupHistory {
  id              String              @id @default(uuid())
  operationType   BackupOperationType // バックアップまたはリストア
  targetKind      String // バックアップ対象の種類（database, csv, file, directory, image）
  targetSource    String // バックアップ対象のソース
  backupPath      String? // バックアップファイルのパス（Dropboxまたはローカル）
  storageProvider String              @default("local") // ストレージプロバイダー（local, dropbox）
  status          BackupStatus        @default(PENDING)
  fileStatus      BackupFileStatus    @default(EXISTS) // バックアップファイルの存在状態
  sizeBytes       Int? // バックアップファイルサイズ（バイト）
  hash            String? // バックアップファイルのハッシュ値（SHA256）
  summary         Json? // バックアップ・リストア結果サマリー
  errorMessage    String? // エラーメッセージ（失敗時）
  startedAt       DateTime            @default(now())
  completedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([operationType])
  @@index([targetKind])
  @@index([status])
  @@index([fileStatus])
  @@index([startedAt])
  @@index([completedAt])
}

model BackupConfigChange {
  id               String   @id @default(uuid())
  actionType       String
  actorUserId      String?
  actorUsername    String?
  summary          String?
  diff             Json?
  snapshotRedacted Json
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([actionType])
}

model SignageSchedule {
  id               String             @id @default(uuid())
  name             String
  contentType      SignageContentType
  pdfId            String?
  pdf              SignagePdf?        @relation("SchedulePdf", fields: [pdfId], references: [id], onDelete: SetNull)
  layoutConfig     Json? // レイアウト設定（FULL/SPLIT + slots定義）。nullの場合は旧contentType/pdfIdから合成
  targetClientKeys String[]           @default([]) // 空=全端末向け。値ありのときは列挙された apiKey（x-client-key）のみ
  dayOfWeek        Int[]
  startTime        String
  endTime          String
  priority         Int
  enabled          Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([enabled])
  @@index([priority])
}

model SignagePdf {
  id            String             @id @default(uuid())
  name          String
  filename      String
  filePath      String
  displayMode   SignageDisplayMode
  slideInterval Int?
  enabled       Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  schedules     SignageSchedule[]  @relation("SchedulePdf")
  emergencies   SignageEmergency[] @relation("EmergencyPdf")

  @@index([enabled])
}

model SignageEmergency {
  id           String              @id @default(uuid())
  message      String?
  contentType  SignageContentType?
  pdfId        String?
  pdf          SignagePdf?         @relation("EmergencyPdf", fields: [pdfId], references: [id], onDelete: SetNull)
  layoutConfig Json? // レイアウト設定（FULL/SPLIT + slots定義）。nullの場合は旧contentType/pdfIdから合成
  enabled      Boolean             @default(false)
  expiresAt    DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([enabled])
  @@index([expiresAt])
}

model VisualizationDashboard {
  id               String   @id @default(uuid())
  name             String
  description      String?
  dataSourceType   String
  rendererType     String
  dataSourceConfig Json
  rendererConfig   Json
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([enabled])
  @@index([dataSourceType])
  @@index([rendererType])
}

enum CsvDashboardIngestMode {
  APPEND // 追加（重複無視）
  DEDUP // 重複除去
}

enum CsvDashboardTemplateType {
  TABLE // テーブル形式
  CARD_GRID // カードグリッド形式
}

enum CsvDashboardConfigType {
  DASHBOARD
  MASTER
}

enum CsvImportStrategy {
  UPSERT
  REPLACE
}

enum AlertSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum AlertChannel {
  SLACK
  EMAIL
  HTTP
}

enum AlertDeliveryStatus {
  PENDING
  SENT
  FAILED
  SUPPRESSED
}

model CsvDashboard {
  id                     String                   @id @default(uuid())
  name                   String // ダッシュボード名
  description            String? // 説明
  configType             CsvDashboardConfigType   @default(DASHBOARD) // 設定種別（ダッシュボード/マスター設定）
  importType             String                   @default("csvDashboards") // インポートタイプ（employees/items/.../csvDashboards）
  allowedManualImport    Boolean                  @default(true) // 手動取り込みを許可
  allowedScheduledImport Boolean                  @default(true) // 自動取り込みを許可
  importStrategy         CsvImportStrategy        @default(UPSERT) // 取り込み戦略（主にマスターデータ用）
  columnDefinitions      Json // 列定義（列名マッピング、順序、型、表示名など）
  dateColumnName         String? // 日付列の内部名（表示期間フィルタ用）
  displayPeriodDays      Int                      @default(1) // 表示期間（日数、デフォルトは当日のみ）
  emptyMessage           String? // 0件時のメッセージ
  ingestMode             CsvDashboardIngestMode   @default(APPEND) // 取り込み方式
  dedupKeyColumns        String[]                 @default([]) // 重複除去キー列（内部名の配列、dedup時のみ使用）
  gmailScheduleId        String? // Gmail取得スケジュールID（オプション、将来の拡張用）
  gmailSubjectPattern    String? // Gmail件名パターン（CSV取得用）
  templateType           CsvDashboardTemplateType @default(TABLE) // 可視化テンプレート種別
  templateConfig         Json // テンプレート設定（行数、フォントサイズ、表示列など）
  csvFilePath            String? // 最新のCSVファイルパス（原本保存先）
  enabled                Boolean                  @default(true)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  ingestRuns             CsvDashboardIngestRun[]
  rows                   CsvDashboardRow[]

  @@index([enabled])
  @@index([gmailScheduleId])
  @@index([gmailSubjectPattern])
  @@index([configType, importType])
}

model CsvDashboardIngestRun {
  id             String            @id @default(uuid())
  csvDashboardId String
  csvDashboard   CsvDashboard      @relation(fields: [csvDashboardId], references: [id], onDelete: Cascade)
  status         ImportStatus      @default(PENDING)
  messageId      String? // GmailメッセージID
  messageSubject String? // Gmail件名
  csvFilePath    String? // 取り込んだCSVファイルパス
  rowsProcessed  Int               @default(0) // 処理行数
  rowsAdded      Int               @default(0) // 追加行数（dedup時は重複除外後の数）
  rowsSkipped    Int               @default(0) // スキップ行数（重複など）
  errorMessage   String? // エラーメッセージ
  startedAt      DateTime          @default(now())
  completedAt    DateTime?
  sourceRows     CsvDashboardRow[] @relation("CsvDashboardRowSourceIngestRun")

  @@index([csvDashboardId])
  @@index([status])
  @@index([startedAt])
  @@index([completedAt])
}

model CsvDashboardRow {
  id                                   String                                @id @default(uuid())
  csvDashboardId                       String
  csvDashboard                         CsvDashboard                          @relation(fields: [csvDashboardId], references: [id], onDelete: Cascade)
  occurredAt                           DateTime // 日付列から抽出した日時（表示期間フィルタ用、Asia/Tokyo）
  dataHash                             String? // データのハッシュ（重複除去用、dedup時のみ使用）
  rowData                              Json // 正規化された行データ（列マッピング適用後）
  sourceIngestRunId                    String?
  sourceIngestRun                      CsvDashboardIngestRun?                @relation("CsvDashboardRowSourceIngestRun", fields: [sourceIngestRunId], references: [id], onDelete: SetNull)
  sourceRowOrdinal                     Int?
  sourceIngestRunStartedAt             DateTime?
  createdAt                            DateTime                              @default(now())
  updatedAt                            DateTime?                             @updatedAt
  orderAssignments                     ProductionScheduleOrderAssignment[]
  orderSplits                          ProductionScheduleOrderSplit[]
  rowNotes                             ProductionScheduleRowNote[]
  productionScheduleProgress           ProductionScheduleProgress?
  productionScheduleExternalCompletion ProductionScheduleExternalCompletion?
  globalRowRanks                       ProductionScheduleGlobalRowRank[]
  orderSupplements                     ProductionScheduleOrderSupplement[]
  fkojunstStatus                       ProductionScheduleFkojunstStatus?
  fkojunstMailStatus                   ProductionScheduleFkojunstMailStatus?

  @@index([csvDashboardId])
  @@index([csvDashboardId, occurredAt]) // 表示期間フィルタ用の複合インデックス
  @@index([csvDashboardId, dataHash]) // 重複除去用の複合インデックス（dedup時のみ使用）
  @@index([csvDashboardId, updatedAt]) // 世代トークン用
  @@index([csvDashboardId, sourceIngestRunId, sourceRowOrdinal], map: "CsvDashRow_srcRun_rowOrd_idx") // FKOJUNST_Status DEDUP更新後のCSV run+行順固定用
  @@index([csvDashboardId, sourceIngestRunStartedAt, sourceRowOrdinal], map: "CsvDashRow_srcRunStart_rowOrd_idx") // sourceIngestRunId 欠損旧行の fallback 用
}

model ProductionScheduleOrderSupplement {
  id                          String    @id @default(uuid())
  csvDashboardId              String
  csvDashboardRowId           String
  sourceCsvDashboardId        String
  productNo                   String    @db.VarChar(20)
  resourceCd                  String    @db.VarChar(20)
  processOrder                String    @db.VarChar(20)
  plannedQuantity             Int?
  plannedStartDate            DateTime? @db.Date
  /// 現場の手動補正を保護するフラグ（true のとき取込同期で着手日を上書きしない）。
  plannedStartDateManuallySet Boolean   @default(false)
  plannedEndDate              DateTime? @db.Date
  /// 直近で CSV 同期に再出現した時刻（差分同期の鮮度管理）。
  lastSeenAt                  DateTime  @default(now())
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  csvDashboardRow CsvDashboardRow @relation(fields: [csvDashboardRowId], references: [id], onDelete: Cascade)

  @@unique([csvDashboardRowId], map: "ProductionScheduleOrderSupplement_unique_row")
  @@unique([csvDashboardId, sourceCsvDashboardId, productNo, resourceCd, processOrder], map: "ProductionScheduleOrderSupplement_unique_source_key")
  @@index([csvDashboardId], map: "ProductionScheduleOrderSupplement_idx_dashboard")
  @@index([sourceCsvDashboardId], map: "ProductionScheduleOrderSupplement_idx_source_dashboard")
  @@index([plannedStartDate], map: "ProductionScheduleOrderSupplement_idx_start_date")
  @@index([lastSeenAt], map: "ProductionScheduleOrderSupplement_idx_last_seen")
}

/// Gmail FKOJUNST CSV 由来の工順ステータス（最新CSVが正。source 単位で全置換）
model ProductionScheduleFkojunstStatus {
  id                   String   @id @default(uuid())
  csvDashboardId       String
  csvDashboardRowId    String
  sourceCsvDashboardId String
  productNo            String   @db.VarChar(20)
  resourceCd           String   @db.VarChar(20)
  processOrder         String   @db.VarChar(20)
  /// C=加工完了 P=未確定 S=現場着手 R=移動票発行のみ X=場外
  statusCode           String   @db.VarChar(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  csvDashboardRow CsvDashboardRow @relation(fields: [csvDashboardRowId], references: [id], onDelete: Cascade)

  @@unique([csvDashboardRowId], map: "ProductionScheduleFkojunstStatus_unique_row")
  @@unique([csvDashboardId, sourceCsvDashboardId, productNo, resourceCd, processOrder], map: "ProductionScheduleFkojunstStatus_unique_source_key")
  @@index([csvDashboardId], map: "ProductionScheduleFkojunstStatus_idx_dashboard")
  @@index([sourceCsvDashboardId], map: "ProductionScheduleFkojunstStatus_idx_source_dashboard")
}

/// Gmail 件名 `FKOJUNST_Status` のCSV由来。キーは (FKOJUN, FKOTEICD→本体FSIGENCD, FSEZONO→本体ProductNo)。最新FUPDTEDTを正。
model ProductionScheduleFkojunstMailStatus {
  id                   String   @id @default(uuid())
  csvDashboardId       String
  csvDashboardRowId    String
  sourceCsvDashboardId String
  fkojun               String   @db.VarChar(20)
  fkoteicd             String   @db.VarChar(40)
  fsezono              String   @db.VarChar(32)
  statusCode           String   @db.VarChar(1)
  sourceUpdatedAt      DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  csvDashboardRow CsvDashboardRow @relation(fields: [csvDashboardRowId], references: [id], onDelete: Cascade)

  @@unique([csvDashboardRowId], map: "PSFkojunstMailStatus_unique_row")
  @@unique([csvDashboardId, sourceCsvDashboardId, fkojun, fkoteicd, fsezono], map: "PSFkojunstMailStatus_unique_src_key")
  @@index([csvDashboardId], map: "PSFkojunstMailStatus_idx_dashboard")
  @@index([sourceCsvDashboardId], map: "PSFkojunstMailStatus_idx_source_dashboard")
}

/// 順位ボード用: FKOJUNST_Status raw 全体から抽出した「強い工程変更残骸」疑い snapshot。
model ProductionScheduleProcessChangeResidualSnapshot {
  sourceCsvDashboardId String   @id
  rawMailRowsRevision  String
  algorithmVersion     Int      @default(1)
  evidenceCount        Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  evidenceRows ProductionScheduleProcessChangeResidualEvidence[]

  @@index([rawMailRowsRevision], map: "PSProcChangeResidualSnapshot_idx_revision")
}

/// 順位ボード用: 表示時に raw FKOJUNST_Status 全件を読まないための residual evidence。
model ProductionScheduleProcessChangeResidualEvidence {
  id                            String   @id @default(uuid())
  sourceCsvDashboardId          String
  productNo                     String   @db.VarChar(32)
  fkojun                        String   @db.VarChar(20)
  resourceCd                    String   @db.VarChar(40)
  currentStatusCode             String   @db.VarChar(1)
  currentSourceUpdatedAt        DateTime
  completedOtherResourceCd      String   @db.VarChar(40)
  completedOtherStatusCode      String   @db.VarChar(1)
  completedOtherSourceUpdatedAt DateTime
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  snapshot ProductionScheduleProcessChangeResidualSnapshot @relation(fields: [sourceCsvDashboardId], references: [sourceCsvDashboardId], onDelete: Cascade)

  @@unique([sourceCsvDashboardId, productNo, fkojun, resourceCd], map: "PSProcChangeResidualEvidence_unique_key")
  @@index([sourceCsvDashboardId], map: "PSProcChangeResidualEvidence_idx_source")
}

/// Gmail 件名 `FHINMEI_MH_SH` の補完CSV由来。同一取り込み実行内の重複 FSEIBAN は末尾行が正（同期処理で解決）。
model ProductionScheduleSeibanMachineNameSupplement {
  id                   String   @id @default(uuid())
  sourceCsvDashboardId String
  fseiban              String   @db.VarChar(64)
  machineName          String   @db.VarChar(500)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([sourceCsvDashboardId, fseiban], map: "PSSeibanMachNmSup_unique_src_fsb")
  @@index([fseiban], map: "PSSeibanMachNmSup_idx_fseiban")
}

/// Gmail 件名 `CustomerSCAW` 由来。FANKENMEI と MH/SH 行の FHINMEI を正規化照合し、同一製番は後勝ちで顧客名を紐付け（source 単位で全置換）。
model ProductionScheduleFseibanCustomerScaw {
  id                   String   @id @default(uuid())
  sourceCsvDashboardId String
  fseiban              String   @db.VarChar(64)
  customerName         String   @db.VarChar(500)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([sourceCsvDashboardId, fseiban], map: "PSFseibanCustScaw_unique_src_fsb")
  @@index([fseiban], map: "PSFseibanCustScaw_idx_fseiban")
}

/// Gmail 件名 `FKOBAINO` の購買CSV由来。取り込みごとに upsert し、同一キーは更新・未登録は追加（履歴蓄積）。
model PurchaseOrderLookupRow {
  id                         String   @id @default(uuid())
  sourceCsvDashboardId       String
  purchaseOrderNo            String   @db.VarChar(20)
  purchasePartCodeRaw        String   @db.VarChar(128)
  purchasePartCodeNormalized String   @db.VarChar(128)
  /// 生産日程 `FHINCD` との照合キー（括弧除去 + 末尾数値枝番除去）。upsert 一意制約はこの列。
  purchasePartCodeMatchKey   String   @db.VarChar(128)
  seiban                     String   @db.VarChar(64)
  purchasePartName           String   @db.VarChar(500)
  acceptedQuantity           Int      @default(0)
  lineIndex                  Int      @default(0)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@unique([sourceCsvDashboardId, purchaseOrderNo, seiban, purchasePartCodeMatchKey], map: "POLookup_unique_src_po_seiban_matchkey")
  @@index([purchaseOrderNo], map: "POLookup_idx_purchaseOrderNo")
  @@index([sourceCsvDashboardId], map: "POLookup_idx_sourceDashboard")
}

model ProductionScheduleRowNote {
  id                String    @id @default(uuid())
  csvDashboardId    String
  csvDashboardRowId String
