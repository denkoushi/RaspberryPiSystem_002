# Copy to `.env` on the DGX host (do not commit `.env`).
# Paths must stay under private-personal only — never mount system-prod secrets or logs.
# Enforcement: start-private-comfyui.sh sources boundary-check.sh (prefix `/srv/dgx/private-personal`).

# Root for bind-mounted ComfyUI state (models, outputs, user workflows cache).
COMFYUI_DATA_ROOT=/srv/dgx/private-personal/comfyui/data

# Published only on loopback on the DGX host (LAN-wide bind is intentionally avoided).
COMFYUI_PORT=8188

# Compose project name (isolates container names / networks from other stacks).
COMPOSE_PROJECT_NAME=dgx-private-comfyui

# External Docker network created for private-personal workloads (ExecPlan naming).
DGX_PRIVATE_NETWORK_NAME=dgx_private_personal_net
