# NVIDIA Spark ComfyUI playbook aligns with: CUDA 13 + PyTorch cu130 + ComfyUI from GitHub.
# Copy this file to `Dockerfile` beside `compose.yaml` before `docker compose build`.
#
# References:
# - https://build.nvidia.com/spark/comfy-ui/instructions
# - https://github.com/NVIDIA/dgx-spark-playbooks/tree/main/nvidia/comfy-ui

FROM nvcr.io/nvidia/cuda:13.0.1-devel-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-venv \
    python3-pip \
    git \
    wget \
    ca-certificates \
    build-essential \
    python3-dev \
  && rm -rf /var/lib/apt/lists/*

# Isolated venv (matches playbook spirit; avoids PEP 668 conflicts on the base image).
RUN python3 -m venv /opt/comfyui-venv
ENV PATH="/opt/comfyui-venv/bin:${PATH}"

RUN pip install --no-cache-dir torch torchvision --index-url https://download.pytorch.org/whl/cu130

WORKDIR /opt/ComfyUI
RUN git clone --depth 1 https://github.com/comfyanonymous/ComfyUI.git .

RUN pip install --no-cache-dir -r requirements.txt

EXPOSE 8188

# DGX Spark unified-memory safeguard:
# avoid extra copy on safetensors device transfer when ComfyUI's utils still uses copy=True.
RUN python - <<'PY'
from pathlib import Path
path = Path("/opt/ComfyUI/comfy/utils.py")
src = path.read_text(encoding="utf-8")
if "copy=True" in src:
    path.write_text(src.replace("copy=True", "copy=False"), encoding="utf-8")
PY

# DGX Spark GB10 uses unified CPU/GPU memory. Use host-available memory for
# ComfyUI's free-memory estimate on GB10 so large models are not offloaded early.
RUN python - <<'PY'
from pathlib import Path
path = Path("/opt/ComfyUI/comfy/model_management.py")
src = path.read_text(encoding="utf-8")
helper = '''def is_nvidia_gb10_cuda_device(dev):
    if not (hasattr(dev, 'type') and dev.type == 'cuda'):
        return False
    try:
        return "GB10" in torch.cuda.get_device_name(dev)
    except Exception:
        return False

'''
if "def is_nvidia_gb10_cuda_device" not in src:
    src = src.replace("def free_memory(memory_required, device, keep_loaded=[], for_dynamic=False, pins_required=0, ram_required=0):", helper + "def free_memory(memory_required, device, keep_loaded=[], for_dynamic=False, pins_required=0, ram_required=0):")
branch = '''        elif is_nvidia_gb10_cuda_device(dev):
            stats = torch.cuda.memory_stats(dev)
            mem_active = stats['active_bytes.all.current']
            mem_reserved = stats['reserved_bytes.all.current']
            mem_free_torch = mem_reserved - mem_active
            mem_free_total = psutil.virtual_memory().available + mem_free_torch
'''
needle = '''        else:
            stats = torch.cuda.memory_stats(dev)
            mem_active = stats['active_bytes.all.current']
            mem_reserved = stats['reserved_bytes.all.current']
            mem_free_cuda, _ = torch.cuda.mem_get_info(dev)
            mem_free_torch = mem_reserved - mem_active
            mem_free_total = mem_free_cuda + mem_free_torch
'''
if "elif is_nvidia_gb10_cuda_device(dev):" not in src:
    src = src.replace(needle, branch + needle)
path.write_text(src, encoding="utf-8")
PY

# Listen inside the container; host publish is restricted to 127.0.0.1 in compose.yaml.
# Keep runtime args in compose/.env via COMFYUI_EXTRA_ARGS.
CMD ["python", "main.py", "--listen", "0.0.0.0", "--port", "8188"]
