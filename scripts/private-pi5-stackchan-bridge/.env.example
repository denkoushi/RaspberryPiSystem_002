STACKCHAN_BRIDGE_HOST=0.0.0.0
STACKCHAN_BRIDGE_PORT=18080
# Optional: limit seconds for reading POST body (0 or unset = no limit). Try 30–120 if STT WAV stalls.
# STACKCHAN_REQUEST_READ_TIMEOUT_SEC=0

DGX_BASE_URL=http://100.118.82.72:38081
DGX_MODEL=system-prod-primary
DGX_LLM_SHARED_TOKEN=replace-me
DGX_RUNTIME_AUTO_START=false
DGX_RUNTIME_CONTROL_TOKEN=
DGX_RUNTIME_START_PATH=/start
DGX_RUNTIME_READY_PATH=/v1/models
# blue / vLLM cold start では 60 秒未満では不足しうる（推奨 300–600）
DGX_RUNTIME_READY_TIMEOUT_SEC=600
DGX_RUNTIME_READY_POLL_SEC=1

# Optional inbound guard from StackChan device
STACKCHAN_TOKEN=

UPSTREAM_TIMEOUT_SEC=45

# Low-latency chat defaults for StackChan voice interaction
STACKCHAN_CHAT_DEFAULT_MAX_TOKENS=160
STACKCHAN_CHAT_MAX_TOKENS_CAP=192
STACKCHAN_CHAT_MAX_MESSAGES=8
STACKCHAN_CHAT_ALLOW_THINKING=false

# Optional read-only Home Assistant context injected into chat prompts.
HOME_ASSISTANT_CONTEXT_ENABLED=false
HOME_ASSISTANT_BASE_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=
HOME_ASSISTANT_CONTEXT_ENTITIES=
HOME_ASSISTANT_TIMEOUT_SEC=5

# STT bridge mode:
# - upstream-openai      : forward audio to OpenAI-compatible transcription endpoint
# - faster-whisper-local : run faster-whisper on Pi5 local CPU/GPU
STT_PROVIDER=upstream-openai
STT_UPSTREAM_BASE_URL=http://100.118.82.72:38081
STT_UPSTREAM_PATH=/v1/audio/transcriptions
STT_UPSTREAM_AUTH_MODE=x-llm-token
STT_UPSTREAM_TOKEN=replace-me
STT_UPSTREAM_MODEL=whisper-1
STT_UPSTREAM_TIMEOUT_SEC=60

# Used when STT_PROVIDER=faster-whisper-local
STT_LOCAL_MODEL=small
STT_LOCAL_DEVICE=cpu
STT_LOCAL_COMPUTE_TYPE=int8
STT_LOCAL_LANGUAGE_DEFAULT=ja
STT_LOCAL_VAD_FILTER=true
STT_LOCAL_RETRY_WITHOUT_VAD=true
# Optional: if local faster-whisper returns empty after retries, forward to STT upstream.
STT_LOCAL_FALLBACK_TO_UPSTREAM_ON_EMPTY=false

# Voice turn (STT -> chat -> Pi5 VOICEVOX -> optional StackChan playback)
VOICEVOX_BASE_URL=http://127.0.0.1:50021
VOICEVOX_ENABLED=true
VOICEVOX_SPEAKER_ID=1
VOICEVOX_TIMEOUT_SEC=60

# Required for audioUrl from StackChan (do NOT use 127.0.0.1 — device cannot reach Pi5 loopback)
VOICE_AUDIO_PUBLIC_BASE_URL=http://192.168.128.112:18080
# Optional alternative: host only (port from STACKCHAN_BRIDGE_PORT)
# VOICE_AUDIO_PUBLIC_HOST=192.168.128.112

# Max decoded WAV bytes per voice-turn (default 2 MiB)
VOICE_TURN_MAX_AUDIO_BYTES=2097152
# Max JSON HTTP body for voice-turn (default max(4x audio cap, 8 MiB)); raw WAV uses audio cap only
# VOICE_TURN_MAX_JSON_BODY_BYTES=8388608

# Optional: Pi5 triggers device HTTP playback (requires firmware private-bridge routes)
STACKCHAN_DEVICE_BASE_URL=http://192.168.128.50
STACKCHAN_DEVICE_CONTROL_ENABLED=false
STACKCHAN_DEVICE_TIMEOUT_SEC=15
