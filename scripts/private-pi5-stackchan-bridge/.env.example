STACKCHAN_BRIDGE_HOST=0.0.0.0
STACKCHAN_BRIDGE_PORT=18080

DGX_BASE_URL=http://100.118.82.72:38081
DGX_MODEL=system-prod-primary
DGX_LLM_SHARED_TOKEN=replace-me
DGX_RUNTIME_AUTO_START=false
DGX_RUNTIME_CONTROL_TOKEN=
DGX_RUNTIME_START_PATH=/start
DGX_RUNTIME_READY_PATH=/v1/models
# blue / vLLM cold start では 60 秒未満では不足しうる（推奨 300–600）
DGX_RUNTIME_READY_TIMEOUT_SEC=600
DGX_RUNTIME_READY_POLL_SEC=1

# Optional inbound guard from StackChan device
STACKCHAN_TOKEN=

UPSTREAM_TIMEOUT_SEC=45

# STT bridge mode:
# - upstream-openai      : forward audio to OpenAI-compatible transcription endpoint
# - faster-whisper-local : run faster-whisper on Pi5 local CPU/GPU
STT_PROVIDER=upstream-openai
STT_UPSTREAM_BASE_URL=http://100.118.82.72:38081
STT_UPSTREAM_PATH=/v1/audio/transcriptions
STT_UPSTREAM_AUTH_MODE=x-llm-token
STT_UPSTREAM_TOKEN=replace-me
STT_UPSTREAM_MODEL=whisper-1
STT_UPSTREAM_TIMEOUT_SEC=60

# Used when STT_PROVIDER=faster-whisper-local
STT_LOCAL_MODEL=small
STT_LOCAL_DEVICE=cpu
STT_LOCAL_COMPUTE_TYPE=int8
