{
  "schemaVersion": 1,
  "pi5ControlPlane": {
    "id": "pi5",
    "inventoryGroup": "server",
    "adapterId": "pi5-blue-green",
    "requiredHostCount": 1
  },
  "terminalProfiles": [
    {
      "id": "kiosk",
      "inventoryGroup": "kiosk",
      "rolloutOrder": 10,
      "impactComponent": "kiosk-role",
      "adapterId": "generic-systemd",
      "playbook": "playbooks/deploy-staged.yml",
      "noticeSeconds": 60,
      "canaryGroup": "kiosk_canary",
      "approvalPolicy": "human",
      "adapterOptions": {
        "systemdUnits": [
          "lightdm.service",
          "status-agent.service",
          "status-agent.timer",
          "haizen-agent.service",
          "kiosk-browser.service"
        ],
        "rollbackPaths": [
          "/etc/raspi-status-agent.conf",
          "/etc/systemd/system/status-agent.service",
          "/etc/systemd/system/status-agent.timer",
          "/etc/systemd/system/timers.target.wants/status-agent.timer",
          "/etc/systemd/system/multi-user.target.wants/status-agent.service",
          "/etc/polkit-1/rules.d/50-pcscd-allow-all.rules",
          "/etc/NetworkManager/NetworkManager.conf",
          "/opt/RaspberryPiSystem_002/clients/nfc-agent/.env",
          "/opt/RaspberryPiSystem_002/clients/barcode-agent/.env",
          "/etc/raspi-haizen-agent.conf",
          "/etc/systemd/system/haizen-agent.service",
          "/etc/systemd/system/multi-user.target.wants/haizen-agent.service",
          "/opt/RaspberryPiSystem_002/clients/torque-agent/.env",
          "/usr/bin/chromium-browser",
          "/usr/local/bin/kiosk-launch.sh",
          "/etc/systemd/system/kiosk-browser.service",
          "/etc/systemd/system/graphical.target.wants/kiosk-browser.service",
          "/usr/local/bin/show-kiosk-panel.sh",
          "/usr/local/bin/ibus-kiosk-init.sh",
          "/usr/local/bin/ibus-process-owner.sh",
          "/usr/local/bin/clamav-kiosk-scan.sh",
          "/usr/local/bin/rkhunter-kiosk-scan.sh",
          "/var/spool/cron/crontabs/root"
        ],
        "healthProbeIds": [
          "display-manager",
          "status-agent",
          "nfc-agent",
          "barcode-agent",
          "torque-agent",
          "ready-sha"
        ],
        "readyAuthority": "control-plane"
      }
    },
    {
      "id": "signage",
      "inventoryGroup": "signage",
      "rolloutOrder": 20,
      "impactComponent": "signage-role",
      "adapterId": "signage-systemd",
      "playbook": "playbooks/deploy-staged.yml",
      "noticeSeconds": 0,
      "canaryGroup": "signage_canary",
      "approvalPolicy": "health-only",
      "adapterOptions": {
        "systemdUnits": [
          "lightdm.service",
          "status-agent.service",
          "status-agent.timer",
          "haizen-agent.service",
          "signage-lite.service",
          "signage-lite-update.service",
          "signage-lite-update.timer",
          "signage-lite-watchdog.service",
          "signage-lite-watchdog.timer",
          "signage-daily-reboot.service",
          "signage-daily-reboot.timer"
        ],
        "rollbackPaths": [
          "/etc/raspi-status-agent.conf",
          "/etc/systemd/system/status-agent.service",
          "/etc/systemd/system/status-agent.timer",
          "/etc/systemd/system/timers.target.wants/status-agent.timer",
          "/etc/systemd/system/multi-user.target.wants/status-agent.service",
          "/etc/polkit-1/rules.d/50-pcscd-allow-all.rules",
          "/etc/NetworkManager/NetworkManager.conf",
          "/opt/RaspberryPiSystem_002/clients/nfc-agent/.env",
          "/opt/RaspberryPiSystem_002/clients/barcode-agent/.env",
          "/etc/raspi-haizen-agent.conf",
          "/etc/systemd/system/haizen-agent.service",
          "/etc/systemd/system/multi-user.target.wants/haizen-agent.service",
          "/etc/tmpfiles.d/signage-lite.conf",
          "/usr/local/share/signage-maintenance.svg",
          "/run/signage/current.jpg",
          "/run/signage/current.tmp.jpg",
          "/usr/local/bin/signage-update.sh",
          "/usr/local/bin/signage-display.sh",
          "/usr/local/bin/signage-stop.sh",
          "/usr/local/bin/signage-lite-watchdog.sh",
          "/etc/systemd/system/signage-lite.service",
          "/etc/systemd/system/signage-lite-update.service",
          "/etc/systemd/system/signage-lite-update.timer",
          "/etc/systemd/system/signage-lite-watchdog.service",
          "/etc/systemd/system/signage-lite-watchdog.timer",
          "/etc/systemd/system/signage-daily-reboot.service",
          "/etc/systemd/system/signage-daily-reboot.timer",
          "/etc/systemd/system/graphical.target.wants/signage-lite.service",
          "/etc/systemd/system/timers.target.wants/signage-lite-update.timer",
          "/etc/systemd/system/timers.target.wants/signage-lite-watchdog.timer",
          "/etc/systemd/system/timers.target.wants/signage-daily-reboot.timer",
          "/run/systemd/system/signage-lite.service"
        ],
        "healthProbeIds": [
          "display-manager",
          "status-agent",
          "signage-endpoint",
          "ready-sha"
        ],
        "readyAuthority": "terminal"
      }
    }
  ],
  "pathMappings": [
    {"match": "prefix", "path": "docs/", "component": "neutral"},
    {"match": "prefix", "path": ".cursor/", "component": "neutral"},
    {"match": "prefix", "path": ".agent/", "component": "neutral"},
    {"match": "prefix", "path": ".github/", "component": "neutral"},
    {"match": "prefix", "path": "scripts/deploy/tests/", "component": "neutral"},
    {"match": "exact", "path": "AGENTS.md", "component": "neutral"},
    {"match": "prefix", "path": "README", "component": "neutral"},
    {"match": "exact", "path": "EXEC_PLAN.md", "component": "neutral"},

    {"match": "exact", "path": ".gitignore", "component": "deploy-control"},
    {"match": "exact", "path": "infrastructure/ansible/ansible-readonly.cfg", "component": "deploy-control"},
    {"match": "exact", "path": "scripts/update-all-clients.sh", "component": "deploy-control"},
    {"match": "exact", "path": "scripts/deploy/classify-deploy-impact.py", "component": "deploy-control"},
    {"match": "exact", "path": "scripts/deploy/recover-pi4.py", "component": "deploy-control"},
    {"match": "exact", "path": "scripts/deploy/rollback-manifest.py", "component": "deploy-control"},
    {"match": "exact", "path": "scripts/deploy/rolling-release.py", "component": "deploy-control"},
    {"match": "exact", "path": "scripts/deploy/terminal-profile-registry.json", "component": "deploy-control"},
    {"match": "exact", "path": "scripts/deploy/terminal_profile_registry.py", "component": "deploy-control"},
    {"match": "exact", "path": "scripts/deploy/terminal_profile_contracts.py", "component": "deploy-control"},
    {"match": "exact", "path": "scripts/deploy/terminal-runtime-manifest.py", "component": "deploy-control"},
    {"match": "prefix", "path": "scripts/deploy/rolling_release/", "component": "deploy-control"},

    {"match": "exact", "path": "scripts/deploy/signage-runtime-proof.py", "component": "signage-role"},
    {"match": "prefix", "path": "apps/api/prisma/migrations/", "component": "migration"},
    {"match": "prefix", "path": "apps/api/", "component": "server-app"},
    {"match": "prefix", "path": "apps/web/", "component": "server-app"},
    {"match": "prefix", "path": "packages/", "component": "server-app"},
    {"match": "exact", "path": "infrastructure/docker/Dockerfile.torque-agent", "component": "torque-agent"},
    {"match": "prefix", "path": "infrastructure/docker/", "component": "server-app"},
    {"match": "exact", "path": "package.json", "component": "server-app"},
    {"match": "exact", "path": "pnpm-lock.yaml", "component": "server-app"},
    {"match": "exact", "path": "pnpm-workspace.yaml", "component": "server-app"},
    {"match": "prefix", "path": "clients/nfc-agent/", "component": "nfc-agent"},
    {"match": "prefix", "path": "clients/barcode-agent/", "component": "barcode-agent"},
    {"match": "prefix", "path": "clients/torque-agent/", "component": "torque-agent"},
    {"match": "prefix", "path": "clients/status-agent/", "component": "status-agent"},
    {"match": "prefix", "path": "infrastructure/ansible/roles/kiosk/", "component": "kiosk-role"},
    {"match": "prefix", "path": "infrastructure/ansible/roles/client/", "component": "client-role"},
    {"match": "prefix", "path": "infrastructure/ansible/roles/signage/", "component": "signage-role"},
    {"match": "prefix", "path": "infrastructure/ansible/templates/signage", "component": "signage-role"},
    {"match": "exact", "path": "infrastructure/ansible/templates/torque-agent.env.j2", "component": "torque-agent"},
    {"match": "exact", "path": "infrastructure/ansible/tasks/preflight-signage.yml", "component": "signage-role"},
    {"match": "prefix", "path": "infrastructure/ansible/playbooks/", "component": "global"},
    {"match": "prefix", "path": "infrastructure/ansible/group_vars/", "component": "global"},
    {"match": "prefix", "path": "infrastructure/ansible/inventory", "component": "global"}
  ],
  "componentProfiles": {
    "neutral": [],
    "deploy-control": [],
    "migration": [],
    "server-app": [],
    "nfc-agent": ["kiosk"],
    "barcode-agent": ["kiosk"],
    "torque-agent": ["kiosk"],
    "status-agent": ["kiosk", "signage"],
    "kiosk-role": ["kiosk"],
    "client-role": ["kiosk", "signage"],
    "signage-role": ["signage"],
    "global": ["kiosk", "signage"]
  }
}
