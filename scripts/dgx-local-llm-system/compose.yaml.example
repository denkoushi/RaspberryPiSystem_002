services:
  tailscale:
    image: tailscale/tailscale:stable
    hostname: dgx-local-llm-system
    environment:
      TS_AUTHKEY: ${TS_AUTHKEY}
      TS_STATE_DIR: /var/lib/tailscale
      TS_EXTRA_ARGS: ${TS_EXTRA_ARGS:---advertise-tags=tag:llm}
      TS_USERSPACE: "false"
    volumes:
      - ../state/tailscale:/var/lib/tailscale
      - /dev/net/tun:/dev/net/tun
    cap_add:
      - NET_ADMIN
      - NET_RAW
    restart: unless-stopped

  nginx:
    image: nginx:1.27-alpine
    depends_on:
      - tailscale
    network_mode: service:tailscale
    environment:
      LLM_SHARED_TOKEN: ${LLM_SHARED_TOKEN}
      EMBEDDING_API_KEY: ${EMBEDDING_API_KEY}
      LLM_RUNTIME_CONTROL_TOKEN: ${LLM_RUNTIME_CONTROL_TOKEN}
      DOCKER_BRIDGE_GATEWAY: ${DOCKER_BRIDGE_GATEWAY}
    volumes:
      - ../config/nginx/default.conf.template:/etc/nginx/templates/default.conf.template:ro
    command: >
      sh -lc "envsubst '$${LLM_SHARED_TOKEN} $${EMBEDDING_API_KEY} $${LLM_RUNTIME_CONTROL_TOKEN} $${DOCKER_BRIDGE_GATEWAY}'
      < /etc/nginx/templates/default.conf.template
      > /etc/nginx/conf.d/default.conf && exec nginx -g 'daemon off;'"
    restart: unless-stopped
