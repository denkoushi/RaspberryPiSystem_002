# コピー先: /srv/dgx/system-prod/secrets/gateway-server.env (chmod 600)
# Pi5 vault の vault_api_local_llm_shared_token / runtime_control と整合させる
LLM_SHARED_TOKEN=replace-me
LLM_RUNTIME_CONTROL_TOKEN=replace-me
# 既定は現行 llama.cpp（green）。切替時だけ blue に変更
# ACTIVE_LLM_BACKEND=green
# blue は歴史的に TRT-LLM 想定で命名しているが、現時点の第一候補は
# `Qwen3.6-27B-NVFP4` を Spark 向け vLLM image で `127.0.0.1:38083` に出す構成。
# 必要なら backend ごとの内部 upstream を上書きする
# GREEN_LLM_BASE_URL=http://127.0.0.1:38082
# BLUE_LLM_BASE_URL=http://127.0.0.1:38083
# control / gateway を `@reboot` や手動で起動する場合も、この env を source する想定
# 任意（空なら gateway は EMBEDDING_API_KEY なしで動作）
# EMBEDDING_API_KEY=
