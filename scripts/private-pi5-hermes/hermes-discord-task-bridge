#!/usr/bin/env python3
"""Discord /task bridge CLI helper for local smoke/troubleshooting."""
from __future__ import annotations

import sys
from pathlib import Path

_ROOT = Path(__file__).resolve().parent
# Deployed: ~/.hermes/bin/hermes-discord-task-bridge + ~/.hermes/discord-task-bridge/lib/
_deploy_root = _ROOT.parent / "discord-task-bridge"
if (_deploy_root / "lib").is_dir():
    sys.path.insert(0, str(_deploy_root))
else:
    sys.path.insert(0, str(_ROOT))

from lib.discord_task_bridge import run_cli  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(run_cli())
